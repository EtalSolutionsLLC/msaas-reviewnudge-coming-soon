APP_SLUG=reviewnudge-coming-soon
DEPLOY_ENV=dev
RUNTIME_ADAPTER_CODE=bash-local

# Optional canonical database selector. Uncomment only when the project uses a
# database. Examples: postgres-local, postgres-neon, postgres-gcp,
# mssql-azure, mssql-azurevm, mssql-azuremanaged.
# DB_PROVIDER_PLATFORM_CODE=postgres-local
# DB_NAME=app
# DB_USER=app_user
# DB_PASSWORD=replace-with-development-only-password
# DB_HOST=
# DB_PORT=5432
# DATABASE_SSL_MODE=disable

# Purpose-based control-plane API credentials. Set only the credentials used by
# the selected modules. These values are protected by Portmason and are never
# injected into application runtime services.
# DB_API_KEY=
# RUNTIME_API_KEY=
# DNS_API_KEY=
# STORAGE_API_KEY=
# EMAIL_API_KEY=
# BILLING_API_KEY=

# Neon settings for postgres-neon. DB_API_KEY is the canonical Neon management
# credential and is synchronized to GCP Secret Manager for non-dev GCP deployments.
# NEON_PROJECT_ID=
# NEON_PROJECT_NAME=
# NEON_ORG_ID=
# NEON_BRANCH_NAME=main
# NEON_REGION_ID=aws-us-west-2
# NEON_PG_VERSION=17
# NEON_USE_POOLER=true

TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=web
TRAEFIK_TLS=false

# ------------------------------
# anything below this line probably shouldn't be edited manually
# ------------------------------
STACK=${APP_SLUG}-${DEPLOY_ENV}
LOCAL_DOMAIN=localtest.me
APP_HOST=$STACK.$LOCAL_DOMAIN

URI_SCHEME=http
WP_SITE_URL=$URI_SCHEME://$APP_HOST

PM_SERVE_EXCLUDE_ADDTL_DIRS=portmason
# ------------------------------
# Et al Solutions - EPC Tag Contract
# ------------------------------
OWNER_ALIAS=etalsolutions
MANAGED_BY=compose
LIFECYCLE=long-lived
DATA_CLASS=confidential
DATA_LIFECYCLE=persistent
PROJECT_ID=reviewnudge-coming--1777712786
DEPLOYMENT_ID=reviewnudge-coming--1777712786
