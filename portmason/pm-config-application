#!/usr/bin/env bash
set -euo pipefail
pm_config_application() {
    local scopes='application,web,app,jobs,worker'
    pm_config_register APP_ADMIN_USER secret "$scopes" APP_ADMIN_USER optional
    pm_config_register APP_ADMIN_PASSWORD secret "$scopes" APP_ADMIN_PASSWORD optional
    pm_config_register APP_SECRET secret "$scopes" APP_SECRET optional
    pm_config_register SESSION_SECRET secret "$scopes" SESSION_SECRET optional
    pm_config_register COOKIE_SECRET secret "$scopes" COOKIE_SECRET optional
    pm_config_register JWT_SECRET secret "$scopes" JWT_SECRET optional
    pm_config_register CHECKOUT_TOKEN_KEY secret "$scopes" CHECKOUT_TOKEN_KEY optional
    pm_config_register BILLING_EVENT_SECRET secret "$scopes" BILLING_EVENT_SECRET optional
    pm_config_register REVIEW_PROVIDER_EVENT_SECRET secret "$scopes" REVIEW_PROVIDER_EVENT_SECRET optional
    pm_config_register TURNSTILE_SITE_KEY var "$scopes" TURNSTILE_SITE_KEY optional
    pm_config_register TURNSTILE_SECRET_KEY secret "$scopes" TURNSTILE_SECRET_KEY optional
    pm_config_register ABUSE_IDENTIFIER_SALT secret "$scopes" ABUSE_IDENTIFIER_SALT optional
}
