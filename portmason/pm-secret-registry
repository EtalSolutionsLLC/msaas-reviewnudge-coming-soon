#!/usr/bin/env bash
set -euo pipefail

# Compatibility facade. PM Configuration Manager is the sole registry owner.
: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)}"
# shellcheck disable=SC1090
. "${PORTMASON_SHARE}/pm-helpers"

_pm_secret_registry_previous_entities="${PM_CONFIG_ENTITIES-}"
if [[ -n "$_pm_secret_registry_previous_entities" ]]; then
    PM_CONFIG_ENTITIES="${_pm_secret_registry_previous_entities},database,slack"
else
    PM_CONFIG_ENTITIES="database,slack"
fi
pm_config_manager_prepare compatibility
PM_CONFIG_ENTITIES="$_pm_secret_registry_previous_entities"
unset _pm_secret_registry_previous_entities

pm_secret_registry_records() {
    local key type scopes classification
    for key in "${PM_CONFIG_KEYS[@]}"; do
        type="${PM_CONFIG_TYPE[$key]}"
        case "$type" in
            secret) classification=runtime ;;
            control-plane) classification=control-plane ;;
            *) continue ;;
        esac
        scopes="${PM_CONFIG_SCOPES[$key]}"
        printf '%s|%s|%s\n' "$key" "$classification" "$scopes"
    done
}

pm_secret_registry_record_for_key() {
    local wanted="${1:?secret key required}"
    pm_secret_registry_records | awk -F'|' -v wanted="$wanted" '$1 == wanted {print; found=1; exit} END {exit !found}'
}

pm_secret_registry_keys_for_classification() {
    local wanted="${1:?classification required}"
    case "$wanted" in
        runtime) pm_config_keys_for_type secret ;;
        control-plane) pm_config_keys_for_type control-plane ;;
        *) return 1 ;;
    esac
}

pm_secret_registry_role_matches() {
    pm_config_csv_contains "${1-}" "${2:?service role required}"
}

pm_secret_registry_keys_for_role() {
    pm_config_keys_for_scopes secret "${1:?service role required}"
}

pm_secret_registry_validate() {
    pm_config_validate_registry
}

pm_secret_registry_refresh_derived_arrays() {
    pm_config_refresh_canonical_arrays
}
