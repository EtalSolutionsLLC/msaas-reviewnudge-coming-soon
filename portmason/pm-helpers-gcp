confirm_and_publish_mgt_scripts_artifact(){
    if [[ -z "${GCS_BUCKET:-}" ]]; then
        log "Skipping mgt_scripts artifact publication since GCS_BUCKET is undefined"
	return 0
    fi

    local question="Publish mgt-scripts artifact to cloud for steady-state?"
    local prompt="(y=yes, n=no, c=cancel) [n]:"
    local default="no" # default answer

    while true; do
    # shellcheck disable=SC2162
        read -r -p "${question} ${prompt} " reply || return 2

        # Empty input => default
        if [[ -z "${reply}" ]]; then
            if [[ "${default}" == "yes" ]]; then
                break
            else
                return 0
            fi
        fi

        case "${reply}" in
            y|Y|yes|YES|Yes) break ;;
            n|N|no|NO|No)    return 0 ;;
            c|C|cancel|CANCEL|Cancel) die "Execution cancelled by user." ;;
            *) echo "Please answer: y=yes, n=no, c=cancel (Enter defaults to ${default})." ;;
        esac
    done

    log "Publishing management scripts artifact to GCS bucket gs://${GCS_BUCKET}"
    . pm-publish-mgt-scripts-artifact || warn "Failed to publish management scripts artifact. Continuing anyway..."
}

env_injection_args__gcp() {
  # Reads NUL-separated KEY\0VALUE\0... from stdin and prints NUL-separated
  # argv tokens for gcloud:
  #   --set-env-vars\0KEY=VALUE\0...

  local key="" val=""

  while IFS= read -r -d '' key; do
    # If key contains '=', warn and strip '=' chars from key
    if [[ "$key" == *"="* ]]; then
      warn "env_injection_args__gcp: key contains '='; stripping and continuing" "key=${key}"
      key="${key//=}"
    fi

    # If key becomes empty/invalid, warn+skip (and skip the subsequent value too, if present)
    if [[ -z "$key" ]]; then
      warn "env_injection_args__gcp: empty key after normalization; skipping pair"
      IFS= read -r -d '' _ 2>/dev/null || true
      continue
    fi

    # Read value; if missing (dangling key), treat as empty value
    if IFS= read -r -d '' val 2>/dev/null; then
      :
    else
      val=""
    fi

    # Emit one argv token (NUL-separated) for gcloud
    printf '%s\0%s\0' "--set-env-vars" "${key}=${val}"
  done
}

