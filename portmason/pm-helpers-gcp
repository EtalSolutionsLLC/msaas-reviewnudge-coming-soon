}
secret_injection_args__gcp() {
    # Reads NUL-separated KEY\0VALUE\0... from stdin and prints NUL-separated
    # argv tokens for gcloud:
    #   --set-secrets\0KEY=VALUE\0...

    local key="" val=""

    while IFS= read -r -d '' key; do
        # If key contains '=', warn and strip '=' chars from key
        if [[ "$key" == *"="* ]]; then
        warn "secret_injection_args__gcp: key contains '='; stripping and continuing" "key=${key}"
        key="${key//=}"
        fi

        # If key becomes empty/invalid, warn+skip (and skip the subsequent value too, if present)
        if [[ -z "$key" ]]; then
            warn "secret_injection_args__gcp: empty key after normalization; skipping pair"
            IFS= read -r -d '' _ 2>/dev/null || true
            continue
        fi

        # Read value; if missing (dangling key), treat as empty value
        if IFS= read -r -d '' val 2>/dev/null; then
            :
        else
            val=""
        fi

        # Emit one argv token (NUL-separated) for gcloud
        printf '%s\0%s\0' "--set-secrets" "${key}=${val}"
    done
}

# GCS-specific helper functions (delegating to GCP versions for backward compatibility)
get_gcs_project_number() {
    get_gcp_project_number "$@"
}

get_gcp_project_number() {
    local project_id="${1:?GCP project ID required}"
    local project_info_json=""
    local project_number=""

    log INFO "Getting GCP Project Number ..." \
        "project=${project_id}" >&2

    if ! project_info_json="$(
        gcloud projects describe "$project_id" \
            --format=json
    )"; then
        die "Unable to describe GCP project: ${project_id}" 2
    fi

    project_number="$(
        jq -r '.projectNumber // empty' \
            <<< "$project_info_json"
    )"

    [[ -n "$project_number" ]] \
        || die "GCP project number was not returned for ${project_id}" 2

    printf '%s' "$project_number"
}

# This is a helper function to maintain backward compatibility with gcs naming; it simply delegates to the gcp version
get_gcs_secret() {
    get_gcp_secret "$@"
}
get_gcp_secret() {
    local secret_ref="${1:?GCP secret reference required}"
    local project_id=""
    local secret_name=""
    local project_number=""
    local secret_value=""

    if [[ "$secret_ref" == *":"* ]]; then
        project_id="${secret_ref%%:*}"
        secret_name="${secret_ref#*:}"
    else
        project_id="${GCP_PROJECT_ID:-${GOOGLE_CLOUD_PROJECT:-}}"
        secret_name="$secret_ref"
    fi

    [[ -n "$project_id" ]] \
        || die "GCP project ID is missing for secret retrieval" 2

    [[ -n "$secret_name" ]] \
        || die "GCP secret name is missing" 2

    # Resolve it only if another operation genuinely requires it.
    if ! project_number="$(get_gcp_project_number "$project_id")"; then
        die "Unable to resolve GCP project number for ${project_id}" 2
    fi

    [[ -n "$project_number" ]] \
        || die "Resolved GCP project number is empty for ${project_id}" 2

    # Secret Manager accepts the project ID here.
    if ! secret_value="$(
        gcloud secrets versions access latest \
            --project="$project_id" \
            --secret="$secret_name"
    )"; then
        die "Unable to access configured GCP secret" 2
    fi

    [[ -n "$secret_value" ]] \
        || die "Configured GCP secret is empty" 2

    printf '%s' "$secret_value"
}

# This is a helper function to maintain backward compatibility with gcs naming; it simply delegates to the gcp version
get_gcs_secret_name_from_path() {
    get_gcp_secret_name_from_path "$@"
}
get_gcp_secret_name_from_path(){
    log "Input to get_gcp_secret_name_from_path: '$1'"

    local path="$(urldecode "$1")"           # github-archive-480721:github-backup-token
    local secret_name="${path#*:}"           # github-backup-token

    # Return via stdout
    printf '%s' "${secret_name}"
}

# This is a helper function to maintain backward compatibility with gcs naming; it simply delegates to the gcp version
resolve_gcs_secret_path() {
    resolve_gcp_secret_path "$@"
}
resolve_gcp_secret_path() {
    local in_path="$1"
    in_path="${in_path#gcs:}"
    in_path="${in_path#gcp:}"

  # If already a full Secret Manager resource path, pass through.
  if [[ "$in_path" =~ ^projects/[^/]+/secrets/[^/:]+(:[^/]+)?$ ]]; then
    printf '%s' "$in_path"
    return 0
  fi

  # Expect "PROJECT_ID:SECRET_NAME" (e.g. github-archive-480721:github-backup-token)
  local project_id="${in_path%%:*}"
  local secret_name="${in_path#*:}"

  [[ -n "$project_id" && -n "$secret_name" && "$secret_name" != "$in_path" ]] \
    || { die "resolve_gcp_secret_path: invalid input '$1' (expected gcp:project:secret or projects/.../secrets/...)" 2; }

  local project_number
  project_number="$(get_gcp_project_number "$project_id")" || return 1

  printf 'projects/%s/secrets/%s' "$project_number" "$secret_name"
}

# This is a helper function to maintain backward compatibility with gcs naming; it simply delegates to the gcp version
upsert_gcs_job_env_vars_from_envfile() {
    upsert_gcp_job_env_vars_from_envfile "$@"
}
upsert_gcp_job_env_vars_from_envfile() {
    local run_job="${1:-$RUN_JOB}"
    local -a gcp_env_flags=()

    readarray -d '' -t gcp_env_flags < <(
        env_kv_for_injection | env_injection_args__gcp
    )

    local -a cmd=(
        gcloud run jobs update "$run_job"
        --region "$REGION"
        --set-env-vars IN_CONTAINER=true
        "${gcs_env_flags[@]}"
    )

    log_cmd "${cmd[@]}"
    "${cmd[@]}" >/dev/null
}
