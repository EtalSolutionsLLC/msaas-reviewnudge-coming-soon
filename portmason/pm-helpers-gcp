# GCS-specific helper functions (delegating to GCP versions for backward compatibility)
get_gcs_project_number() {
    get_gcp_project_number "$@"
}
get_gcp_project_number() {
    log "Getting GCP Project Number ..."

    local project_id
    project_id="${1:-}"

    if [[ -z "${GCLOUD_PROJECT_INFO_JSON:-}" || "${GCLOUD_PROJECT_INFO_JSON:-}" == "{}" ]]; then
        if ! GCLOUD_PROJECT_INFO_JSON="$(gcloud projects describe "${project_id}" --format=json 2>/dev/null)"; then
            GCLOUD_PROJECT_INFO_JSON='{}'
            export GCLOUD_PROJECT_INFO_JSON
            return 1
        fi
        export GCLOUD_PROJECT_INFO_JSON
    fi
    local value = "$(jq -r '.projectNumber // false' <<<"$GCLOUD_PROJECT_INFO_JSON")"

    # Return via stdout
    printf '%s' "${value}"
}

# This is a helper function to maintain backward compatibility with gcs naming; it simply delegates to the gcp version
get_gcs_secret() {
    get_gcp_secret "$@"
}
get_gcp_secret() {
    log "Input to get_gcp_secret: '$1'"

    local path="$(urldecode "$1")"           # github-archive-480721:github-backup-token
    local project_id="${path%%:*}"           # github-archive-480721   #project_number=648123572014
    local project_number="$(get_gcp_project_number "$project_id")"
    local secret_name="${path#*:}"           # github-backup-token

    #not sure if this the right implementation for GCS
    local secret_value
    secret_value="$(
        gcloud secrets versions access latest \
        --secret="${secret_name}" \
        --project="${project_number}" \
    )" || return 1

    # Return via stdout
    printf '%s' "${secret_value}"
}

