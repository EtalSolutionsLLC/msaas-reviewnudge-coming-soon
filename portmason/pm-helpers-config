#!/usr/bin/env bash
set -euo pipefail

# Portmason Configuration Manager core registry and service-scope mechanics.
# Source-safe: this file defines capabilities only and performs no lifecycle work.

if [[ "${__PM_HELPERS_CONFIG_LOADED:-0}" == "1" ]]; then
    return 0 2>/dev/null || exit 0
fi
__PM_HELPERS_CONFIG_LOADED=1
export __PM_HELPERS_CONFIG_LOADED

declare -ga PM_CONFIG_KEYS=()
declare -gA PM_CONFIG_TYPE=()
declare -gA PM_CONFIG_SCOPES=()
declare -gA PM_CONFIG_TARGET=()
declare -gA PM_CONFIG_REQUIRED=()
declare -gA PM_CONFIG_OWNER=()

declare -ga PM_CANONICAL_RUNTIME_SECRET_KEYS=()
declare -ga PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS=()
declare -ga PM_CANONICAL_SECRET_KEYS=()

pm_config_reset() {
    PM_CONFIG_KEYS=()
    PM_CONFIG_TYPE=()
    PM_CONFIG_SCOPES=()
    PM_CONFIG_TARGET=()
    PM_CONFIG_REQUIRED=()
    PM_CONFIG_OWNER=()
    PM_CANONICAL_RUNTIME_SECRET_KEYS=()
    PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS=()
    PM_CANONICAL_SECRET_KEYS=()
}

pm_config_trim() {
    local out_var="${1:?output variable required}"
    local value="${2-}"
    value="${value#${value%%[![:space:]]*}}"
    value="${value%${value##*[![:space:]]}}"
    printf -v "$out_var" '%s' "$value"
}

pm_config_csv_contains() {
    local csv="${1-}"
    local wanted="${2:?wanted scope required}"
    local item

    [[ "$csv" == "*" ]] && return 0
    IFS=',' read -r -a _pm_config_csv_items <<<"$csv"
    for item in "${_pm_config_csv_items[@]}"; do
        pm_config_trim item "$item"
        [[ "$item" == "$wanted" ]] && return 0
    done
    return 1
}

pm_config_scopes_intersect() {
    local registered="${1-}"
    local requested="${2-}"
    local scope

    [[ "$registered" == "*" ]] && return 0
    IFS=',' read -r -a _pm_config_requested_scopes <<<"$requested"
    for scope in "${_pm_config_requested_scopes[@]}"; do
        pm_config_trim scope "$scope"
        [[ -n "$scope" ]] || continue
        pm_config_csv_contains "$registered" "$scope" && return 0
    done
    return 1
}

pm_config_register() {
    local key="${1:?configuration key required}"
    local type="${2:?configuration type required}"
    local scopes="${3-}"
    local target="${4:-$key}"
    local required="${5:-optional}"
    local owner="${6:-${PM_CONFIG_ACTIVE_ENTITY:-unknown}}"

    [[ "$key" =~ ^[A-Z][A-Z0-9_]*$ ]] \
        || die "pm-config: invalid key: $key" 2
    [[ "$target" =~ ^[A-Z][A-Z0-9_]*$ ]] \
        || die "pm-config: invalid target key for $key: $target" 2

    case "$type" in
        var|secret|control-plane) ;;
        *) die "pm-config: invalid type for $key: $type" 2 ;;
    esac
    case "$required" in
        required|optional) ;;
        *) die "pm-config: invalid requirement for $key: $required" 2 ;;
    esac
    [[ -n "$scopes" || "$type" == "control-plane" ]] \
        || die "pm-config: runtime key must declare at least one scope: $key" 2
    [[ "$type" != "control-plane" || -z "$scopes" ]] \
        || die "pm-config: control-plane key must not declare runtime scopes: $key" 2

    if [[ -n "${PM_CONFIG_TYPE[$key]+x}" ]]; then
        if [[ "${PM_CONFIG_TYPE[$key]}|${PM_CONFIG_SCOPES[$key]}|${PM_CONFIG_TARGET[$key]}|${PM_CONFIG_REQUIRED[$key]}|${PM_CONFIG_OWNER[$key]}" \
            == "$type|$scopes|$target|$required|$owner" ]]; then
            return 0
        fi
        die "pm-config: conflicting registration for $key; existing owner=${PM_CONFIG_OWNER[$key]} new owner=$owner" 2
    fi

    PM_CONFIG_KEYS+=("$key")
    PM_CONFIG_TYPE["$key"]="$type"
    PM_CONFIG_SCOPES["$key"]="$scopes"
    PM_CONFIG_TARGET["$key"]="$target"
    PM_CONFIG_REQUIRED["$key"]="$required"
    PM_CONFIG_OWNER["$key"]="$owner"
}

pm_config_registry_records() {
    local key
    for key in "${PM_CONFIG_KEYS[@]}"; do
        printf '%s|%s|%s|%s|%s|%s\n' \
            "$key" "${PM_CONFIG_TYPE[$key]}" "${PM_CONFIG_SCOPES[$key]}" \
            "${PM_CONFIG_TARGET[$key]}" "${PM_CONFIG_REQUIRED[$key]}" \
            "${PM_CONFIG_OWNER[$key]}"
    done
}

pm_config_refresh_canonical_arrays() {
    local key type
    PM_CANONICAL_RUNTIME_SECRET_KEYS=()
    PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS=()
    PM_CANONICAL_SECRET_KEYS=()

    for key in "${PM_CONFIG_KEYS[@]}"; do
        type="${PM_CONFIG_TYPE[$key]}"
        case "$type" in
            secret) PM_CANONICAL_RUNTIME_SECRET_KEYS+=("$key") ;;
            control-plane) PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS+=("$key") ;;
        esac
    done
    PM_CANONICAL_SECRET_KEYS=(
        "${PM_CANONICAL_RUNTIME_SECRET_KEYS[@]}"
        "${PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS[@]}"
    )
}

pm_config_key_is_registered() {
    local key="${1:?configuration key required}"
    [[ -n "${PM_CONFIG_TYPE[$key]+x}" ]]
}

pm_config_key_looks_secret() {
    local key="${1:?configuration key required}"
    case "$key" in
        *_PASSWORD|*_PASS|*_TOKEN|*_SECRET|*_KEY|DATABASE_URL|DATABASE_DIRECT_URL|DB_USER|DB_ADMIN_USER|QUEUE_USER)
            return 0
            ;;
    esac
    return 1
}

pm_config_keys_for_type() {
    local wanted_type="${1:?configuration type required}"
    local key
    for key in "${PM_CONFIG_KEYS[@]}"; do
        [[ "${PM_CONFIG_TYPE[$key]}" == "$wanted_type" ]] || continue
        printf '%s\n' "$key"
    done
}

pm_config_keys_for_scopes() {
    local wanted_type="${1:?configuration type required}"
    local scopes="${2-}"
    local key
    for key in "${PM_CONFIG_KEYS[@]}"; do
        [[ "${PM_CONFIG_TYPE[$key]}" == "$wanted_type" ]] || continue
        pm_config_scopes_intersect "${PM_CONFIG_SCOPES[$key]}" "$scopes" || continue
        printf '%s\n' "$key"
    done
}

pm_config_value() {
    local out_var="${1:?output variable required}"
    local key="${2:?configuration key required}"
    local resolved_value=""

    if declare -F pm_current_or_generated_value >/dev/null 2>&1; then
        pm_current_or_generated_value resolved_value "$key"
    elif [[ -v "$key" ]]; then
        resolved_value="${!key}"
    else
        local base="${ENV_FILE:-${SCRIPT_DIR:-${PROJECT_ROOT:-$PWD}}/.env}"
        local file="${base}.generated"
        if [[ -r "$file" ]]; then
            resolved_value="$(awk -F= -v wanted="$key" '$1 == wanted {sub(/^[^=]*=/, ""); print; exit}' "$file")"
            case "$resolved_value" in
                "'"*"'") resolved_value="${resolved_value:1:${#resolved_value}-2}" ;;
                '"'*'"') resolved_value="${resolved_value:1:${#resolved_value}-2}" ;;
            esac
        fi
    fi
    printf -v "$out_var" '%s' "$resolved_value"
}

pm_config_secret_override_exists() {
    local key="${1:?configuration key required}"
    if declare -F pm_preflight_has_secret_override >/dev/null 2>&1; then
        pm_preflight_has_secret_override "$key"
        return
    fi
    local line ref
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -n "$line" && "$line" == *'|'* ]] || continue
        ref="${line%%|*}"
        [[ "$ref" == "$key" ]] && return 0
    done <<<"${SECRET_PATHS:-}"
    return 1
}

pm_config_compose_service_role() {
    local out_var="${1:?output variable required}"
    local service="${2:?service required}"
    local result=""

    if [[ -n "${PROJECT_SERVICES:-}" ]]; then
        result="$(jq -r --arg service "$service" \
            '.[] | select(.service == $service) | .role' \
            <<<"$PROJECT_SERVICES" | head -n1)"
    fi
    [[ -n "$result" && "$result" != null ]] || result="$service"
    printf -v "$out_var" '%s' "$result"
}

pm_config_compose_service_scopes() {
    local out_var="${1:?output variable required}"
    local service="${2:?service required}"
    local role="${3:-}"
    local result=""

    if [[ -z "$role" ]]; then
        pm_config_compose_service_role role "$service"
    fi

    if [[ -n "${PM_COMPOSE_MODEL_JSON:-}" ]]; then
        result="$(jq -r --arg service "$service" '
            ((.services[$service].labels // {})["solutions.etal.config_scopes"] // "")
            | if type == "array" then join(",") else tostring end
        ' <<<"$PM_COMPOSE_MODEL_JSON")"
    fi

    if [[ -z "$result" || "$result" == null ]]; then
        result="$role,$service"
    fi
    printf -v "$out_var" '%s' "$result"
}

pm_config_registered_source_keys_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local type="${3:?configuration type required}"
    local scopes
    pm_config_compose_service_scopes scopes "$service" "$role"
    pm_config_keys_for_scopes "$type" "$scopes"

    if [[ "$type" == secret ]]; then
        local extra
        IFS=',' read -r -a _pm_config_extra_secret_keys <<<"${PM_ADDITIONAL_SECRET_KEYS:-}"
        for extra in "${_pm_config_extra_secret_keys[@]}"; do
            pm_config_trim extra "$extra"
            [[ -n "$extra" ]] && printf '%s\n' "$extra"
        done
    fi
}

pm_config_unregistered_var_kv_nul_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local strict="${PM_CONFIG_STRICT:-false}"
    case "${strict,,}" in
        1|true|yes|on) return 0 ;;
    esac

    local file="${ENV_FILE:-${SCRIPT_DIR:-$PWD}/.env}.generated"
    [[ -r "$file" ]] || return 0
    declare -A emitted=()
    local key value

    while IFS= read -r -d '' key; do
        IFS= read -r -d '' value || value=""
        [[ -n "$key" && -z "${emitted[$key]+x}" ]] || continue
        emitted["$key"]=1
        pm_config_key_is_registered "$key" && continue
        pm_config_key_looks_secret "$key" && continue
        case "$key" in
            PM_*|ENV_FILE|SECRET_PATHS|DEBUG|VERBOSE|PATH|HOME|PWD|OLDPWD|SHELL|SHLVL|USER|LOGNAME|LANG|LANGUAGE|LC_*|TERM|XDG_*)
                continue
                ;;
        esac
        printf '%s\0%s\0' "$key" "$value"
    done < <(env_file_to_kv_nul "$file")
}

pm_config_var_kv_nul_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local key value target
    declare -A emitted=()

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        target="${PM_CONFIG_TARGET[$key]}"
        [[ -z "${emitted[$target]+x}" ]] || continue
        pm_config_value value "$key"
        [[ -n "$value" || "${PM_CONFIG_REQUIRED[$key]}" == required ]] || continue
        printf '%s\0%s\0' "$target" "$value"
        emitted["$target"]=1
    done < <(pm_config_registered_source_keys_for_service "$service" "$role" var)

    while IFS= read -r -d '' key; do
        IFS= read -r -d '' value || value=""
        [[ -z "${emitted[$key]+x}" ]] || continue
        printf '%s\0%s\0' "$key" "$value"
        emitted["$key"]=1
    done < <(pm_config_unregistered_var_kv_nul_for_service "$service" "$role")
}

pm_config_secret_binding_nul_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local key value target
    declare -A emitted=()

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        target="${PM_CONFIG_TARGET[$key]}"
        [[ -z "${emitted[$target]+x}" ]] || continue
        pm_config_value value "$key"
        if [[ -n "$value" ]] || pm_config_secret_override_exists "$key"; then
            printf '%s\0%s\0%s\0' "$key" "$target" "$value"
            emitted["$target"]=1
        fi
    done < <(pm_config_registered_source_keys_for_service "$service" "$role" secret)
}

pm_config_secret_kv_nul_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local source target value
    while IFS= read -r -d '' source; do
        IFS= read -r -d '' target || target="$source"
        IFS= read -r -d '' value || value=""
        printf '%s\0%s\0' "$target" "$value"
    done < <(pm_config_secret_binding_nul_for_service "$service" "$role")
}

pm_config_dotenv_write_pair() {
    local file="${1:?file required}"
    local key="${2:?key required}"
    local value="${3-}"
    local encoded

    case "$value" in
        *$'\n'*|*$'\r'*) die "pm-config: refusing multiline value for $key" 2 ;;
    esac
    encoded="${value//\\/\\\\}"
    encoded="${encoded//\'/\\\'}"
    printf "%s='%s'\n" "$key" "$encoded" >>"$file"
}

pm_config_write_service_env_file() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local output_dir="${PM_CONFIG_OUTPUT_DIR:-${SCRIPT_DIR:-$PWD}/.portmason/config}"
    local file="${output_dir}/${service}.env"
    local tmp key value var_count=0 secret_count=0 scopes

    mkdir -p -- "$output_dir"
    tmp="$(mktemp "${file}.XXXXXX")"
    chmod 600 "$tmp"
    printf '# Generated by PM Configuration Manager. Do not edit.\n' >"$tmp"

    while IFS= read -r -d '' key; do
        IFS= read -r -d '' value || value=""
        pm_config_dotenv_write_pair "$tmp" "$key" "$value"
        ((var_count+=1))
    done < <(pm_config_var_kv_nul_for_service "$service" "$role")

    while IFS= read -r -d '' key; do
        IFS= read -r -d '' value || value=""
        pm_config_dotenv_write_pair "$tmp" "$key" "$value"
        ((secret_count+=1))
    done < <(pm_config_secret_kv_nul_for_service "$service" "$role")

    mv -- "$tmp" "$file"
    chmod 600 "$file"
    pm_config_compose_service_scopes scopes "$service" "$role"
    log INFO "pm-config: wrote service environment" \
        "service=$service" "role=$role" "scopes=$scopes" \
        "vars=$var_count" "secrets=$secret_count" "file=$file"
}

pm_config_write_local_files() {
    declare -F pm_compose_load_model >/dev/null 2>&1 \
        || die "pm-config-local requires pm-helpers-db" 2
    pm_compose_load_model

    local output_dir="${PM_CONFIG_OUTPUT_DIR:-${SCRIPT_DIR:-$PWD}/.portmason/config}"
    local manifest="${output_dir}/manifest.tsv"
    local tmp service role scopes
    mkdir -p -- "$output_dir"
    tmp="$(mktemp "${manifest}.XXXXXX")"
    chmod 600 "$tmp"
    printf 'service\trole\tconfig_scopes\n' >"$tmp"

    while IFS=$'\t' read -r service role _image _has_build; do
        [[ -n "$service" ]] || continue
        pm_config_write_service_env_file "$service" "$role"
        pm_config_compose_service_scopes scopes "$service" "$role"
        printf '%s\t%s\t%s\n' "$service" "$role" "$scopes" >>"$tmp"
    done < <(jq -r '.[] | [.service,.role,.image,(.has_build|tostring)] | @tsv' \
        <<<"${PROJECT_SERVICES:-[]}")

    mv -- "$tmp" "$manifest"
    chmod 600 "$manifest"
    log INFO "pm-config: local service environments complete" "directory=$output_dir"
}

pm_config_validate_registry() {
    local key type scopes target required owner
    declare -A targets=()
    for key in "${PM_CONFIG_KEYS[@]}"; do
        type="${PM_CONFIG_TYPE[$key]-}"
        scopes="${PM_CONFIG_SCOPES[$key]-}"
        target="${PM_CONFIG_TARGET[$key]-}"
        required="${PM_CONFIG_REQUIRED[$key]-}"
        owner="${PM_CONFIG_OWNER[$key]-}"

        [[ -n "$type" ]]             || die "pm-config: registry key is missing type metadata: key=$key" 2
        [[ -n "$target" ]]             || die "pm-config: registry key is missing target metadata: key=$key" 2
        [[ -n "$required" ]]             || die "pm-config: registry key is missing required metadata: key=$key" 2
        [[ -n "$owner" ]]             || die "pm-config: registry key is missing owner metadata: key=$key" 2
        [[ "$type" == control-plane || -n "$scopes" ]] \
            || die "pm-config: runtime key has no scopes: $key" 2
        [[ "$required" == required || "$required" == optional ]] \
            || die "pm-config: invalid required flag for $key" 2
        targets["$target"]=1
    done
    pm_config_refresh_canonical_arrays
}

pm_config_validate_required_services() {
    [[ -n "${PROJECT_SERVICES:-}" ]] || return 0
    local service role key value missing=0
    while IFS=$'\t' read -r service role _image _has_build; do
        [[ -n "$service" ]] || continue
        while IFS= read -r key; do
            [[ "${PM_CONFIG_REQUIRED[$key]-}" == required ]] || continue
            pm_config_value value "$key"
            if [[ -z "$value" ]] && ! pm_config_secret_override_exists "$key"; then
                if declare -F pm_preflight_error >/dev/null 2>&1; then
                    pm_preflight_error "config.required" "$key" \
                        "required by service=$service owner=${PM_CONFIG_OWNER[$key]-<unregistered>}"                else
                    log ERROR "pm-config: required value missing" \
                        "key=$key" "service=$service" "owner=${PM_CONFIG_OWNER[$key]-<unregistered>}"
                fi
                missing=1
            fi
        done < <(
            pm_config_registered_source_keys_for_service "$service" "$role" var
            pm_config_registered_source_keys_for_service "$service" "$role" secret
        )
    done < <(jq -r '.[] | [.service,.role,.image,(.has_build|tostring)] | @tsv' \
        <<<"${PROJECT_SERVICES:-[]}")
    return "$missing"
}

# Backward-compatible contract used by existing platform helpers.
pm_service_secret_keys() {
    local role="${1:?service role required}"
    local key extra
    pm_config_keys_for_scopes secret "$role"
    IFS=',' read -r -a _pm_extra_secret_keys <<<"${PM_ADDITIONAL_SECRET_KEYS:-}"
    for extra in "${_pm_extra_secret_keys[@]}"; do
        pm_config_trim extra "$extra"
        [[ -n "$extra" ]] && printf '%s\n' "$extra"
    done
}

pm_service_secret_kv_nul() {
    local role="${1:?service role required}"
    local key value
    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        pm_config_value value "$key"
        if [[ -n "$value" ]] || pm_config_secret_override_exists "$key"; then
            printf '%s\0%s\0' "$key" "$value"
        fi
    done < <(pm_service_secret_keys "$role" | awk '!seen[$0]++')
}

pm_service_nonsecret_kv_nul() {
    local role="${1:?service role required}"
    local key value target
    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        target="${PM_CONFIG_TARGET[$key]}"
        pm_config_value value "$key"
        [[ -n "$value" || "${PM_CONFIG_REQUIRED[$key]}" == required ]] || continue
        printf '%s\0%s\0' "$target" "$value"
    done < <(pm_config_keys_for_scopes var "$role")
}
