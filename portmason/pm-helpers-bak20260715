# Run-level error collection. Entry scripts may print a concise summary at the
# end without forcing every implementation layer to repeat its diagnostics.
declare -ga PM_ERROR_SUMMARY_ITEMS=()
declare -g PM_ERROR_SUMMARY_PRINTED=0
declare -g PM_ERROR_SUMMARY_ACTIVE=0

pm_error_summary_reset() {
    PM_ERROR_SUMMARY_ITEMS=()
    PM_ERROR_SUMMARY_PRINTED=0
    PM_ERROR_SUMMARY_ACTIVE=0
}

pm_error_record() {
    local severity="${1:-ERROR}"
    local message="${2:-}"
    shift 2 || true
    local fields=""

    (( PM_ERROR_SUMMARY_ACTIVE == 0 )) || return 0
    if (( $# > 0 )); then
        fields=" $*"
    fi
    PM_ERROR_SUMMARY_ITEMS+=("${severity}|${message}${fields}")
}

pm_error_summary_print() {
    local count="${#PM_ERROR_SUMMARY_ITEMS[@]}"
    local item severity message index=0

    (( PM_ERROR_SUMMARY_PRINTED == 0 )) || return 0

    PM_ERROR_SUMMARY_PRINTED=1
    PM_ERROR_SUMMARY_ACTIVE=1

    # PM-LINT-MACHINE-OUTPUT: deliberate compact operator summary.
    printf '\n========== ERROR SUMMARY (%s) ==========\n' "$count" >&2
    if (( count == 0 )); then
        # PM-LINT-MACHINE-OUTPUT: deliberate compact operator summary.
        printf 'No errors encountered.\n' >&2
    else
        for item in "${PM_ERROR_SUMMARY_ITEMS[@]}"; do
            ((index += 1))
            severity="${item%%|*}"
            message="${item#*|}"
            # PM-LINT-MACHINE-OUTPUT: deliberate compact operator summary.
            printf '%2d. [%s] %s\n' "$index" "$severity" "$message" >&2
        done
    fi
    # PM-LINT-MACHINE-OUTPUT: deliberate compact operator summary.
    printf '=========================================\n' >&2

    PM_ERROR_SUMMARY_ACTIVE=0
}

