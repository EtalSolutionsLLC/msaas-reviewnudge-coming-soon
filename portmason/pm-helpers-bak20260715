error() { log ERROR "$@"; }

fatal() { exit "${1:-1}"; }

fatal_error() {
    local msg="${1:-}"; local rc="${2:-1}"
    error "$@"
    fatal "$rc"
}

get_deploy_env_value() {
  local short="${1:?pm_env_get requires: <short> <field> [map_file]}"
  local field="${2:?pm_env_get requires: <short> <field> [map_file]}"
  local map_file="${3:-${PORTMASON_SHARE}/pm-deploy-env-mapping.json}"

  have jq || { fatal_error "jq is required" 1; }
  [[ -f "$map_file" ]] || { fatal_error "mapping file not found: '$map_file'" 1; }

  short="$(printf '%s' "$short" | tr '[:upper:]' '[:lower:]')"
  field="$(printf '%s' "$field" | tr '[:upper:]' '[:lower:]')"

  case "$field" in
    short|long|gcp_tag)
      ;;
    *)
      error "unknown field '$field' (allowed: short,long,gcp_tag)"
      return 1
      ;;
  esac

  local val
  val="$(jq -r --arg s "$short" --arg f "$field" '
    .envs[$s][$f] // empty
  ' "$map_file")"

  if [[ -z "$val" ]]; then
    error "unknown env '$short' or missing field '$field'"
    return 1
  fi

  printf '%s\n' "$val"
}

godaddy_upsert_cname() {
    local target_url="${1:?target_url required (e.g., https://web-702605617368.us-central1.run.app)}"

  : "${GODADDY_API_KEY:?GODADDY_API_KEY is required for DNS updates}"
  : "${GODADDY_API_SECRET:?GODADDY_API_SECRET is required for DNS updates}"
  : "${GODADDY_API_BASE:=https://api.godaddy.com}"
  : "${GODADDY_API_TTL:=600}"

  # Normalize input
  target_url="${target_url#http://}"
  target_url="${target_url#https://}"
  target_url="${target_url%%/*}"
  target_url="${target_url%.}"

  # PUT replaces the CNAME for this (type,name). Payload is an array of records.
  # Endpoint family: /v1/domains/{domain}/records/{type}/{name} :contentReference[oaicite:1]{index=1}
  curl -sS -X PUT \
    -H "Authorization: sso-key ${GODADDY_API_KEY}:${GODADDY_API_SECRET}" \

    -H "Content-Type: application/json" \
    "${GODADDY_API_BASE}/v1/domains/${LOCAL_DOMAIN}/records/CNAME/${STACK}" \
    --data "[{\"data\":\"${tar
    get_url}\",\"ttl\":${GODADDY_API_TTL}}]"
}

secret_spec_parts() {
    # Usage: secret_spec_parts SPEC PROVIDER_OUT SECRET_ID_OUT
    local spec="${1:?secret spec required}"
    local provider_out="${2:?provider output variable required}"
    local secret_id_out="${3:?secret id output variable required}"

    local parsed_provider=""
    local parsed_secret_id=""

    if [[ "$spec" == *":"* ]]; then
        parsed_provider="${spec%%:*}"
        parsed_secret_id="${spec#*:}"
    else
        parsed_provider="${DEFAULT_SECRET_PROVIDER:-gcp}"
        parsed_secret_id="$spec"
    fi

    [[ -n "$parsed_provider" ]] \
        || parsed_provider="${DEFAULT_SECRET_PROVIDER:-gcp}"

    [[ "$parsed_provider" == "gcs" ]] \
        && parsed_provider="gcp"

    [[ -n "$parsed_secret_id" ]] \
        || die "Secret identifier is empty in spec: ${spec}" 2

    printf -v "$provider_out" '%s' "$parsed_provider"
    printf -v "$secret_id_out" '%s' "$parsed_secret_id"
}


get_secret() {
    local spec="${1:?secret spec required}"
    local provider=""
    local secret_id=""
    local fn=""

    secret_spec_parts "$spec" provider secret_id
    fn="get_${provider}_secret"

    declare -F "$fn" >/dev/null 2>&1 \
        || die "Secret provider function is unavailable: ${fn}" 2

    log INFO "retrieving secret" \
        "provider=${provider}" \
        "secret_id=${secret_id}" >&2

    "$fn" "$secret_id"
}


get_secret_name_from_path(){
    local spec="${1:?secret path required}"
    local provider secret_id fn
    secret_spec_parts "$spec" provider secret_id
    fn="get_${provider}_secret_name_from_path"
    declare -F "$fn" >/dev/null 2>&1 || die "get_secret_name_from_path: unsupported secret provider '$provider' for spec '$spec'"
    "$fn" "${secret_id}"
}

get_secret_name_by_ref() {
  local path
  path="$(get_secret_path_by_ref "$1")" || return 1
  get_secret_name_from_path "$path" #secret_name is the provider's secret_name
}

get_secret_path_by_ref() {
  local want="${1:-}"
  [[ -z "$want" ]] && bail "get_secret_path_by_ref: missing ref key" 2
  : "${SECRET_PATHS:=}" #secret_path consists of [secret_provider (GCP, AZURE, etc)]:[secret_id]

  local line ref path
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" ]] && continue
    [[ "$line" != *"|"* ]] && bail "get_secret_path_by_ref: invalid entry (expected 'REF|PATH'): '$line'" 2

    ref="${line%%|*}"
    path="${line#*|}"

    [[ -n "$ref" && -n "$path" ]] || bail "get_secret_path_by_ref: invalid entry (empty ref/path): '$line'" 2

    if [[ "$ref" == "$want" ]]; then
      log "$path"
      return 0
    fi
  done <<< "$SECRET_PATHS"

  return 1
}

get_secret_names_list() {
  local spec secret_path secret_name
  for spec in "${SECRET_PATHS[@]}"; do
    [[ -z "$spec" ]] && continue
    [[ "$spec" != *"|"* ]] && die "secret_names_list: invalid entry (expected 'REF|PATH'): '$spec'"

    secret_path="${spec#*|}"
    [[ -n "$secret_path" ]] || die "secret_names_list: empty path in '$spec'"

    secret_name="$(get_secret_name_from_path "$secret_path")" || die "secret_names_list: failed to derive secret name from '$secret_path'"
    [[ -n "$secret_name" ]] || die "secret_names_list: empty secret name derived from '$secret_path'"

    printf '%s\n' "$secret_name"
  done
}

get_secret_paths_list() {
  local spec secret_path
  for spec in "${SECRET_PATHS[@]}"; do
    [[ -z "$spec" ]] && continue
    [[ "$spec" != *"|"* ]] && die "secret_paths_list: invalid entry (expected 'REF|PATH'): '$spec'"
    secret_path="${spec#*|}"
    [[ -n "$secret_path" ]] || die "secret_paths_list: empty path in '$spec'"
    printf '%s\n' "$secret_path"
  done
}

