log_callsite() {
    local index
    local function_name
    local source_file

    for ((index = 1; index < ${#FUNCNAME[@]}; index++)); do
        function_name="${FUNCNAME[$index]}"
        source_file="${BASH_SOURCE[$index]##*/}"

        case "$function_name" in
            log|die|pm_log_callsite|pm_format_log)
                continue
                ;;
        esac

        printf '%s\t%s\n' "$source_file" "$function_name"
        return 0
    done

    printf '%s\t%s\n' "$PM_ENTRY_SCRIPT" "main"
}

log() {
    local severity
    local msg
    local -a extra_fields=()

    case "$#" in
        0)
            severity="INFO"
            msg=""
            ;;
        1)
            severity="INFO"
            msg="${1:-}"
            shift
            ;;
        *)
            severity="${1:-}"
            msg="${2:-}"
            shift 2
            extra_fields=("$@")
            ;;
    esac

    case "${severity^^}" in
        ERROR|CRITICAL)
            pm_error_record "${severity^^}" "$msg" "${extra_fields[@]}"
            ;;
    esac

    should_log "${severity}" || return 0

    # Timestamp (RFC3339 UTC)
    local ts
    ts="$(date -u +'%Y-%m-%dT%H:%M:%S.%3NZ')"

    if [[ "${LOG_FORMAT:-text}" == "json" ]]; then
        local service="${K_SERVICE:-${CLOUD_RUN_SERVICE:-}}"
        local revision="${K_REVISION:-}"
        local execution="${CLOUD_RUN_EXECUTION:-}"
        local task_index="${CLOUD_RUN_TASK_INDEX:-}"
        local script_name="${PM_ENTRY_SCRIPT:-}"

        local esc_msg="${msg//\\/\\\\}"
        esc_msg="${esc_msg//\"/\\\"}"

        local extras_json=""
        local k v kv
        for kv in "${extra_fields[@]}"; do
            if [[ "$kv" == *"="* ]]; then
                k="${kv%%=*}"
                v="${kv#*=}"
                v="${v//\\/\\\\}"
                v="${v//\"/\\\"}"
                extras_json+=",\"${k}\":\"${v}\""
            fi
        done

        local json
        json="{\"severity\":\"${severity}\",\"timestamp\":\"${ts}\",\"message\":\"${esc_msg}\""
        [[ -n "${service:-}"     ]] && json+=",\"service\":\"${service}\""
        [[ -n "${script_name:-}" ]] && json+=",\"script\":\"${script_name}\""
        [[ -n "${revision:-}"    ]] && json+=",\"revision\":\"${revision}\""
        [[ -n "${execution:-}"   ]] && json+=",\"execution\":\"${execution}\""
        [[ -n "${task_index:-}"  ]] && json+=",\"task_index\":\"${task_index}\""
        json+="${extras_json}"
        json+="}"

        printf '%s\n' "$json" >&2
    else
        # Text mode mirrors JSON mode by appending the structured fields after
        # the human-readable message. This keeps local logs complete while
        # preserving the existing message text and callsite prefix.
        local callsite
        local implementation_script
        local implementation_function
        local extras=""

        if (( ${#extra_fields[@]} > 0 )); then
            extras=" ${extra_fields[*]}"
        fi

        callsite="$(log_callsite)"
        IFS=$'\t' read -r implementation_script implementation_function \
            <<< "$callsite"

        printf '[%s][%s][%s][%s:%s] %s%s\n' \
            "$ts" "$severity" "$PM_ENTRY_SCRIPT" \
            "$implementation_script" "$implementation_function" \
            "$msg" "$extras" >&2
    fi
}

log_cmd() {
  local out="" a
  for a in "$@"; do out+=" $(printf '%q' "$a")"; done
  log "CMD:${out# }"
}

stage_portmason() {
    # Usage:
    #   stage_portmason [exclude_pattern...]
    #
    # Exclude patterns are rsync-style, relative to the source root:
    #   "cache/"          (exclude subdir)
    #   "secrets.env"     (exclude file)
    #   "*.log"           (exclude glob)
    #
    # Example:
    #   stage_portmason "cache/" "*.tmp" "node_modules/"

    local src="${PORTMASON_SHARE}"
#    local dest="$(determine_dest_root)/portmason"
    local dest="${REPO_ROOT}/portmason"

    log "Staging portmason -> ${dest} (from ${PORTMASON_SHARE})"

    [[ -d "$src" ]] || die "Missing directory: ${src}"
    mkdir -p "$dest"

    # -a = archive; -L = copy the symlink targets as real files/dirs
    local -a rsync_cmd=(rsync -aL --delete)

    # Add excludes (if any)
    local pat
    for pat in "$@"; do
        [[ -n "$pat" ]] || continue
        rsync_cmd+=(--exclude "$pat")
    done

    rsync_cmd+=("${src}/" "${dest}/")

    # Optional: log the exact command
    local _print
    printf -v _print '%q ' "${rsync_cmd[@]}"
    log DEBUG "CMD: ${_print}"

    "${rsync_cmd[@]}"
}


resolve_project_root_candidate() {
    local invocation_dir="${1:-$(pwd -P)}"
    local requested_root=""

    if [[ -n "${PORTMASON_PROJECT_ROOT:-}" ]]; then
        requested_root="${PORTMASON_PROJECT_ROOT}"
    elif command -v git >/dev/null 2>&1; then
        requested_root="$(
            git -C "${invocation_dir}" rev-parse --show-toplevel 2>/dev/null || true
        )"
    fi

    requested_root="${requested_root:-${invocation_dir}}"

    [[ -d "${requested_root}" ]] \
        || die "Project root does not exist: ${requested_root}"

    (
        cd -- "${requested_root}"
        pwd -P
    )
}

resolve_project_root() {
    PROJECT_ROOT="$(resolve_project_root_candidate "${ORIG_PWD}")"
    export PROJECT_ROOT
}

