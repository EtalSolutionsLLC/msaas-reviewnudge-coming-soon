pm_context_resolve_project_root() {
    local output_var="${1:?output variable required}"
    local invocation_dir explicit_root candidate git_root

    invocation_dir="$(pwd -P)"
    explicit_root="${PORTMASON_PROJECT_ROOT:-}"

    if [[ -n "$explicit_root" ]]; then
        [[ -d "$explicit_root" ]] \
            || die "PORTMASON_PROJECT_ROOT is not a directory: $explicit_root" 2
        candidate="$(cd -- "$explicit_root" && pwd -P)"
    elif command -v git >/dev/null 2>&1 \
        && git_root="$(git -C "$invocation_dir" rev-parse --show-toplevel 2>/dev/null)"; then
        candidate="$(cd -- "$git_root" && pwd -P)"
    else
        candidate="$invocation_dir"
    fi

    printf -v "$output_var" '%s' "$candidate"
}

pm_context_path_is_within() {
    local candidate="${1:-}"
    local root="${2:?root required}"

    [[ -n "$candidate" ]] || return 1
    case "$candidate" in
        "$root"|"$root"/*) return 0 ;;
        *) return 1 ;;
    esac
}

pm_context_append_key() {
    local output_var="${1:?output variable required}"
    local key="${2:-}"
    local current="${!output_var:-}"

    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || return 0
    case ":$current:" in
        *":$key:"*) return 0 ;;
    esac

    if [[ -n "$current" ]]; then
        printf -v "$output_var" '%s:%s' "$current" "$key"
    else
        printf -v "$output_var" '%s' "$key"
    fi
}

pm_context_collect_env_file_keys() {
    local output_var="${1:?output variable required}"
    local env_file="${2:-}"
    local raw line key keys=""

    if [[ ! -r "$env_file" ]]; then
        printf -v "$output_var" '%s' ""
        return 0
    fi

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        line="${raw#"${raw%%[![:space:]]*}"}"
        [[ -n "$line" && "$line" != \#* ]] || continue

        if [[ "$line" == export[[:space:]]* ]]; then
            line="${line#export}"
            line="${line#"${line%%[![:space:]]*}"}"
        fi

        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)= ]] || continue
        key="${BASH_REMATCH[1]}"
        pm_context_append_key keys "$key"
    done < "$env_file"

    printf -v "$output_var" '%s' "$keys"
}

pm_context_record_project_keys() {
    local keys=""
    local env_keys=""
    local key

    pm_context_collect_env_file_keys env_keys "${ENV_FILE:-}"
    if [[ -n "$env_keys" ]]; then
        keys="$env_keys"
    fi

    for key in "${ENV_INIT_VARS[@]}"; do
        pm_context_append_key keys "$key"
    done

    __PM_HELPERS_PROJECT_ENV_KEYS="$keys"
    export __PM_HELPERS_PROJECT_ENV_KEYS
}

pm_context_reset_project_state() {
    local requested_root="${1:?requested project root required}"
    local keep_site_dir=""
    local keep_site_root=""
    local keep_script_dir=""
    local keep_env_file=""
    local keep_deploy_env=""
    local stale_env_keys="${__PM_HELPERS_PROJECT_ENV_KEYS:-}"
    local file_env_keys=""
    local key
    local -a keys=()

    # Preserve path inputs that the current caller has already resolved inside
    # the requested project. Values outside that root belong to the stale cache.
    pm_context_path_is_within "${SITE_DIR:-}" "$requested_root" \
        && keep_site_dir="$SITE_DIR"
    pm_context_path_is_within "${SITE_ROOT:-}" "$requested_root" \
        && keep_site_root="$SITE_ROOT"
    pm_context_path_is_within "${SCRIPT_DIR:-}" "$requested_root" \
        && keep_script_dir="$SCRIPT_DIR"
    pm_context_path_is_within "${ENV_FILE:-}" "$requested_root" \
        && keep_env_file="$ENV_FILE"

    # pm-setup may have resolved DEPLOY_ENV from a current deploy/<env> path.
    # Capture it before stale environment keys are cleared.
    if [[ -n "${DEPLOY_ENV:-}" && -n "$keep_script_dir" \
        && "$keep_script_dir" == "$requested_root/deploy/$DEPLOY_ENV" ]]; then
        keep_deploy_env="$DEPLOY_ENV"
    fi

    # Legacy loaded contexts may not have exported a key list. Parse the stale
    # ENV_FILE as a fallback so project-only values do not leak across roots.
    pm_context_collect_env_file_keys file_env_keys "${ENV_FILE:-}"
    if [[ -n "$file_env_keys" ]]; then
        stale_env_keys="${stale_env_keys:+$stale_env_keys:}$file_env_keys"
    fi

    if [[ -n "$stale_env_keys" ]]; then
        IFS=':' read -r -a keys <<< "$stale_env_keys"
        for key in "${keys[@]}"; do
            [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue

            # Process/tool controls are not project configuration.
            case "$key" in
                PATH|HOME|PWD|OLDPWD|SHELL|SHLVL|USER|LOGNAME|LANG|LANGUAGE|TERM)
                    continue
                    ;;
                PORTMASON_SHARE|PORTMASON_PROJECT_ROOT|PM_ENTRY_SCRIPT|MINIMAL|IN_CONTAINER)
                    continue
                    ;;
                DEBUG|VERBOSE|FORCE_PERSIST|PM_*)
                    continue
                    ;;
                __PM_HELPERS_*)
                    continue
                    ;;
            esac

            unset "$key"
        done
    fi

    unset \
        PROJECT_ROOT \
        REPO_ROOT \
        REPO_NAME \
        ORIG_PWD \
        SITE_DIR \
        SITE_ROOT \
        SCRIPT_DIR \
        ENV_FILE \
        ENV_EXAMPLE_SRC \
        LOG_DIR \
        LOG_FILE \
        STACK \
        APP_URL \
        PROJECT_ID \
        DEPLOYMENT_ID \
        RUNTIME_ADAPTER_CODE \
        RUNTIME_CODE \
        ADAPTER_CODE \
        BACK_END_CODE \
        FRONT_END_CODE \
        PROJECT_SERVICES \
        __ENVFILE_LOADED \
        __PM_HELPERS_STATE \
        __PM_HELPERS_PROJECT_ROOT \
        __PM_HELPERS_PROJECT_ENV_KEYS

    ENV_INIT_VARS=()

    [[ -n "$keep_site_dir" ]] && export SITE_DIR="$keep_site_dir"
    [[ -n "$keep_site_root" ]] && export SITE_ROOT="$keep_site_root"
    [[ -n "$keep_script_dir" ]] && export SCRIPT_DIR="$keep_script_dir"
    [[ -n "$keep_env_file" ]] && export ENV_FILE="$keep_env_file"

    if [[ -n "$keep_deploy_env" ]]; then
        export DEPLOY_ENV="$keep_deploy_env"
    else
        unset DEPLOY_ENV
    fi
}

pm_init() {
    local requested_root
    local cached_root="${__PM_HELPERS_PROJECT_ROOT:-}"
    local cached_state="${__PM_HELPERS_STATE:-}"

    # Resolve the requested context before consulting inherited cache state.
    # PROJECT_ROOT is deliberately excluded from this resolution path.
    pm_context_resolve_project_root requested_root

    case "$cached_state" in
        loaded|loading)
            if [[ -n "$cached_root" && "$cached_root" == "$requested_root" ]]; then
                # Normalize owned outputs even when a generic stale PROJECT_ROOT
                # was injected alongside an otherwise valid cache marker.
                PROJECT_ROOT="$requested_root"
                REPO_ROOT="$requested_root"
                export PROJECT_ROOT REPO_ROOT
                return 0 2>/dev/null || exit 0
            fi

            pm_context_reset_project_state "$requested_root"
            ;;
    esac

    __PM_HELPERS_STATE="loading"
    __PM_HELPERS_PROJECT_ROOT="$requested_root"
    export __PM_HELPERS_STATE __PM_HELPERS_PROJECT_ROOT

    # If init fails, clear both state and context so a later retry is allowed.
    trap '__PM_HELPERS_STATE=""; __PM_HELPERS_PROJECT_ROOT=""; __PM_HELPERS_PROJECT_ENV_KEYS=""; unset __PM_HELPERS_STATE __PM_HELPERS_PROJECT_ROOT __PM_HELPERS_PROJECT_ENV_KEYS' ERR

    env_init_set IN_CONTAINER "${IN_CONTAINER:-false}"
    env_init_set ORIG_PWD "$(pwd -P)"
    env_init_set PROJECT_ROOT "$requested_root"
    env_init_set REPO_ROOT "$requested_root"
    env_init_set REPO_NAME "$(basename -- "$requested_root")"

    if [[ -z "${SITE_DIR:-}" ]]; then
        if [[ -f "$ORIG_PWD/index.html" ]]; then
            env_init_set SITE_DIR "$ORIG_PWD"
        elif [[ -f "$ORIG_PWD/www/index.html" ]]; then
            env_init_set SITE_DIR "$ORIG_PWD/www"
        else
            env_init_set SITE_DIR "$ORIG_PWD"
        fi
    else
        env_init_set SITE_DIR "$SITE_DIR"
    fi

    env_init_set SITE_ROOT "${SITE_ROOT:-$SITE_DIR}"
    env_init_set SCRIPT_DIR "${SCRIPT_DIR:-${SITE_DIR}/mgt-scripts}"
    env_init_set MGT_SCRIPTS "${SITE_DIR}/mgt-scripts"
    env_init_set PORTMASON_SHARE "${PORTMASON_SHARE:-"$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"

    env_init_set ENV_FILE "${ENV_FILE:-${ORIG_PWD}/.env}"
    env_init_set ENV_EXAMPLE_SRC "${ENV_EXAMPLE_SRC:-${PORTMASON_SHARE}/templates/.env.example}"

    ensure_env_file "$@"
    setup_logging "$@"

    if [[ "${PM_DUMP_ENV_ON_INIT:-0}" == "1" ]]; then
        log "Environment variables:"
        env | sort | sed 's/^/  /'
    fi

    # shellcheck disable=SC1090
    . "${PORTMASON_SHARE}/pm-helpers-base"

    sys_bootstrap "$@"
    pm_context_record_project_keys

    __PM_HELPERS_STATE="loaded"
    __PM_HELPERS_PROJECT_ROOT="$requested_root"
    export __PM_HELPERS_STATE __PM_HELPERS_PROJECT_ROOT

    trap - ERR
}

trap_add() {
  local trap_name="$1"; shift
  local new_cmd="$*"
  local existing
  existing="$(trap -p "$trap_name" | sed -E "s/^trap -- '(.*)' ${trap_name}$/\1/")"

  if [[ -n "$existing" ]]; then
    trap "${existing}; ${new_cmd}" "$trap_name"
  else
    trap "${new_cmd}" "$trap_name"
  fi
}

upsert_job_env_vars_from_envfile(){
    local job_name="${1:-${JOB_NAME:-}}"; "${job_name:?job_name is required}"
    local fn="upsert_${RUNTIME_ADAPTER_CODE}_job_env_vars_from_envfile"

    if declare -F "$fn" >/dev/null; then
        "$fn" "$@"
    else
        warn "Skipping: runtime-specific function not defined ($fn)"
        return 1
    fi
}

warn() { log WARNING "$@"; }

write_project_timestamp() {
  local ts_filename=".project_timestamp"
  local target="${1:-$(pwd -P)}/${ts_filename}"

  # Generate an epoch timestamp in SECONDS (integer)
  ts=""

  # Prefer `date +%s` (works on GNU and BSD/macOS)
  if command -v date >/dev/null 2>&1; then
    tmp_ts="$(date +%s 2>/dev/null || true)"
    # Ensure it's all digits
    case "$tmp_ts" in
      ''|*[!0-9]*) ;;   # not a pure integer, ignore
      *) ts="$tmp_ts" ;;
    esac
  fi

  # Fallback: Python
  if [ -z "$ts" ]; then
    if command -v python3 >/dev/null 2>&1; then
      ts="$(python3 - <<'PY'
import time
print(int(time.time()))
PY
  )"
    elif command -v python >/dev/null 2>&1; then
      ts="$(python - <<'PY'
import time
print(int(time.time()))
PY
  )"
    else
      echo "Unable to generate seconds timestamp: need 'date' or Python" >&2
      exit 1
    fi
  fi

  # if [[ ! -s  "$target" ]]; then #file does not exist or it's empty
  #   printf '%s\n' "$ts" > "$target"
  #   log "(write_project_timestamp) wrote '$target' which was non-eistent or empty"
  # else #file 
  #   log WARNING "(write_project_timestamp) NOOP, '$target' exists and is not empty"
  # fi

  if [[ ! -f "$target" || ! -s "$target" ]]; then
      printf '%s\n' "$ts" > "$target"
      log "Wrote '$target', which was missing, not a regular file, or empty"
  else
      warn "NOOP, '$target' exists and is not empty"
  fi
}

# Idempotent + re-entrancy safe.
# - "loading" blocks recursion during init.
# - "loaded" blocks future calls.


# Read-only bootstrap for inspection tools such as pm-lint. It loads an
# existing project-root .env when present but never scaffolds, derives, or
# persists project identity. Normal Portmason lifecycle commands still use
# the full pm_init path below.
pm_init_read_only() {
    local requested_root
    pm_context_resolve_project_root requested_root

    PROJECT_ROOT="$requested_root"
    REPO_ROOT="$requested_root"
    ORIG_PWD="$(pwd -P)"
    PORTMASON_SHARE="${PORTMASON_SHARE:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)}"
    ENV_FILE="${ENV_FILE:-${requested_root}/.env}"
    export PROJECT_ROOT REPO_ROOT ORIG_PWD PORTMASON_SHARE ENV_FILE

    if [[ -r "$ENV_FILE" ]]; then
        set -a
        # shellcheck disable=SC1090
        . "$ENV_FILE"
        set +a
    fi

    __PM_HELPERS_STATE="loaded"
    __PM_HELPERS_PROJECT_ROOT="$requested_root"
    export __PM_HELPERS_STATE __PM_HELPERS_PROJECT_ROOT
}

# Initialize whenever pm-helpers is sourced or executed. Inspection-only
# commands request a non-mutating bootstrap explicitly.
case "${1:-}" in
    --read-only) pm_init_read_only ;;
    --minimal) : ;;
    *) pm_init "$@" ;;
esac
