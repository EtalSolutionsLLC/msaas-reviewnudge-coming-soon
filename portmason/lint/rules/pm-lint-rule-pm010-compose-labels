#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm010() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local service start_line end_line block key
    local -a keys=(
        solutions.etal.project_id
        solutions.etal.stack
        solutions.etal.deployment_id
        solutions.etal.service
    )

    pm_lint_is_compose_file "$path" || return 0

    while IFS=$'\t' read -r service start_line end_line; do
        [[ -n "$service" ]] || continue
        block="$(pm_lint_compose_service_block "$file" "$start_line" "$end_line")"
        for key in "${keys[@]}"; do
            grep -Fq "$key" <<<"$block" && continue
            pm_lint_report PM010 "$path" "$start_line" \
                "Compose service '$service' is missing required EPC label: $key" \
                "Apply the standard solutions.etal.* identity and service labels to this service."
        done
    done < <(pm_lint_compose_services_tsv "$file")
}

pm_lint_register_rule PM010 WARNING file \
    "Required EPC Compose labels" \
    "EPC A2.8.1; EPC A2.8.4" \
    pm_lint_rule_pm010
