#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm020() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local output="" rc=0 record line_no message
    local excludes="${PM_LINT_SHELLCHECK_EXCLUDES:-SC1090,SC1091}"
    local -a command=(shellcheck --shell=bash --severity=warning --format=gcc --external-sources)

    pm_lint_is_shell_file "$file" || return 0
    command -v shellcheck >/dev/null 2>&1 || return 0
    [[ -n "$excludes" ]] && command+=(--exclude="$excludes")

    output="$("${command[@]}" "$file" 2>&1)" || rc=$?
    (( rc == 0 )) && return 0

    while IFS= read -r record; do
        [[ -n "$record" ]] || continue
        line_no="$(sed -E 's#^[^:]+:([0-9]+):.*#\1#' <<<"$record")"
        [[ "$line_no" =~ ^[0-9]+$ ]] || line_no=1
        message="$(sed -E 's#^[^:]+:[0-9]+:[0-9]+:[[:space:]]*[^:]+:[[:space:]]*##' <<<"$record")"
        pm_lint_report PM020 "$path" "$line_no" \
            "ShellCheck: $message" \
            "Correct the shell defect or add the narrow ShellCheck directive required by the implementation."
    done <<<"$output"
}

pm_lint_register_rule PM020 WARNING file \
    "ShellCheck static analysis" \
    "TGF Coding Standards / Shell; TGF Quality Gates" \
    pm_lint_rule_pm020
