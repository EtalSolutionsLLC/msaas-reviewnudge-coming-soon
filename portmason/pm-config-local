#!/usr/bin/env bash
set -euo pipefail
pm_config_local() { :; }
pm_config_apply_local() {
    local adapter="${ADAPTER_CODE:-}"
    if [[ -z "$adapter" && -n "${RUNTIME_ADAPTER_CODE:-}" ]]; then
        adapter="${RUNTIME_ADAPTER_CODE#*-}"
    fi
    [[ "$adapter" == local ]] || return 0
    pm_config_write_local_files
}
