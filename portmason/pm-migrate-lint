#!/usr/bin/env bash
set -euo pipefail

: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)}"

# shellcheck disable=SC1091
. "${PORTMASON_SHARE}/pm-helpers" --read-only

usage() {
    cat <<'USAGE'
Usage:
  pm-migrate-lint [--apply] [--target PATH]

Options:
  --apply        Apply the standard lint migration baseline.
  --target PATH  Repository to migrate. Defaults to the current Git repository.
  -h, --help     Show this help.

Behavior:
  Without --apply, performs an audit only.
  With --apply, installs the shared lint baseline and runs strict validation.

The command never creates lint exceptions and never suppresses findings.
USAGE
}

resolve_repo_root() {
    local requested="${1:-}"

    if [[ -n "$requested" ]]; then
        git -C "$requested" rev-parse --show-toplevel 2>/dev/null
    else
        git rev-parse --show-toplevel 2>/dev/null
    fi
}

require_clean_worktree() {
    local root="${1:?repository root required}"

    if [[ -n "$(git -C "$root" status --porcelain)" ]]; then
        die "pm-migrate-lint: repository has uncommitted changes: $root" 2
    fi
}

ensure_directory_marker() {
    local directory="${1:?directory required}"

    mkdir -p "$directory"
    [[ -e "$directory/.gitkeep" ]] || : > "$directory/.gitkeep"
}

ensure_gitignore_entry() {
    local file="${1:?gitignore path required}"
    local entry="${2:?entry required}"

    touch "$file"

    grep -Fqx "$entry" "$file" 2>/dev/null || {
        [[ ! -s "$file" ]] || printf '\n' >> "$file"
        printf '%s\n' "$entry" >> "$file"
    }
}

write_lint_workflow() {
    local root="${1:?repository root required}"
    local workflow_dir="${root}/.github/workflows"
    local workflow="${workflow_dir}/portmason-lint.yml"

    mkdir -p "$workflow_dir"

    cat > "$workflow" <<'YAML'
name: Portmason Lint

on:
  pull_request:
  push:
    branches:
      - main
    paths:
      - ".github/workflows/portmason-lint.yml"
      - ".pm-lint-exceptions"
      - ".portmason-tooling-ref"
      - "**/*.sh"
      - "**/*.yml"
      - "**/*.yaml"
      - "Dockerfile*"
      - "docker-compose*.yml"
      - "docker-compose*.yaml"

permissions:
  contents: read

jobs:
  lint:
    runs-on: ubuntu-latest

    steps:
      - name: Check out project
        uses: actions/checkout@v7
        with:
          fetch-depth: 0

      - name: Read Portmason tooling revision
        id: portmason-ref
        run: |
          set -euo pipefail

          if [[ ! -r .portmason-tooling-ref ]]; then
            echo "::error::.portmason-tooling-ref is missing or unreadable"
            exit 1
          fi

          ref="$(tr -d '[:space:]' < .portmason-tooling-ref)"
          ref="${ref,,}"

          if [[ ! "$ref" =~ ^[0-9a-f]{40}$ ]]; then
            echo "::error::.portmason-tooling-ref must contain a full Git commit SHA"
            exit 1
          fi

          echo "sha=$ref" >> "$GITHUB_OUTPUT"

      - name: Check out Portmason
        uses: actions/checkout@v7
        with:
          repository: domer6811/ops-and-sops
          ref: ${{ steps.portmason-ref.outputs.sha }}
          token: ${{ secrets.OPS_AND_SOPS_READ_TOKEN }}
          path: ops-and-sops
          sparse-checkout: |
            ops/portmason
          sparse-checkout-cone-mode: true
          persist-credentials: false

      - name: Install lint dependencies
        run: |
          set -euo pipefail
          sudo apt-get update
          sudo apt-get install --yes shellcheck

      - name: Run Portmason lint
        env:
          PORTMASON_SHARE: ${{ github.workspace }}/ops-and-sops/ops/portmason
          PM_LINT_CI_STRICT: "true"
          PM_LINT_CI_FAIL_ON_REVIEW: "true"
        run: |
          set -euo pipefail

          echo "$PORTMASON_SHARE" >> "$GITHUB_PATH"
          "$PORTMASON_SHARE/pm-lint-ci"
YAML
}

write_tooling_ref() {
    local root="${1:?repository root required}"
    local tooling_root="${2:?tooling root required}"
    local sha=""

    sha="$(git -C "$tooling_root" rev-parse HEAD)"
    [[ "$sha" =~ ^[0-9a-f]{40}$ ]] \
        || die "pm-migrate-lint: unable to resolve Portmason tooling revision" 2

    printf '%s\n' "$sha" > "${root}/.portmason-tooling-ref"
}

run_lint_report() {
    local root="${1:?repository root required}"
    local report="${2:?report path required}"
    local strict="${3:-false}"
    local rc=0
    local -a args=(
        --root "$root"
        --all
        --format text
    )

    [[ "$strict" == true ]] && args+=(--strict --fail-on-review)

    {
        printf 'Repository: %s\n' "$root"
        printf 'Commit: %s\n' "$(git -C "$root" rev-parse HEAD)"
        printf 'Generated: %s\n\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')"

        "${PORTMASON_SHARE}/pm-lint" "${args[@]}"
    } > "$report" 2>&1 || rc=$?

    return "$rc"
}

apply_baseline() {
    local root="${1:?repository root required}"
    local tooling_root="${2:?tooling root required}"

    ensure_directory_marker "${root}/logs"
    ensure_directory_marker "${root}/logs/runtime"
    ensure_directory_marker "${root}/logs/lint-migration"

    ensure_gitignore_entry "${root}/.gitignore" "logs/*"
    ensure_gitignore_entry "${root}/.gitignore" "!logs/.gitkeep"
    ensure_gitignore_entry "${root}/.gitignore" "!logs/runtime/"
    ensure_gitignore_entry "${root}/.gitignore" "logs/runtime/*"
    ensure_gitignore_entry "${root}/.gitignore" "!logs/runtime/.gitkeep"
    ensure_gitignore_entry "${root}/.gitignore" "!logs/lint-migration/"
    ensure_gitignore_entry "${root}/.gitignore" "logs/lint-migration/*"

    write_lint_workflow "$root"
    write_tooling_ref "$root" "$tooling_root"
}

main() {
    local apply=false
    local requested_target=""
    local root=""
    local tooling_root=""
    local timestamp=""
    local report_dir=""
    local before_report=""
    local after_report=""
    local lint_rc=0

    while (( $# > 0 )); do
        case "$1" in
            --apply)
                apply=true
                shift
                ;;
            --target)
                [[ $# -ge 2 ]] \
                    || die "pm-migrate-lint: --target requires a path" 2
                requested_target="$2"
                shift 2
                ;;
            -h|--help)
                usage
                return 0
                ;;
            *)
                die "pm-migrate-lint: unknown argument: $1" 2
                ;;
        esac
    done

    root="$(resolve_repo_root "$requested_target")" \
        || die "pm-migrate-lint: target is not inside a Git repository" 2
    root="$(cd -- "$root" && pwd -P)"

    tooling_root="$(git -C "$PORTMASON_SHARE" rev-parse --show-toplevel 2>/dev/null)" \
        || die "pm-migrate-lint: Portmason tooling is not inside a Git repository" 2

    require_clean_worktree "$root"

    timestamp="$(date -u +'%Y%m%dT%H%M%SZ')"
    report_dir="${root}/logs/lint-migration"
    mkdir -p "$report_dir"

    before_report="${report_dir}/${timestamp}-before.txt"
    after_report="${report_dir}/${timestamp}-after.txt"

    log INFO "pm-migrate-lint: auditing repository" \
        "root=$root" \
        "report=$before_report"

    run_lint_report "$root" "$before_report" false || true

    if [[ "$apply" != true ]]; then
        log INFO "pm-migrate-lint: audit complete" \
            "report=$before_report"
        printf '\nAudit report: %s\n' "$before_report"
        printf 'Re-run with --apply to install the migration baseline.\n'
        return 0
    fi

    log INFO "pm-migrate-lint: applying standard lint baseline" \
        "root=$root"

    apply_baseline "$root" "$tooling_root"

    log INFO "pm-migrate-lint: running strict post-migration validation" \
        "root=$root" \
        "report=$after_report"

    run_lint_report "$root" "$after_report" true || lint_rc=$?

    printf '\nBefore report: %s\n' "$before_report"
    printf 'After report:  %s\n' "$after_report"

    if (( lint_rc != 0 )); then
        log ERROR "pm-migrate-lint: repository still has blocking lint findings" \
            "root=$root" \
            "report=$after_report" \
            "rc=$lint_rc"

        printf '\nMigration baseline was installed, but code-level findings remain.\n'
        printf 'No exceptions were created. Review: %s\n' "$after_report"
        return "$lint_rc"
    fi

    log INFO "pm-migrate-lint: repository is lint compliant" \
        "root=$root"

    printf '\nRepository is lint compliant.\n'
    git -C "$root" status --short
}

main "$@"
