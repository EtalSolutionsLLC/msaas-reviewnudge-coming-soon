#!/usr/bin/env bash
set -euo pipefail

# GitHub adapter configuration mechanics. Source-safe: no mutation at load time.
if [[ "${__PM_HELPERS_GITHUB_LOADED:-0}" == 1 ]]; then
    return 0 2>/dev/null || exit 0
fi
__PM_HELPERS_GITHUB_LOADED=1
export __PM_HELPERS_GITHUB_LOADED

: "${GITHUB_PAGES_BUILD_DIR:=${STATIC_BUILD_DIR:-${SITE_DIR:-$PWD}}}"
: "${GITHUB_PAGES_CONFIG_JSON:=${GITHUB_PAGES_BUILD_DIR}/config.generated.json}"
: "${PM_GITHUB_CONFIG_SCOPES:=routing,application,web,static,observability}"
export GITHUB_PAGES_BUILD_DIR GITHUB_PAGES_CONFIG_JSON PM_GITHUB_CONFIG_SCOPES

pm_github_resolve_repository() {
    local out_var="${1:?output variable required}"
    local resolved_repository="${PM_GITHUB_REPOSITORY:-}"

    if [[ -z "$resolved_repository" ]]; then
        have gh || die "gh is required to resolve the GitHub repository" 2
        resolved_repository="$(gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null)" \
            || die "unable to resolve the GitHub repository; set PM_GITHUB_REPOSITORY" 2
    fi
    [[ "$resolved_repository" == */* ]] \
        || die "PM_GITHUB_REPOSITORY must use owner/repository: $resolved_repository" 2
    printf -v "$out_var" '%s' "$resolved_repository"
}

pm_github_write_browser_config() {
    local file="${1:-$GITHUB_PAGES_CONFIG_JSON}"
    local directory tmp next key target value

    directory="$(dirname -- "$file")"
    mkdir -p -- "$directory"
    tmp="$(mktemp "${file}.XXXXXX")"
    chmod 600 "$tmp"
    printf '{}\n' >"$tmp"

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        pm_config_value value "$key"
        [[ -n "$value" || "${PM_CONFIG_REQUIRED[$key]}" == required ]] || continue
        target="${PM_CONFIG_TARGET[$key]}"
        next="$(mktemp "${file}.XXXXXX")"
        jq --arg key "$target" --arg value "$value" '. + {($key): $value}' \
            "$tmp" >"$next"
        mv -- "$next" "$tmp"
    done < <(pm_config_keys_for_scopes var "$PM_GITHUB_CONFIG_SCOPES")

    mv -- "$tmp" "$file"
    chmod 644 "$file"
    log INFO "pm-config-github: wrote public browser configuration" \
        "file=$file" "scopes=$PM_GITHUB_CONFIG_SCOPES"
}

pm_github_sync_actions_config() {
    local repository key target value
    have gh || die "gh is required to synchronize GitHub Actions configuration" 2
    pm_github_resolve_repository repository

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        pm_config_value value "$key"
        [[ -n "$value" || "${PM_CONFIG_REQUIRED[$key]}" == required ]] || continue
        target="${PM_CONFIG_TARGET[$key]}"
        gh variable set "$target" --body "$value" --repo "$repository" >/dev/null
        log INFO "pm-config-github: synchronized Actions variable" \
            "repository=$repository" "key=$target"
    done < <(pm_config_keys_for_scopes var "$PM_GITHUB_CONFIG_SCOPES")

    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        pm_config_value value "$key"
        if [[ -z "$value" ]] && ! pm_config_secret_override_exists "$key"; then
            continue
        fi
        target="${PM_CONFIG_TARGET[$key]}"
        printf '%s' "$value" \
            | gh secret set "$target" --body - --repo "$repository" >/dev/null
        log INFO "pm-config-github: synchronized Actions secret" \
            "repository=$repository" "key=$target"
    done < <(pm_config_keys_for_scopes secret "$PM_GITHUB_CONFIG_SCOPES")
}

github_pages_prepare() {
    pm_github_write_browser_config "$GITHUB_PAGES_CONFIG_JSON"
    touch "${GITHUB_PAGES_BUILD_DIR}/.nojekyll"
    log INFO "GitHub Pages static artifact ready" \
        "directory=$GITHUB_PAGES_BUILD_DIR"
}
