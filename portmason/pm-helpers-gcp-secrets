#!/usr/bin/env bash
set -euo pipefail


GCP_SECRET_MANAGER_PROJECT_ID=github-archive-480721
GCP_SECRET_MANAGER_PROJECT_NAME=github-archive
export GCP_SECRET_MANAGER_PROJECT_ID
export GCP_SECRET_MANAGER_PROJECT_NAME

: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
. "${PORTMASON_SHARE}/pm-helpers" $@

# GCP Secret Manager synchronization and Cloud Run secret-argument helpers.
# Secret values are never logged.

if [[ "${__PM_HELPERS_GCP_SECRETS_LOADED:-0}" == "1" ]]; then
    return 0 2>/dev/null || exit 0
fi
__PM_HELPERS_GCP_SECRETS_LOADED=1
export __PM_HELPERS_GCP_SECRETS_LOADED

pm_gcp_ensure_config_manager() {
    if ! declare -F pm_config_manager_prepare >/dev/null 2>&1; then
        # shellcheck disable=SC1090
        . "${PORTMASON_SHARE}/pm-config-manager"
    fi
    if [[ "${PM_CONFIG_MANAGER_PREPARED:-0}" != 1 ]]; then
        pm_config_manager_prepare gcp
    fi
}

pm_gcp_secret_name_for_key() {
    local out_var="${1:?output variable required}"
    local key="${2:?key required}"
    local base="${STACK:?STACK required}-${key}"
    base="${base,,}"
    base="${base//_/-}"
    base="$(printf '%s' "$base" | sed 's/[^a-z0-9-]/-/g; s/-\{2,\}/-/g; s/^-//; s/-$//')"
    [[ -n "$base" ]] || base="portmason-secret"
    printf -v "$out_var" '%s' "${base:0:255}"
}

pm_gcp_secret_override_parts() {
    local out_project="${1:?project output required}"
    local out_secret="${2:?secret output required}"
    local key="${3:?key required}"
    local line ref path result_project="" result_secret=""

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -n "$line" && "$line" == *"|"* ]] || continue
        ref="${line%%|*}"
        path="${line#*|}"
        [[ "$ref" == "$key" ]] || continue

        path="${path#gcs:}"
        path="${path#gcp:}"
        case "$path" in
            projects/*/secrets/*)
                result_project="${path#projects/}"
                result_project="${result_project%%/*}"
                result_secret="${path##*/}"
                ;;
            *:*)
                result_project="${path%%:*}"
                result_secret="${path#*:}"
                ;;
            *)
                result_project="${DEPLOYMENT_ID:-}"
                result_secret="$path"
                ;;
        esac
        printf -v "$out_project" '%s' "$result_project"
        printf -v "$out_secret" '%s' "$result_secret"
        return 0
    done <<<"${SECRET_PATHS:-}"

    return 1
}

pm_gcp_secret_location_for_key() {
    local out_project="${1:?project output required}"
    local out_secret="${2:?secret output required}"
    local key="${3:?key required}"
    local result_project="" result_secret=""

    if pm_gcp_secret_override_parts result_project result_secret "$key"; then
        :
    else
        result_project="${DEPLOYMENT_ID:?DEPLOYMENT_ID required}"
        pm_gcp_secret_name_for_key result_secret "$key"
    fi

    printf -v "$out_project" '%s' "$result_project"
    printf -v "$out_secret" '%s' "$result_secret"
}

pm_gcp_secret_resource_for_key() {
    local out_var="${1:?output variable required}"
    local key="${2:?key required}"
    local project secret
    pm_gcp_secret_location_for_key project secret "$key"
    printf -v "$out_var" '%s' "projects/${project}/secrets/${secret}"
}   

pm_gcp_ensure_secret_container() {
    local project="${1:?project required}"
    local secret="${2:?secret required}"

    if gcloud secrets describe "$secret" --project "$project" >/dev/null 2>&1; then
        log DEBUG "pm-gcp-secrets: secret container exists" \
            "project=$project" "secret=$secret"
        return 0
    fi

    log INFO "pm-gcp-secrets: creating secret container" \
        "project=$project" "secret=$secret"
    gcloud secrets create "$secret" \
        --project "$project" \
        --replication-policy=automatic \
        >/dev/null
}

pm_gcp_secret_latest_matches() {
    local project="${1:?project required}"
    local secret="${2:?secret required}"
    local value="${3-}"
    local tmp current_hash wanted_hash

    tmp="$(mktemp)"
    chmod 600 "$tmp"
    if ! gcloud secrets versions access latest \
        --secret "$secret" \
        --project "$project" \
        --out-file "$tmp" >/dev/null 2>&1; then
        rm -f "$tmp"
        return 1
    fi

    current_hash="$(sha256sum "$tmp" | awk '{print $1}')"
    wanted_hash="$(printf '%s' "$value" | sha256sum | awk '{print $1}')"
    rm -f "$tmp"
    [[ "$current_hash" == "$wanted_hash" ]]
}

pm_gcp_sync_secret_value() {
    local key="${1:?key required}"
    local value="${2-}"
    local project secret

    pm_gcp_secret_location_for_key project secret "$key"
    pm_gcp_ensure_secret_container "$project" "$secret"

    if [[ -z "$value" ]]; then
        log INFO "pm-gcp-secrets: using existing externally managed secret" \
            "key=$key" "project=$project" "secret=$secret"
        gcloud secrets versions access latest \
            --secret "$secret" --project "$project" >/dev/null 2>&1 \
            || die "Secret override for $key has no accessible version: projects/$project/secrets/$secret" 2
        return 0
    fi

    if pm_gcp_secret_latest_matches "$project" "$secret" "$value"; then
        log INFO "pm-gcp-secrets: secret value is current" \
            "key=$key" "project=$project" "secret=$secret"
        return 0
    fi

    log INFO "pm-gcp-secrets: adding secret version" \
        "key=$key" "project=$project" "secret=$secret"
    printf '%s' "$value" \
        | gcloud secrets versions add "$secret" \
            --project "$project" \
            --data-file=- \
            >/dev/null
}

pm_gcp_get_secret_value() {
    local out_var="${1:?output variable required}"
    local key="${2:?key required}"
    local project secret result
    pm_gcp_secret_location_for_key project secret "$key"
    result="$(gcloud secrets versions access latest \
        --secret "$secret" --project "$project")" \
        || return 1
    printf -v "$out_var" '%s' "$result"
}

pm_gcp_get_or_create_internal_secret() {
    local out_var="${1:?output variable required}"
    local key="${2:?key required}"
    local value="${!key:-}"
    local project secret

    pm_gcp_secret_location_for_key project secret "$key"
    if [[ -z "$value" ]] && gcloud secrets versions access latest \
        --secret "$secret" --project "$project" >/dev/null 2>&1; then
        pm_gcp_get_secret_value value "$key"
        log INFO "pm-gcp-secrets: loaded existing internal secret" \
            "key=$key" "project=$project" "secret=$secret"
    fi

    if [[ -z "$value" ]]; then
        have openssl || die "openssl is required to generate internal secret $key" 2
        value="$(openssl rand -base64 48 | tr -d '\r\n')"
        log INFO "pm-gcp-secrets: generated internal secret" \
            "key=$key" "project=$project" "secret=$secret"
    fi

    pm_gcp_sync_secret_value "$key" "$value"
    printf -v "$out_var" '%s' "$value"
}

pm_gcp_sync_project_runtime_secrets() {
    [[ "${DEPLOY_ENV:-dev}" != "dev" ]] || {
        log DEBUG "pm-gcp-secrets: development environment; platform secret synchronization skipped"
        return 0
    }

    pm_gcp_ensure_config_manager
    local service role key value
    declare -A seen=()
    log INFO "pm-gcp-secrets: synchronizing runtime secret contract"    

    while IFS=$'	' read -r service role _image _has_build; do
        [[ -n "$service" && -n "$role" ]] || continue
        while IFS= read -r key; do
            [[ -n "$key" && -z "${seen[$key]+x}" ]] || continue
            seen["$key"]=1
            pm_config_value value "$key"
            if [[ -n "$value" ]] || pm_config_secret_override_exists "$key"; then
                pm_gcp_sync_secret_value "$key" "$value"
            fi
        done < <(pm_config_registered_source_keys_for_service "$service" "$role" secret)
    done < <(pm_compose_deployable_services_tsv)

    log INFO "pm-gcp-secrets: runtime secret synchronization complete" \
        "count=${#seen[@]}"
}

pm_gcp_secret_args_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local source target value resource
    pm_gcp_ensure_config_manager
    while IFS= read -r -d '' source; do
        IFS= read -r -d '' target || target="$source"
        IFS= read -r -d '' value || value=""
        pm_gcp_secret_resource_for_key resource "$source"
        printf '%s\0%s\0' "--set-secrets" "${target}=${resource}:latest"
    done < <(pm_config_secret_binding_nul_for_service "$service" "$role")
}

pm_gcp_secret_args_for_role() {
    local role="${1:?service role required}"
    pm_gcp_secret_args_for_service "$role" "$role"
}

pm_gcp_env_args_for_service() {
    local service="${1:?service required}"
    local role="${2:?service role required}"
    local key value
    pm_gcp_ensure_config_manager
    while IFS= read -r -d '' key; do
        IFS= read -r -d '' value || value=""
        printf '%s\0%s\0' "--set-env-vars" "${key}=${value}"
    done < <(pm_config_var_kv_nul_for_service "$service" "$role")
}

pm_gcp_env_args_for_role() {
    local role="${1:?service role required}"
    pm_gcp_env_args_for_service "$role" "$role"
}

pm_gcp_write_env_file_for_service() {
    local out_var="${1:?output variable required}"
    local service="${2:?service required}"
    local role="${3:?service role required}"
    local file key value json_value count=0
    pm_gcp_ensure_config_manager

    file="$(mktemp)"
    chmod 600 "$file"
    while IFS= read -r -d '' key; do
        IFS= read -r -d '' value || value=""
        json_value="$(jq -Rn --arg value "$value" '$value')" \
            || { rm -f "$file"; die "pm-gcp-secrets: unable to encode environment value for $key" 2; }
        printf '%s: %s\n' "$key" "$json_value" >>"$file"
        ((count+=1))
    done < <(pm_config_var_kv_nul_for_service "$service" "$role")

    printf -v "$out_var" '%s' "$file"
    log DEBUG "pm-gcp-secrets: wrote runtime environment file" \
        "service=$service" "role=$role" "variables=$count" "file=$file"
}

pm_gcp_write_env_file_for_role() {
    local out_var="${1:?output variable required}"
    local role="${2:?service role required}"
    pm_gcp_write_env_file_for_service "$out_var" "$role" "$role"
}

pm_gcp_bind_service_secret_access() {
    local service_account="${1:?service account required}"
    local service role
    if (( $# >= 3 )); then
        service="${2:?service required}"
        role="${3:?service role required}"
    else
        role="${2:?service role required}"
        service="$role"
    fi

    local source target value project secret
    declare -A seen=()
    pm_gcp_ensure_config_manager
    while IFS= read -r -d '' source; do
        IFS= read -r -d '' target || target="$source"
        IFS= read -r -d '' value || value=""
        [[ -z "${seen[$source]+x}" ]] || continue
        seen["$source"]=1
        pm_gcp_secret_location_for_key project secret "$source"
        log INFO "pm-gcp-secrets: ensuring runtime secret access" \
            "service_account=$service_account" "service=$service" \
            "key=$source" "project=$project" "secret=$secret"
        gcloud secrets add-iam-policy-binding "$secret" \
            --project "$project" \
            --member "serviceAccount:${service_account}" \
            --role roles/secretmanager.secretAccessor \
            --quiet >/dev/null
    done < <(pm_config_secret_binding_nul_for_service "$service" "$role")
}
