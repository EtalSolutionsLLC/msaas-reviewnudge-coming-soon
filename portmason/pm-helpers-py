#!/usr/bin/env bash
set -euo pipefail

script_name="${script_name:-$(basename "${BASH_SOURCE[0]}")}"

# --- Configuration (env overridable) ---
PROJECT_DIR="${PROJECT_DIR:-$PWD}"
CLI_ENTRYPOINT_FILE="${CLI_ENTRYPOINT_FILE:-${PROJECT_DIR}/main.py}"
CLI_ENTRYPOINT_MODULE="${CLI_ENTRYPOINT_MODULE:-}"
CLI_DEFAULT_ARGS="${CLI_DEFAULT_ARGS:-}"

run() {
  ensure_env_created
  "$(venv_python)" "$@"
}

