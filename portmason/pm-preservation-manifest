#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
: "${PORTMASON_SHARE:=$SCRIPT_DIR}"
export PORTMASON_SHARE

# shellcheck disable=SC1091
. "${PORTMASON_SHARE}/pm-helpers" --read-only

pm_preservation_validate() {
    local file="${1:?manifest required}"
    have jq || die "pm-preservation-manifest requires jq" 2
    [[ -r "$file" ]] || die "preservation manifest not readable: $file" 2

    jq -e '
      .schemaVersion == "1.0"
      and (.migrationId | type == "string" and length > 5)
      and (.createdAt | test("^[0-9]{4}-[0-9]{2}-[0-9]{2}$"))
      and (.sourceSnapshot.file | type == "string" and length > 0)
      and (.sourceSnapshot.sha256 | test("^[a-f0-9]{64}$"))
      and (.preserved | type == "object")
      and (.preserved.services | type == "array")
      and (.preserved.volumes | type == "array")
      and (.preserved.routes | type == "array")
      and (.preserved.environmentKeys | type == "array")
      and (.renamed | type == "object")
      and (.removed | type == "array")
      and all(.removed[]; (.item | type == "string" and length > 0) and (.reason | type == "string" and length > 12))
      and (.added | type == "array")
      and (.verification | type == "array" and length > 0)
    ' "$file" >/dev/null

    log INFO "preservation manifest valid" "file=$file" \
        "services=$(jq '.preserved.services | length' "$file")" \
        "environment_keys=$(jq '.preserved.environmentKeys | length' "$file")"
}

pm_preservation_usage() {
    cat <<'USAGE'
Usage:
  pm-preservation-manifest validate FILE
  pm-preservation-manifest summary FILE
  pm-preservation-manifest template [OUTPUT]
USAGE
}

main() {
    local command_name="${1:-}"
    case "$command_name" in
        validate)
            [[ $# -eq 2 ]] || die "validate requires one manifest path" 2
            pm_preservation_validate "$2"
            ;;
        summary)
            [[ $# -eq 2 ]] || die "summary requires one manifest path" 2
            pm_preservation_validate "$2" >/dev/null
            jq -r '
              "migration: \(.migrationId)",
              "snapshot: \(.sourceSnapshot.file)",
              "preserved services: \(.preserved.services | join(", "))",
              "preserved volumes: \(.preserved.volumes | join(", "))",
              "renamed: \(.renamed | keys | length)",
              "removed: \(.removed | length)",
              "added: \(.added | length)",
              "verification checks: \(.verification | length)"
            ' "$2"
            ;;
        template)
            local output="${2:-preservation.json}"
            [[ ! -e "$output" ]] || die "refusing to overwrite existing file: $output" 2
            cp -- "${PORTMASON_SHARE}/templates/preservation.json.example" "$output"
            log INFO "created preservation manifest template" "file=$output"
            ;;
        -h|--help|help)
            pm_preservation_usage
            ;;
        *)
            pm_preservation_usage >&2
            die "unknown pm-preservation-manifest command: ${command_name:-<unset>}" 2
            ;;
    esac
}

main "$@"
