#!/usr/bin/env bash

## Purpose: Capture a project workspace using source-of-truth directory boundaries.

## Behavior: Best-effort. Capture failures are logged and do not stop unrelated sections.

set -u
set -o pipefail || true

script_name="$(basename "${BASH_SOURCE[0]}")"

# ---- SNIP: (unchanged content omitted for brevity above) ----
# EVERYTHING ABOVE THIS POINT REMAINS EXACTLY THE SAME
# (no changes were made to your capture logic)

# ---- SNIP ----

if (( COPILOT_MODE == 1 )); then
  SNAPSHOT_FILE="$RUN_DIR/copilot_snapshot.txt"
  log "Generating Copilot snapshot: $SNAPSHOT_FILE"

  {
  echo "===== CAPTURE MANIFEST ====="
  if [[ -f "$RUN_DIR/capture-manifest.txt" ]]; then
    cat "$RUN_DIR/capture-manifest.txt"
  else
    echo "NOT FOUND"
  fi

  echo ""
  echo "===== PROJECT ENV FILES ====="

  if [[ -d "$PROJECT_OUT" ]]; then
    found_env=0
    for f in "$PROJECT_OUT"/.env*; do
      if [[ -f "$f" ]]; then
        found_env=1
        echo "--- $(basename "$f") ---"
        cat "$f"
        echo ""
      fi
    done

    if [[ "$found_env" -eq 0 ]]; then
      echo "NO ENV FILES FOUND"
    fi
  else
    echo "PROJECT_OUT DIRECTORY NOT FOUND"
  fi

  } > "$SNAPSHOT_FILE"

  echo "Copilot snapshot created:"
  echo "$SNAPSHOT_FILE"
fi

log "Capture complete."
echo "Run directory:  $RUN_DIR"

isfile "$ARCHIVE_PATH" && echo "Archive:        $ARCHIVE_PATH"

[[ -n "$COPY_TARGET" ]] && echo "Copy target:    $COPY_TARGET (best-effort)"

exit 0
