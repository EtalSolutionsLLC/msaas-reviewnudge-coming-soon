mkdir -p security-reports/zap

docker run \
  --rm \
  --volume "$PWD/security-reports/zap:/zap/wrk:rw" \
  --tty \
  ghcr.io/zaproxy/zaproxy:stable \
  zap-baseline.py \
    --target 'https://YOUR-PRODUCTION-HOST' \
    --ajax-spider \
    --report zap-baseline.html \
    --json-report zap-baseline.json