#!/usr/bin/env bash
set -euo pipefail

# Neon platform helpers. Safe to source: no infrastructure mutation occurs here.

: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
. "${PORTMASON_SHARE}/pm-helpers" $@

if [[ "${__PM_HELPERS_NEON_LOADED:-0}" == "1" ]]; then
    return 0 2>/dev/null || exit 0
fi
__PM_HELPERS_NEON_LOADED=1
export __PM_HELPERS_NEON_LOADED

: "${NEON_API_BASE:=https://console.neon.tech/api/v2}"
: "${NEON_API_CONNECT_TIMEOUT_SECONDS:=10}"
: "${NEON_API_MAX_TIME_SECONDS:=90}"
: "${NEON_OPERATION_ATTEMPTS:=90}"
: "${NEON_OPERATION_DELAY_SECONDS:=2}"
: "${DB_REGION_ID:=aws-us-west-2}"
: "${NEON_PG_VERSION:=17}"
: "${NEON_BRANCH_NAME:=main}"
: "${NEON_USE_POOLER:=true}"
export NEON_API_BASE NEON_API_CONNECT_TIMEOUT_SECONDS NEON_API_MAX_TIME_SECONDS
export NEON_OPERATION_ATTEMPTS NEON_OPERATION_DELAY_SECONDS DB_REGION_ID
export NEON_PG_VERSION NEON_BRANCH_NAME NEON_USE_POOLER

neon_urlencode() {
    local out_var="${1:?output variable required}"
    local value="${2-}"
    local encoded
    encoded="$(jq -nr --arg value "$value" '$value | @uri')" \
        || die "unable to URL-encode API parameter" 2
    printf -v "$out_var" '%s' "$encoded"
}

neon_adopt_legacy_api_key() {
    if [[ -n "${DB_API_KEY:-}" && -n "${NEON_API_KEY:-}" ]]; then
        warn "DB_API_KEY and deprecated NEON_API_KEY are both configured; remove NEON_API_KEY" 2
    fi
    [[ -n "${DB_API_KEY:-}" || -z "${NEON_API_KEY:-}" ]] && return 0

    DB_API_KEY="$NEON_API_KEY"
    export DB_API_KEY
    unset NEON_API_KEY
    log WARN "mapped deprecated control-plane credential in memory" \
        "from=NEON_API_KEY" "to=DB_API_KEY"
}

neon_load_api_key() {
    neon_sync_control_secret

    [[ -n "${DB_API_KEY:-}" ]] \
        || die "DB_API_KEY is required or must resolve through SECRET_PATHS" 2

}

neon_sync_control_secret() {
    [[ "${DEPLOY_ENV:-dev}" != "dev" ]] || return 0
    local secret_val=$(get_secret "${DB_API_KEY_PATH:-}") 
    DB_API_KEY="${secret_val}"
    export DB_API_KEY
    log INFO "control-plane credential synchronized" "key=DB_API_KEY" "path=${DB_API_KEY_PATH:-}" "partial_value=${DB_API_KEY:0:5}"
}

neon_api_request() {
    local out_var="${1:?output variable required}"
    local method="${2:?HTTP method required}"
    local path="${3:?API path required}"
    local body="${4-}"
    local response_file status response_body message
    local -a curl_args

#    =10000
    DATABASE_STARTUP_ATTEMPTS=30
    DATABASE_STARTUP_DELAY_MS=1000
    DATABASE_MAX_TIMEOUT_MS=100000

    neon_load_api_key
    response_file="$(mktemp)"
    chmod 600 "$response_file"
    curl_args=(
        --silent --show-error
        --connect-timeout "$(( (DATABASE_CONNECTION_TIMEOUT_MS + 999) / 1000 ))"
        --max-time "$(( (DB_MAX_TIMEOUT_MS + 999) / 1000 ))"
        --request "$method"
        --header 'Accept: application/json'
        --header "Authorization: Bearer ${DB_API_KEY}"
        --output "$response_file"
        --write-out '%{http_code}'
    )
    if [[ -n "$body" ]]; then
        curl_args+=(--header 'Content-Type: application/json' --data "$body")
    fi

    log DEBUG "API request" "method=$method" "path=$path"
    if ! status="$(curl "${curl_args[@]}" "${NEON_API_BASE}${path}")"; then
        rm -f "$response_file"
        die "API request failed: $method $path" 2
    fi
    response_body="$(cat "$response_file")"
    rm -f "$response_file"
    [[ -n "$response_body" ]] || response_body='{}'

    if [[ ! "$status" =~ ^2[0-9][0-9]$ ]]; then
        message="$(jq -r '.message // .error // .detail // "No error message returned"' \
            <<<"$response_body" 2>/dev/null || printf 'Unable to parse Neon API error')"
        die "API returned HTTP $status for $method $path: $message" 2
    fi
    jq -e . >/dev/null 2>&1 <<<"$response_body" \
        || die "API returned invalid JSON for $method $path" 2
    printf -v "$out_var" '%s' "$response_body"
    log DEBUG "API request complete" "method=$method" "path=$path" "status=$status"
}

neon_wait_for_operation() {
    local operation_id="${1:?operation ID required}"
    local attempt response status
    for ((attempt=1; attempt<=NEON_OPERATION_ATTEMPTS; attempt+=1)); do
        neon_api_request response GET "/projects/${DB_PROJECT_ID}/operations/${operation_id}"
        status="$(jq -r '.operation.status // empty' <<<"$response")"
        log DEBUG "operation status" "operation=$operation_id" \
            "status=${status:-unknown}" "attempt=$attempt"
        case "$status" in
            finished|skipped) return 0 ;;
            failed|cancelled) die "operation $operation_id ended with status $status" 2 ;;
            scheduling|running|cancelling|'') sleep "$NEON_OPERATION_DELAY_SECONDS" ;;
            *) die "operation $operation_id returned unknown status $status" 2 ;;
        esac
    done
    die "timed out waiting for operation $operation_id" 2
}

neon_wait_for_operations() {
    local response_json="${1:-}" operation_id count=0
    [[ -n "$response_json" ]] || response_json='{}'
    while IFS= read -r operation_id; do
        [[ -n "$operation_id" ]] || continue
        ((count+=1))
        neon_wait_for_operation "$operation_id"
    done < <(jq -r '.operations[]?.id // .operation.id // empty' <<<"$response_json")
    log DEBUG "operation wait complete" "count=$count"
}

neon_connection_uri() {
    local out_var="${1:?output variable required}"
    local role="${2:?role required}"
    local database="${3:?database required}"
    local pooled="${4:?pooled flag required}"
    local branch endpoint db role_enc response uri
    neon_urlencode branch "$DB_BRANCH_ID"
    neon_urlencode endpoint "$NEON_ENDPOINT_ID"
    neon_urlencode db "$database"
    neon_urlencode role_enc "$role"
    neon_api_request response GET \
        "/projects/${DB_PROJECT_ID}/connection_uri?branch_id=${branch}&endpoint_id=${endpoint}&database_name=${db}&role_name=${role_enc}&pooled=${pooled}"
    uri="$(jq -r '.uri // .connection_uri // empty' <<<"$response")"
    [[ -n "$uri" ]] || die "connection URI was not returned" 2
    printf -v "$out_var" '%s' "$uri"
}

db_platform_preflight() {
    [[ "${DB_PLATFORM_CODE:-}" == "neon" ]] || return 0

    have curl || pm_preflight_error "database.platform.neon" "curl" \
                "curl is required for Neon API operations"
    have jq || pm_preflight_error "database.platform.neon" "jq" \
        "jq is required for Neon API operations"
    pm_preflight_require_secret_with_alias \
        "database.platform.neon" "DB_API_KEY" "NEON_API_KEY" \
        "Neon API credential is required in DB_API_KEY or must be mapped through SECRET_PATHS"

    case "$NEON_PG_VERSION" in
        14|15|16|17|18) ;;
        *) pm_preflight_error "database.platform.neon" "NEON_PG_VERSION" \
            "must be one of 14, 15, 16, 17, or 18" ;;
    esac
    [[ -n "$DB_REGION_ID" ]] \
        || pm_preflight_error "database.platform.neon" "DB_REGION_ID" "must not be empty"
    if [[ -n "${DB_ORG_ID:-}" && ! "$DB_ORG_ID" =~ ^[a-z0-9-]{1,60}$ ]]; then
        pm_preflight_error "database.platform.neon" "DB_ORG_ID" \
            "must match ^[a-z0-9-]{1,60}$"
    fi
    [[ "$NEON_OPERATION_ATTEMPTS" =~ ^[0-9]+$ && "$NEON_OPERATION_ATTEMPTS" -gt 0 ]] \
        || pm_preflight_error "database.platform.neon" "NEON_OPERATION_ATTEMPTS" "must be a positive integer"
    [[ "$NEON_OPERATION_DELAY_SECONDS" =~ ^[0-9]+$ ]] \
        || pm_preflight_error "database.platform.neon" "NEON_OPERATION_DELAY_SECONDS" "must be a non-negative integer"
    case "$NEON_USE_POOLER" in
        1|true|TRUE|yes|YES|on|ON|0|false|FALSE|no|NO|off|OFF) ;;
        *) pm_preflight_error "database.platform.neon" "NEON_USE_POOLER" "must be boolean" ;;
    esac
}
# Build 087 compatibility entrypoints. The entity helper owns the Neon-specific
# behavior; these names preserve the established Portmason lifecycle contract.
pm_db_platform_preflight() {
    db_platform_preflight "$@"
}

pm_neon_adopt_legacy_api_key() {
    neon_adopt_legacy_api_key "$@"
}

pm_neon_api_request() {
    neon_api_request "$@"
}

pm_neon_connection_uri() {
    neon_connection_uri "$@"
}

