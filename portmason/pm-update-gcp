#!/usr/bin/env bash

set -euo pipefail

main() {
    : "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
    . "${PORTMASON_SHARE}/pm-helpers" "$@"

    TAG="v$(date +%Y%m%d-%H%M%S)"

    gcloud config set project "$DEPLOYMENT_ID"

    gcloud builds submit \
      --region="$REGION" \
      --tag "$REGION-docker.pkg.dev/$DEPLOYMENT_ID/$AR_REPO/$IMAGE:$TAG" \
      .

    digest="$(gcloud artifacts docker images describe \
        "$REGION-docker.pkg.dev/$DEPLOYMENT_ID/$AR_REPO/$IMAGE:$TAG" \
        --format='value(image_summary.digest)')"

    gcloud run jobs update "$JOB" \
      --region="$REGION" \
      --image "$REGION-docker.pkg.dev/$DEPLOYMENT_ID/$AR_REPO/$IMAGE:$digest"
}

main "$@"
