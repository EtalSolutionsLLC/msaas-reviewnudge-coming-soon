#!/usr/bin/env bash
set -euo pipefail

# Binding between PostgreSQL provider behavior and Docker Compose local hosting.

pm_db_bridge_provision() {
    [[ "${DB_PROVIDER_CODE:-}" == "postgres" && "${DB_PLATFORM_CODE:-}" == "local" ]] \
        || die "postgres-local bridge loaded for the wrong implementation" 2

    local service
    service="$(pm_compose_service_for_role db)"
    [[ -n "$service" ]] || die "postgres-local requires one Compose service with role db" 2

    env_init_set PM_DB_SERVICE "$service"
    env_init_set DB_HOST "${DB_HOST:-$service}"
    env_init_set DB_PORT "${DB_PORT:-5432}"
    env_init_set DB_ADMIN_USER "${DB_ADMIN_USER:-${DB_USER:-}}"
    env_init_set DB_ADMIN_PASSWORD "${DB_ADMIN_PASSWORD:-${DB_PASSWORD:-}}"

    local url
    pm_db_postgres_build_url url "$DB_HOST" "$DB_PORT" "$DB_NAME" "$DB_USER" "$DB_PASSWORD" "${DATABASE_SSL_MODE:-disable}"
    env_init_set DATABASE_URL "$url"
    env_init_set DATABASE_DIRECT_URL "$url"
    pm_db_publish_generated_contract

    log INFO "provider/platform binding ready" \
        "service=$PM_DB_SERVICE" "host=$DB_HOST" "port=$DB_PORT" \
        "database=$DB_NAME"
}

pm_db_bridge_deploy() {
    log INFO "verifying local PostgreSQL execution path" \
        "service=${PM_DB_SERVICE:-<unset>}"
    db_rt --command 'SELECT 1' >/dev/null
    log INFO "local PostgreSQL execution path verified"
}

db_rt() {
    local user="${PM_DB_RT_USER:-${DB_USER:?DB_USER required}}"
    local password="${PM_DB_RT_PASSWORD:-${DB_PASSWORD:?DB_PASSWORD required}}"
    local database="${PM_DB_RT_DATABASE:-${DB_NAME:?DB_NAME required}}"
    local service="${PM_DB_SERVICE:-$(pm_compose_service_for_role db)}"

    [[ -n "$service" ]] || die "db_rt: local db service could not be resolved" 2
    [[ ${#PM_COMPOSE_CMD[@]} -gt 0 ]] || pm_compose_init_command

    log DEBUG "executing psql" \
        "service=$service" "user=$user" "database=$database"

    # Pass secret values through the client process environment and ask Compose
    # to forward only the variable names. This keeps passwords out of argv and
    # out of command logging while preserving a fully containerized workflow.
    PGPASSWORD="$password" PM_DB_SQL_SECRET="${PM_DB_SQL_SECRET:-}" \
        "${PM_COMPOSE_CMD[@]}" exec -T \
            -e PGPASSWORD -e PM_DB_SQL_SECRET \
            "$service" \
            psql --set=ON_ERROR_STOP=1 --no-psqlrc \
            --username "$user" --dbname "$database" "$@"
}
