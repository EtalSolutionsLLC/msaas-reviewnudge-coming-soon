#!/usr/bin/env bash
# pm-health-generic: explicit fallback for runtimes without a first-class adapter yet
# shellcheck shell=bash

set -euo pipefail

cmd="${1:-}"
case "$cmd" in
  compose-test-json)
    if [[ -z "${PM_HEALTHCHECK_TEST:-}" ]]; then
      printf 'pm-health-generic: PM_HEALTHCHECK_TEST is required for runtime %s\n' "${RUNTIME_ADAPTER_CODE:-unknown}" >&2
      printf 'pm-health-generic: example: PM_HEALTHCHECK_TEST='"'"'["CMD", "node", "/path/to/probe"]'"'"'\n' >&2
      exit 2
    fi
    printf '%s\n' "$PM_HEALTHCHECK_TEST"
    ;;
  *)
    printf 'pm-health-generic: unsupported command: %s\n' "$cmd" >&2
    exit 2
    ;;
esac
