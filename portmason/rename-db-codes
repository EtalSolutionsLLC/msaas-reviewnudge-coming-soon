#!/usr/bin/env bash
set -euo pipefail

platform_pattern='(?<![A-Za-z0-9_])DB_PLATFORM_CODE(?![A-Za-z0-9_])'
provider_pattern='(?<![A-Za-z0-9_])DB_PROVIDER_CODE(?![A-Za-z0-9_])'

declare -a files=()

while IFS= read -r -d '' file; do
  if grep -Pq "$provider_pattern" "$file"; then
    files+=("$file")
  fi
done < <(
  grep -RIlZP \
    --exclude-dir='.git' \
    "$platform_pattern" \
    .
)

if ((${#files[@]} == 0)); then
  printf 'No files contain both standalone variables.\n'
  exit 0
fi

for file in "${files[@]}"; do
  perl -pi -e '
    s/(?<![A-Za-z0-9_])DB_PLATFORM_CODE(?![A-Za-z0-9_])/DB_PLATFORM_CODE/g;
    s/(?<![A-Za-z0-9_])DB_PROVIDER_CODE(?![A-Za-z0-9_])/DB_PROVIDER_CODE/g;
  ' "$file"

  printf 'Updated: %s\n' "$file"
done

printf '\nVerifying original standalone variables are gone...\n'

failed=0

for file in "${files[@]}"; do
  if grep -nP \
    "$platform_pattern|$provider_pattern" \
    "$file"; then
    printf 'Verification failed: %s\n' "$file" >&2
    failed=1
  fi
done

if ((failed)); then
  exit 1
fi

printf 'Verification passed. Updated %d file(s).\n' "${#files[@]}"
