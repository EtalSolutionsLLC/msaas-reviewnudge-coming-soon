#!/usr/bin/env bash
set -euo pipefail


: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]:-${0:-}}")}"
export CUR_SCRIPT

env_init_set TRAEFIK_DIR "${TRAEFIK_DIR:-$HOME/code/traefik}"
env_init_set LOCAL_EXEC_MODE "${LOCAL_EXEC_MODE:-container}"
env_init_set LOCAL_CONTAINER_ENGINE "${LOCAL_CONTAINER_ENGINE:-docker}"

if [[ "${IN_CONTAINER}" != true ]]; then
    pm_setup_arg COMPOSE_FILE "-c|--compose_file" needs_value export
    pm_commit_args "$@"

    . "${PORTMASON_SHARE}/pm-ensure-external-networks" "$@"
fi

local_exec_mode() {
  printf '%s' "${LOCAL_EXEC_MODE:-container}"
}

local_exec_is_container() {
  [[ "$(local_exec_mode)" == "container" ]]
}

local_exec_is_native() {
  [[ "$(local_exec_mode)" == "native" ]]
}

local_exec_is_venv() {
  [[ "$(local_exec_mode)" == "venv" ]]
}

get_gcp_secret() {
    local id="$1"                          # github-archive-480721:cosign-private-key
    local project_id="${id%%:*}"           # github-archive-480721
    local secret_name="${id#*:}"           # cosign-private-key

    local secret_value
    secret_value="$(
        gcloud secrets versions access latest \
        --secret="${secret_name}" \
        --project="${project_id}"
    )" || die 1

    # Return via stdout
    printf '%s' "${secret_value}"

    unset secret_value
}

