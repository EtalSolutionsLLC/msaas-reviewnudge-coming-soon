#!/usr/bin/env bash
set -euo pipefail

: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)}"

bootstrap_error() {
    # PM-LINT-MACHINE-OUTPUT: bootstrap diagnostic before logging exists.
    printf 'ERROR: pm-setup bootstrap: %s\n' "$*" >&2
    exit 2
}

resolve_setup_context() {
    local invocation_dir="${1:?invocation directory required}"
    local repo_root relative deploy_tail deploy_env active_dir

    command -v git >/dev/null 2>&1 \
        || bootstrap_error "git is required to locate the repository root"

    repo_root="$(git -C "$invocation_dir" rev-parse --show-toplevel 2>/dev/null)" \
        || bootstrap_error "not inside a Git repository: $invocation_dir"

    repo_root="$(cd -- "$repo_root" && pwd -P)"
    invocation_dir="$(cd -- "$invocation_dir" && pwd -P)"

    case "$invocation_dir" in
        "$repo_root")
            active_dir="$repo_root"
            deploy_env=""
            ;;
        "$repo_root"/deploy/*)
            relative="${invocation_dir#"$repo_root"/}"
            deploy_tail="${relative#deploy/}"
            deploy_env="${deploy_tail%%/*}"
            [[ -n "$deploy_env" ]] \
                || bootstrap_error "unable to resolve deployment environment from $invocation_dir"
            active_dir="$repo_root/deploy/$deploy_env"
            [[ -d "$active_dir" ]] \
                || bootstrap_error "deployment directory does not exist: $active_dir"
            ;;
        "$repo_root"/*)
            active_dir="$repo_root"
            deploy_env=""
            ;;
        *)
            bootstrap_error "resolved directory escapes repository root: $invocation_dir"
            ;;
    esac

    export PM_SETUP_INVOKED_FROM="$invocation_dir"
    export PORTMASON_PROJECT_ROOT="$repo_root"
    export SCRIPT_DIR="$active_dir"
    export MGT_SCRIPT_DIR=
    [[ -n "$deploy_env" ]] && export DEPLOY_ENV="$deploy_env"
    cd -- "$active_dir"
}

resolve_setup_context "$PWD"

if [[ "${1:-}" == "--bootstrap-context" ]]; then
    # PM-LINT-MACHINE-OUTPUT: stable bootstrap context protocol.
    printf 'PROJECT_ROOT=%s\n' "$PORTMASON_PROJECT_ROOT"
    # PM-LINT-MACHINE-OUTPUT: stable bootstrap context protocol.
    printf 'SCRIPT_DIR=%s\n' "$SCRIPT_DIR"
    # PM-LINT-MACHINE-OUTPUT: stable bootstrap context protocol.
    printf 'DEPLOY_ENV=%s\n' "${DEPLOY_ENV:-}"
    # PM-LINT-MACHINE-OUTPUT: stable bootstrap context protocol.
    printf 'PWD=%s\n' "$PWD"
    exit 0
fi

PM_SETUP_UPDATE_ARCHIVE="${PM_SETUP_UPDATE_ARCHIVE:-}"
PM_SETUP_UPDATE_SHA256="${PM_SETUP_UPDATE_SHA256:-}"
PM_SETUP_UPDATE_RECEIPT="${PM_SETUP_UPDATE_RECEIPT:-}"
PM_SETUP_UPDATE_STARTED_AT="${PM_SETUP_UPDATE_STARTED_AT:-}"
PM_SETUP_UPDATE_REENTERED="${PM_SETUP_UPDATE_REENTERED:-0}"
declare -a PM_SETUP_FORWARD_ARGS=()

pm_setup_resolve_update_archive() {
    local requested="${1:?archive path required}"
    local candidate=""

    if [[ "$requested" == /* ]]; then
        candidate="$requested"
    elif [[ -f "${PM_SETUP_INVOKED_FROM}/${requested}" ]]; then
        candidate="${PM_SETUP_INVOKED_FROM}/${requested}"
    else
        candidate="${PORTMASON_PROJECT_ROOT}/${requested}"
    fi

    [[ -f "$candidate" ]] \
        || bootstrap_error "update archive not found: $requested"
    realpath -- "$candidate"
}

pm_setup_prepare_update() {
    local requested="${1:?archive path required}"
    local archive_name receipt_dir

    command -v sha256sum >/dev/null 2>&1 \
        || bootstrap_error "sha256sum is required for --update"
    [[ -x "${PORTMASON_SHARE}/pm-extract-files-from-tar" ]] \
        || bootstrap_error "pm-extract-files-from-tar is unavailable or not executable"

    PM_SETUP_UPDATE_ARCHIVE="$(pm_setup_resolve_update_archive "$requested")"
    PM_SETUP_UPDATE_SHA256="$(sha256sum -- "$PM_SETUP_UPDATE_ARCHIVE" | awk '{print $1}')"
    PM_SETUP_UPDATE_STARTED_AT="$(date --utc +%Y-%m-%dT%H:%M:%SZ)"
    archive_name="$(basename -- "$PM_SETUP_UPDATE_ARCHIVE")"
    receipt_dir="${PORTMASON_PROJECT_ROOT}/.portmason/updates"
    mkdir --parents -- "$receipt_dir"
    PM_SETUP_UPDATE_RECEIPT="${receipt_dir}/${PM_SETUP_UPDATE_SHA256}.json"

    # Extraction is deliberately completed before configuration bootstrap so
    # every later phase reads the newly applied project state.
    (
        cd -- "$PORTMASON_PROJECT_ROOT"
        "${PORTMASON_SHARE}/pm-extract-files-from-tar" \
            "$PM_SETUP_UPDATE_ARCHIVE"
    )

    export PM_SETUP_UPDATE_ARCHIVE PM_SETUP_UPDATE_SHA256 \
        PM_SETUP_UPDATE_RECEIPT PM_SETUP_UPDATE_STARTED_AT
    # PM-LINT-MACHINE-OUTPUT: exact update receipt JSON written before normal logging exists.
    printf '{"archive":"%s","sha256":"%s","startedAt":"%s","result":"extracted"}\n' \
        "$archive_name" "$PM_SETUP_UPDATE_SHA256" "$PM_SETUP_UPDATE_STARTED_AT" \
        > "$PM_SETUP_UPDATE_RECEIPT"
}

pm_setup_parse_bootstrap_args() {
    local arg
    while (($#)); do
        arg="$1"
        shift
        case "$arg" in
            --update)
                (($#)) || bootstrap_error "--update requires an archive path"
                [[ -z "$PM_SETUP_UPDATE_ARCHIVE" ]] \
                    || bootstrap_error "--update may be specified only once"
                pm_setup_prepare_update "$1"
                shift
                ;;
            --update=*)
                [[ -z "$PM_SETUP_UPDATE_ARCHIVE" ]] \
                    || bootstrap_error "--update may be specified only once"
                [[ -n "${arg#--update=}" ]] \
                    || bootstrap_error "--update requires an archive path"
                pm_setup_prepare_update "${arg#--update=}"
                ;;
            *)
                PM_SETUP_FORWARD_ARGS+=("$arg")
                ;;
        esac
    done
}

pm_setup_parse_bootstrap_args "$@"
set -- "${PM_SETUP_FORWARD_ARGS[@]}"

# Reload the newly extracted entrypoint before configuration bootstrap. This
# guarantees that the remainder of the run uses the updated pm-setup and helper
# code while preserving the original project/deployment working context.
if [[ -n "${PM_SETUP_UPDATE_ARCHIVE:-}" ]]     && [[ "${PM_SETUP_UPDATE_REENTERED:-0}" != "1" ]]; then

    export PM_SETUP_UPDATE_REENTERED=1

    cd -- "${PM_SETUP_INVOKED_FROM}"
    exec "${PORTMASON_SHARE}/pm-setup" "$@"
fi

. "${PORTMASON_SHARE}/pm-helpers" "$@"
# pm-helpers normally loads this during bootstrap; source idempotently for direct tests.
. "${PORTMASON_SHARE}/pm-helpers-db"

pm_error_summary_reset
PM_SETUP_HANDLED_FAILURE=0

pm_setup_write_update_receipt() {
    local result="${1:?result required}"
    local rc="${2:-0}"
    local completed_at archive_name

    [[ -n "${PM_SETUP_UPDATE_RECEIPT:-}" ]] || return 0
    completed_at="$(date --utc +%Y-%m-%dT%H:%M:%SZ)"
    archive_name="$(basename -- "${PM_SETUP_UPDATE_ARCHIVE}")"

    # Exact update receipt JSON is an intentional printf exception.
    printf '{"archive":"%s","sha256":"%s","startedAt":"%s","completedAt":"%s","result":"%s","exitCode":%s}\n' \
        "$archive_name" "$PM_SETUP_UPDATE_SHA256" "$PM_SETUP_UPDATE_STARTED_AT" \
        "$completed_at" "$result" "$rc" > "$PM_SETUP_UPDATE_RECEIPT"
}

pm_setup_report_error() {
    local rc="${1:-$?}"
    local command="${2:-${BASH_COMMAND:-<unknown>}}"
    local source_file="${3:-${BASH_SOURCE[1]:-${BASH_SOURCE[0]:-pm-setup}}}"
    local source_line="${4:-${BASH_LINENO[0]:-${LINENO:-0}}}"
    local function_name="${5:-${FUNCNAME[1]:-main}}"

    trap - ERR

    if [[ "${PM_SETUP_HANDLED_FAILURE:-0}" != 1 ]]; then
        if declare -F log >/dev/null 2>&1; then
            log ERROR "unhandled command failure" \
                "rc=${rc}" \
                "source=${source_file}" \
                "line=${source_line}" \
                "function=${function_name}" \
                "command=${command}"
        else
            # PM-LINT-MACHINE-OUTPUT: bootstrap fallback when logging is unavailable.
            printf 'ERROR: pm-setup failure rc=%s source=%s line=%s function=%s command=%s\n' \
                "$rc" "$source_file" "$source_line" "$function_name" "$command" >&2
        fi
    fi

    if declare -F pm_error_summary_print >/dev/null 2>&1; then
        pm_error_summary_print
    fi
    pm_setup_write_update_receipt "failed" "$rc"
    exit "$rc"
}

set -E
trap 'pm_setup_report_error "$?" "$BASH_COMMAND" "${BASH_SOURCE[0]:-pm-setup}" "${LINENO:-0}" "${FUNCNAME[0]:-main}"' ERR

is_deploy_snapshot_dir() {
    [[ "$SCRIPT_DIR" == "$PROJECT_ROOT"/deploy/* ]] \
        && [[ "$(dirname -- "$SCRIPT_DIR")" == "$PROJECT_ROOT/deploy" ]]
}

pm_setup_refresh_runtime_selectors() {
    local code="${RUNTIME_ADAPTER_CODE:-}"
    if [[ ! "$code" =~ ^[a-z0-9][a-z0-9+]*-[a-z0-9][a-z0-9-]*$ ]]; then
        RUNTIME_CODE=""
        ADAPTER_CODE=""
        FRONT_END_CODE=""
        BACK_END_CODE=""
        export RUNTIME_CODE ADAPTER_CODE FRONT_END_CODE BACK_END_CODE
        log WARN "deferring invalid runtime selector to aggregate preflight" \
            "runtime_adapter=${code:-<unset>}"
        return 0
    fi

    RUNTIME_CODE="${code%%-*}"
    ADAPTER_CODE="${code##*-}"
    export RUNTIME_CODE ADAPTER_CODE

    if [[ "$RUNTIME_CODE" == *+* ]]; then
        FRONT_END_CODE="${RUNTIME_CODE%%+*}"
        BACK_END_CODE="${RUNTIME_CODE#*+}"
    else
        FRONT_END_CODE=""
        BACK_END_CODE=""
    fi
    export FRONT_END_CODE BACK_END_CODE

    log INFO "refreshed runtime selectors" \
        "runtime_adapter=$RUNTIME_ADAPTER_CODE" \
        "runtime=$RUNTIME_CODE" "adapter=$ADAPTER_CODE"

    # Bootstrap may have occurred before generated configuration was available.
    # Load the now-current helper and bridge layers without executing lifecycle work.
    load_bridge_runtime_adapter "$@"
    load_adapter_helper "$@"
    load_runtime_helper "$@"
}

pm_setup_refresh_generated_environment() {
    pm_load_generated_environment "pm-setup" force
    if declare -F ensure_public_host_identity >/dev/null 2>&1; then
        ensure_public_host_identity
    fi
    ensure_app_url
    pm_setup_refresh_runtime_selectors "$@"
    pm_db_refresh_selectors || true
    pm_db_call_optional pm_db_provider_prepare
}

pm_setup_source_module_once() {
    local module_name="${1:?module name required}"
    local requirement="${2:-optional}"
    shift 2
    local module_file=""

    [[ -z "${PM_DB_LOADED_MODULES[$module_name]+x}" ]] || return 0
    if declare -F pm_db_resolve_module >/dev/null 2>&1; then
        pm_db_resolve_module module_file "$module_name"
    elif [[ -r "${SCRIPT_DIR}/${module_name}" ]]; then
        module_file="${SCRIPT_DIR}/${module_name}"
    elif [[ -r "${PORTMASON_SHARE}/${module_name}" ]]; then
        module_file="${PORTMASON_SHARE}/${module_name}"
    fi
    if [[ -z "$module_file" ]]; then
        [[ "$requirement" == "required" ]] \
            && die "Required Portmason module not found: $module_name" 2
        log DEBUG "optional module not found" "module=$module_name"
        return 1
    fi

    log INFO "loading workflow module" \
        "module=$module_name" "path=$module_file"
    # shellcheck disable=SC1090
    . "$module_file" "$@"
    pm_db_mark_module_loaded "$module_name"
}

pm_setup_run_runtime_platform_provision() {
    local module="pm-provision-${ADAPTER_CODE}"
    log INFO "phase start" "phase=runtime-platform-provision" \
        "adapter=$ADAPTER_CODE"
    pm_setup_source_module_once "$module" optional "$@" || true
    if declare -F pm_provision_runtime_platform >/dev/null 2>&1; then
        pm_provision_runtime_platform "$@"
    else
        log DEBUG "runtime platform module used legacy source-time execution" \
            "module=$module"
    fi
    log INFO "phase complete" "phase=runtime-platform-provision"
}

pm_setup_run_runtime_platform_deploy() {
    local module="pm-deploy-${ADAPTER_CODE}"

    if [[ "${DB_PLATFORM_CODE:-}" != "${ADAPTER_CODE:-}" ]]; then
        unset -f pm_deploy_runtime_platform 2>/dev/null || true
        unset 'PM_DB_LOADED_MODULES[$module]' 2>/dev/null || true
    fi

    log INFO "phase start" "phase=runtime-platform-deploy" \
        "adapter=$ADAPTER_CODE"
    pm_setup_source_module_once "$module" optional "$@" || true
    if declare -F pm_deploy_runtime_platform >/dev/null 2>&1; then
        pm_deploy_runtime_platform "$@"
    else
        log DEBUG "runtime platform module used legacy source-time execution" \
            "module=$module"
    fi
    log INFO "phase complete" "phase=runtime-platform-deploy"
}

pm_setup_run_runtime_setup_modules() {
    local file
    file="${PORTMASON_SHARE}/pm-setup-${ADAPTER_CODE}"
    if [[ -r "$file" ]]; then
        log INFO "loading adapter setup module" "path=$file"
        . "$file" "$@"
    fi

    file="${PORTMASON_SHARE}/pm-setup-${RUNTIME_CODE}"
    if [[ -r "$file" ]]; then
        log INFO "loading runtime setup module" "path=$file"
        . "$file" "$@"
    fi
}

pm_setup_run_application_phase() {
    local hook_file runtime_file rc

    # Preserve the project application hook as an extensibility point, but do
    # not allow it to replace or short-circuit Portmason's normal deployment
    # lifecycle. A successful hook prepares the application; Portmason still
    # owns runtime loading, bridge deployment, and adapter deployment.
    hook_file="${MGT_SCRIPTS:-}/setup"
    if [[ -r "$hook_file" ]]; then
        log INFO "phase start"             "phase=project-application-setup"             "path=$hook_file"

        set +e
        . "$hook_file" "$@"
        rc=$?
        set -e

        case "$rc" in
            0)
                log INFO "phase complete"                     "phase=project-application-setup"                     "path=$hook_file"
                ;;
            1)
                die "Project setup returned a general error" "$rc"
                ;;
            2)
                die "Project setup reported command misuse" "$rc"
                ;;
            *)
                fatal_error "Project setup returned unexpected code $rc" "$rc"
                ;;
        esac
    fi

    runtime_file="${PORTMASON_SHARE}/pm-deploy-${RUNTIME_CODE}"
    if [[ -r "$runtime_file" ]]; then
        log INFO "loading runtime deployment module" "path=$runtime_file"
        . "$runtime_file" "$@"
    fi

    if declare -F pm_bridge_deploy >/dev/null 2>&1; then
        log INFO "phase start" "phase=runtime-bridge-deploy"
        pm_bridge_deploy "$@"
        log INFO "phase complete" "phase=runtime-bridge-deploy"
    else
        pm_setup_run_runtime_platform_deploy "$@"
    fi
}

pm_setup_log_completion() {
    log INFO "workflow complete" \
        "deploy_env=${DEPLOY_ENV:-prd}" "stack=${STACK:-<unset>}"

    # Preserve the long-standing operator-facing completion contract: the final
    # pm-setup log entry identifies the canonical application URL. Resolve it
    # again here because runtime/platform modules may establish APP_HOST or an
    # application-specific URL alias late in the workflow.
    ensure_app_url
    if [[ -n "${APP_URL:-}" ]]; then
        log INFO "application ready" "APP_URL=${APP_URL}"
    else
        warn "application URL unavailable" "APP_URL=<unset>"
    fi
}

main() {
    export PROJECT_SERVICES=""

    local deploy_sync_active=0 deploy_sync_force=0 sync_owner_host="" sync_rc=0
    local database_enabled=0
    local -a sync_args=(--prepare)

    case "${PM_DEPLOY_SYNC_FORCE:-}" in
        1|true|TRUE|yes|YES|on|ON) deploy_sync_force=1 ;;
    esac

    local setup_arg
    for setup_arg in "$@"; do
        case "$setup_arg" in
            --refresh-from-root|--force-deploy-sync)
                deploy_sync_force=1
                ;;
        esac
    done

    log INFO "workflow start" \
        "project_root=$PROJECT_ROOT" "script_dir=$SCRIPT_DIR" \
        "deploy_env=${DEPLOY_ENV:-prd}" \
        "runtime_adapter=${RUNTIME_ADAPTER_CODE:-<unset>}" \
        "db_provider_platform=${DB_PROVIDER_PLATFORM_CODE:-${DB_PROVIDER_CODE:-<unset>}}"

    if is_deploy_snapshot_dir; then
        sync_owner_host="$(hostname 2>/dev/null || printf unknown)"
        if [[ "$deploy_sync_force" -eq 1 ]]; then
            sync_args+=(--force)
            log INFO "explicit deploy refresh requested"
        fi
        if PM_DEPLOY_SYNC_OWNER_PID="$$" \
            PM_DEPLOY_SYNC_OWNER_HOST="$sync_owner_host" \
                "${PORTMASON_SHARE}/pm-sync-deploy-from-root" "${sync_args[@]}"; then
            deploy_sync_active=1
        else
            sync_rc=$?
            case "$sync_rc" in
                3)
                    # Drift protects the environment snapshot from automatic
                    # copy-forward, but it must not prevent routine pm-setup
                    # maintenance from running against the existing snapshot.
                    # No in-progress marker exists, so finalization is skipped
                    # and the same drift is reported again on the next run.
                    log WARN "deploy drift detected; automatic root refresh skipped" \
                        "deploy_env=${DEPLOY_ENV:-<unset>}" \
                        "action=continue-existing-snapshot" \
                        "override=--refresh-from-root"
                    deploy_sync_active=0
                    ;;
                *)
                    fatal_error "pm-sync-deploy-from-root failed with exit code $sync_rc" "$sync_rc"
                    ;;
            esac
        fi
    elif [[ "$deploy_sync_force" -eq 1 ]]; then
        die "--refresh-from-root is only valid from deploy/<env>" 2
    fi

    log INFO "phase start" "phase=configuration-generation" \
        "env_file=${ENV_FILE:-<unset>}"
    if "${PORTMASON_SHARE}/pm-generate-config"; then
        log INFO "phase complete" "phase=configuration-generation"
    else
        local rc=$?
        fatal_error "pm-generate-config failed with exit code $rc" "$rc"
    fi

    # Local Compose models may reference generated service env files. Create
    # non-destructive placeholders before loading the local adapter helper,
    # because that helper inspects the Compose model during selector refresh.
    if declare -F pm_config_manager_bootstrap_local_env_files >/dev/null 2>&1; then
        pm_config_manager_bootstrap_local_env_files
    fi
    pm_setup_refresh_generated_environment
    if declare -F pm_config_manager_bootstrap_local_env_files >/dev/null 2>&1; then
        pm_config_manager_bootstrap_local_env_files
    fi

    if pm_db_has_configuration; then
        database_enabled=1
    fi

    # Full aggregate validation, including module availability, occurs before
    # any infrastructure-changing action. Required modules are promoted from
    # optional preflight loads only after the complete report passes.
    if ! pm_db_preflight; then
        PM_SETUP_HANDLED_FAILURE=1
        pm_error_summary_print
        return 2
    fi
    
    if [[ "$database_enabled" -eq 1 ]]; then
        pm_db_load_helpers required
    fi

    log INFO "staging Portmason runtime"
    stage_portmason "archive" "cagent" "*cosign*" "*log"

    pm_setup_run_runtime_platform_provision "$@"

    if [[ "$database_enabled" -eq 1 ]]; then
        log INFO "phase start" "phase=database-provision"
        pm_db_run_provision "$@"
        log INFO "phase complete" "phase=database-provision"
    fi

    # Apply scoped configuration after provisioners have produced derived values,
    # but before runtime setup can start or recreate services that consume them.
    if declare -F pm_config_manager_apply >/dev/null 2>&1; then
        log INFO "phase start" "phase=configuration"
        pm_config_manager_apply
        log INFO "phase complete" "phase=configuration"
    else
        log DEBUG "PM Configuration Manager is unavailable in this minimal runtime; configuration phase skipped"
    fi

    pm_setup_run_runtime_setup_modules "$@"

    if [[ "$database_enabled" -eq 1 ]]; then
        log INFO "phase start" "phase=database-deploy"
        pm_db_run_deploy "$@"
        log INFO "phase complete" "phase=database-deploy"
    fi

    pm_setup_run_application_phase "$@"

    if [[ "$deploy_sync_active" -eq 1 ]]; then
        PM_DEPLOY_SYNC_OWNER_PID="$$" \
        PM_DEPLOY_SYNC_OWNER_HOST="$sync_owner_host" \
            "${PORTMASON_SHARE}/pm-sync-deploy-from-root" --finalize
    fi

    pm_setup_log_completion
    pm_setup_write_update_receipt "deployed" 0
}

pm_setup_arg REFRESH_FROM_ROOT "--refresh-from-root" export
pm_setup_arg FORCE_DEPLOY_SYNC "--force-deploy-sync" export
pm_commit_args "$@"

main "$@"
pm_error_summary_print
