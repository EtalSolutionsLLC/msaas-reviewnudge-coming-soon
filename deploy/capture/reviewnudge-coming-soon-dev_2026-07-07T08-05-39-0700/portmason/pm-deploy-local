#!/usr/bin/env bash
set -euo pipefail

: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]:-${0:-}}")}" 
export CUR_SCRIPT
: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)}"
if ! declare -F log >/dev/null 2>&1; then
    . "${PORTMASON_SHARE}/pm-helpers" "$@"
fi

pm_local_wait_for_db() {
    local service="${PM_DB_SERVICE:-$(pm_compose_service_for_role db)}"
    local attempt max_attempts="${DATABASE_STARTUP_ATTEMPTS:-30}"
    local delay_ms="${DATABASE_STARTUP_DELAY_MS:-1000}"
    local delay_seconds
    delay_seconds="$(awk -v ms="$delay_ms" 'BEGIN { printf "%.3f", ms / 1000 }')"

    for attempt in $(seq 1 "$max_attempts"); do
        if PGPASSWORD="${DB_PASSWORD}" "${PM_COMPOSE_CMD[@]}" exec -T \
            -e PGPASSWORD \
            "$service" \
            pg_isready --username "$DB_USER" --dbname "$DB_NAME" >/dev/null 2>&1; then
            log INFO "database service is ready" \
                "service=$service" "attempt=$attempt"
            return 0
        fi
        log DEBUG "waiting for database readiness" \
            "service=$service" "attempt=$attempt/$max_attempts"
        sleep "$delay_seconds"
    done

    "${PM_COMPOSE_CMD[@]}" logs --tail=100 "$service" >&2 || true
    die "Local database service did not become ready: $service" 2
}

pm_deploy_db_platform() {
    [[ "${DB_PLATFORM:-}" == "local" ]] \
        || die "pm-deploy-local database entrypoint requires DB_PLATFORM=local" 2

    pm_compose_load_model
    local service
    service="$(pm_compose_service_for_role db)"
    [[ -n "$service" ]] || die "no Compose db service was found" 2
    env_init_set PM_DB_SERVICE "$service"

    [[ ${#PM_COMPOSE_CMD[@]} -gt 0 ]] || pm_compose_init_command
    log INFO "starting database service" "service=$service"
    "${PM_COMPOSE_CMD[@]}" up -d --remove-orphans "$service"
    pm_local_wait_for_db
    log INFO "database platform deployment complete" \
        "service=$service"
}

pm_deploy_runtime_platform() {
    [[ "${ADAPTER_CODE:-}" == "local" ]] \
        || die "pm-deploy-local runtime entrypoint requires ADAPTER_CODE=local" 2

    pm_compose_load_model
    [[ ${#PM_COMPOSE_CMD[@]} -gt 0 ]] || pm_compose_init_command

    log INFO "starting project containers" \
        "services=$(jq -r 'map(.service) | join(",")' <<<"${PROJECT_SERVICES:-[]}")"
    "${PM_COMPOSE_CMD[@]}" up -d --build --remove-orphans

    if [[ -n "${APP_URL:-}" ]]; then
        log INFO "runtime deployment complete" "app_url=$APP_URL"
    else
        warn "runtime is up, but APP_URL is unavailable"
    fi
}

main() {
    pm_deploy_runtime_platform "$@"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
