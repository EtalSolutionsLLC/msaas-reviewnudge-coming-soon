#!/usr/bin/env bash
set -euo pipefail

: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]}")}"
export CUR_SCRIPT
: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"}"
# shellcheck source=/dev/null
. "${PORTMASON_SHARE}/pm-helpers"

# # Testing-only: override live tail so it dies on exit/signals.
# if [[ -r "${PORTMASON_SHARE}/pm-helpers-live-tail" ]]; then
#   # shellcheck source=/dev/null
#   . "${PORTMASON_SHARE}/pm-helpers-live-tail"
# fi

: "${HOST_ARTIFACT_DIR:=./_artifacts}"
: "${CONTAINER_ARTIFACT_DIR:=/artifacts}"
: "${ARTIFACT_NAME:=runtime.tgz}"
: "${HOST_ARTIFACT_PATH:=${HOST_ARTIFACT_DIR}/${ARTIFACT_NAME}}"

fetch_runtime_artifact() {
    # ENV_FILE="${ENV_FILE:-.env}"
    out_path="${HOST_ARTIFACT_DIR}/${ARTIFACT_NAME}"
    : "${RUNTIME_ARTIFACT:="${out_path}"}"
    export RUNTIME_ARTIFACT

    # # Load env
    # if [[ -f "$ENV_FILE" ]]; then
    #   # shellcheck disable=SC1090
    #   set -a
    #   source "$ENV_FILE"
    #   set +a
    # else
    #   die "ENV_FILE not found: $ENV_FILE"
    # fi

    : "${RUNTIME_ARTIFACT:?RUNTIME_ARTIFACT is required (gs://..., https://..., or absolute path)}"

    mkdir -p "$HOST_ARTIFACT_DIR"

    #
    # TURNS OUT WE NEED TO GET THE ARTIFACT EVERYTIME TO PREVENT CACHING ISSUES
    #
    # need_fetch=0
    # if [[ "${FORCE_FETCH:-0}" == "1" ]]; then
    #   need_fetch=1
    # elif [[ ! -f "$out_path" ]]; then
    #   need_fetch=1
    # fi

    # if [[ "$need_fetch" == "0" ]]; then
    #   log INFO "Artifact already present; skipping fetch" "path=$out_path"
    # else
    log INFO "Fetching runtime artifact" "src=$RUNTIME_ARTIFACT" "dst=$out_path"

    if [[ "$RUNTIME_ARTIFACT" == gs://* ]]; then
        command -v gcloud >/dev/null 2>&1 || die "gcloud is required to fetch: $RUNTIME_ARTIFACT"
        gcloud storage cp "$RUNTIME_ARTIFACT" "$out_path" >/dev/null
    elif [[ "$RUNTIME_ARTIFACT" == http://* || "$RUNTIME_ARTIFACT" == https://* ]]; then
        command -v curl >/dev/null 2>&1 || die "curl is required to fetch: $RUNTIME_ARTIFACT"
        curl -fsSL "$RUNTIME_ARTIFACT" -o "$out_path"
    else
        [[ "$RUNTIME_ARTIFACT" == /* ]] || die "Local artifact paths must be absolute: $RUNTIME_ARTIFACT"
        [[ -f "$RUNTIME_ARTIFACT" ]] || die "Artifact not found: $RUNTIME_ARTIFACT"
        cp -f "$RUNTIME_ARTIFACT" "$out_path"
    fi
    #fi

    # Integrity + info
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$out_path" | awk '{print $1}' > "${out_path}.sha256"
        sha="$(cat "${out_path}.sha256" 2>/dev/null || true)"
    else
        sha=""
    fi

    if command -v stat >/dev/null 2>&1; then
        size="$(stat -c '%s' "$out_path" 2>/dev/null || stat -f '%z' "$out_path" 2>/dev/null || echo "")"
    else
        size=""
    fi

    log INFO "Artifact ready" "path=$(pwd -P)/${out_path#./}" "sha256=${sha:-unknown}" "bytes=${size:-unknown}"
}

main(){
    # Ensure artifact exists (repeatable)
    fetch_runtime_artifact

    [[ -f "$HOST_ARTIFACT_PATH" ]] || die "Expected artifact missing after fetch: $HOST_ARTIFACT_PATH"

    abs_art_dir="$(cd "$HOST_ARTIFACT_DIR" && pwd -P)"
    emu_tmp_size="${EMU_TMP_SIZE:-512m}"

    # Extra env injection (optional)
    extra_env_args=()
    if [[ -n "${EMU_EXTRA_ENV:-}" ]]; then
    # shellcheck disable=SC2206
    tokens=( ${EMU_EXTRA_ENV} )
    for t in "${tokens[@]}"; do
        extra_env_args+=( -e "$t" )
    done
    fi

    # Extra docker args (optional)
    extra_docker_args=()
    if [[ -n "${EMU_EXTRA_DOCKER_ARGS:-}" ]]; then
        # shellcheck disable=SC2206
        extra_docker_args=( ${EMU_EXTRA_DOCKER_ARGS} )
    fi

    # Prefer Cloud Run-ish logging behavior (stdout/stderr)
    export PM_NO_REDIRECT="${PM_NO_REDIRECT:-1}"

    # Override RUNTIME_ARTIFACT directly so container never touches gs:// and never calls gcloud.
    export CONTAINER_ARGS="\
        -v ${abs_art_dir}:${CONTAINER_ARTIFACT_DIR}:ro \
        --tmpfs /tmp:rw,exec,nosuid,nodev,mode=1777,size=${emu_tmp_size} \
        -e HOME=/tmp \
        -e RUNTIME_ARTIFACT=${CONTAINER_ARTIFACT_DIR}/${ARTIFACT_NAME} \
        ${extra_env_args[*]} \
        ${extra_docker_args[*]} \
        "

    log INFO "Starting Cloud Run emulation" \
        "artifact_host=${HOST_ARTIFACT_PATH}" \
        "artifact_in_container=${CONTAINER_ARTIFACT_DIR}/${ARTIFACT_NAME}" \
        "tmpfs=/tmp:${emu_tmp_size}" \
        "pm=$(command -v $PORTMASON_SHARE/pm-emulate-cloudrun || echo $PORTMASON_SHARE/pm-emulate-cloudrun)"

    . "$PORTMASON_SHARE/pm-emulate-cloudrun"
}

main  "$@"
