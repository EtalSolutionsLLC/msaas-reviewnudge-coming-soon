#!/usr/bin/env bash
set -euo pipefail

PORTMASON_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
TMP_ROOT="$(mktemp -d)"
trap 'rm -rf "${TMP_ROOT}"' EXIT

pass_count=0

fail() {
    printf 'FAIL: %s\n' "$*" >&2
    exit 1
}

assert_equal() {
    local expected="${1:?expected value required}"
    local actual="${2-}"
    local label="${3:?label required}"

    if [[ "${actual}" != "${expected}" ]]; then
        fail "${label}: expected '${expected}', got '${actual}'"
    fi

    pass_count=$((pass_count + 1))
    printf 'PASS: %s\n' "${label}"
}

new_project() {
    local name="${1:?name required}"
    local project="${TMP_ROOT}/${name}"

    mkdir -p "${project}"
    cat > "${project}/docker-compose.yml" <<'YAML'
services:
  web:
    image: scratch
YAML

    printf '%s\n' "${project}"
}

read_canonical_url() {
    local project="${1:?project required}"

    (
        cd "${project}"
        PM_NO_REDIRECT=1 \
        LIVE_TAIL=0 \
        LOG_LEVEL=ERROR \
        PORTMASON_SHARE="${PORTMASON_ROOT}" \
            bash -c '
                set -euo pipefail
                . "${PORTMASON_SHARE}/pm-helpers" >/dev/null 2>&1
                printf "%s" "${APP_URL:-}"
            '
    )
}

write_common_env() {
    local project="${1:?project required}"

    cat > "${project}/.env" <<'ENV'
APP_SLUG=reviewnudge
DEPLOY_ENV=dev
RUNTIME_ADAPTER_CODE=node-local
PROJECT_ID=reviewnudge-dev-1234567890
DEPLOYMENT_ID=reviewnudge-dev-1234567890
ENV
}

project="$(new_project app-base-url)"
write_common_env "${project}"
cat >> "${project}/.env" <<'ENV'
APP_BASE_URL=http://reviewnudge-dev.localtest.me
ENV
assert_equal \
    "http://reviewnudge-dev.localtest.me" \
    "$(read_canonical_url "${project}")" \
    "APP_BASE_URL becomes canonical APP_URL"

project="$(new_project app-host-scheme)"
write_common_env "${project}"
cat >> "${project}/.env" <<'ENV'
APP_HOST=reviewnudge-dev.localtest.me
URI_SCHEME=https:
ENV
assert_equal \
    "https://reviewnudge-dev.localtest.me" \
    "$(read_canonical_url "${project}")" \
    "APP_HOST uses normalized URI_SCHEME"

project="$(new_project app-host-tls)"
write_common_env "${project}"
cat >> "${project}/.env" <<'ENV'
APP_HOST=reviewnudge-dev.localtest.me
TRAEFIK_TLS=true
ENV
assert_equal \
    "https://reviewnudge-dev.localtest.me" \
    "$(read_canonical_url "${project}")" \
    "APP_HOST uses HTTPS when Traefik TLS is enabled"

project="$(new_project explicit-app-url)"
write_common_env "${project}"
cat >> "${project}/.env" <<'ENV'
APP_URL=https://preferred.example.test/
APP_BASE_URL=http://ignored.example.test
SITE_URL=http://also-ignored.example.test
ENV
assert_equal \
    "https://preferred.example.test" \
    "$(read_canonical_url "${project}")" \
    "explicit APP_URL wins and root trailing slash is normalized"

project="$(new_project deploy-output)"
write_common_env "${project}"
cat >> "${project}/.env" <<'ENV'
APP_BASE_URL=http://reviewnudge-dev.localtest.me
ENV
mkdir -p "${project}/fakebin"
cat > "${project}/fakebin/docker" <<'SH'
#!/usr/bin/env bash
set -euo pipefail
exit 0
SH
chmod +x "${project}/fakebin/docker"

deploy_output="$({
    cd "${project}"
    PM_NO_REDIRECT=1 \
    LIVE_TAIL=0 \
    LOG_LEVEL=INFO \
    PATH="${project}/fakebin:${PATH}" \
    PORTMASON_SHARE="${PORTMASON_ROOT}" \
        "${PORTMASON_ROOT}/pm-deploy-local"
} 2>&1)"

if ! grep -Fq \
    'Up. APP_URL: http://reviewnudge-dev.localtest.me' \
    <<<"${deploy_output}"
then
    printf '%s\n' "${deploy_output}" >&2
    fail "pm-deploy-local did not report the canonical APP_URL"
fi
pass_count=$((pass_count + 1))
printf 'PASS: %s\n' "pm-deploy-local reports canonical APP_URL"

printf 'All %d APP_URL tests passed.\n' "${pass_count}"
