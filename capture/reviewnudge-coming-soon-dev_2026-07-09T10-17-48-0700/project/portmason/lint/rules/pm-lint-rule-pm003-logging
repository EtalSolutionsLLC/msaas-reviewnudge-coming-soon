#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm003() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local base="${path##*/}"
    local record line_no line

    pm_lint_is_shell_file "$file" || return 0
    [[ "$base" == pm-* ]] || return 0
    case "$path" in */tests/*) return 0 ;; esac

    while IFS= read -r record; do
        line_no="${record%%:*}"
        line="${record#*:}"
        [[ "$line" == *PM-LINT-MACHINE-OUTPUT* ]] && continue
        if (( line_no > 1 )) && sed -n "$((line_no - 1))p" "$file" | grep -q 'PM-LINT-MACHINE-OUTPUT'; then
            continue
        fi
        [[ "$line" =~ printf[[:space:]]+-v ]] && continue
        [[ "$line" == *"\\0"* ]] && continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        pm_lint_report PM003 "$path" "$line_no" \
            "Direct echo/printf output bypasses Portmason logging conventions" \
            "Use log, warn, die, ok, or fatal_error. Mark narrowly justified machine output with PM-LINT-MACHINE-OUTPUT."
    done < <(grep -nE '^[[:space:]]*(echo|printf)([[:space:]]|$)' "$file" 2>/dev/null || true)
}

pm_lint_register_rule PM003 WARNING file \
    "Portmason logging discipline" \
    "TGF Shell / Channel Discipline; Portmason conventions" \
    pm_lint_rule_pm003
