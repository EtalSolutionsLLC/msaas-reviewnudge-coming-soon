#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm012() {
    local root="${1:?root required}"
    local compose service start_line end_line block role=""
    local has_http=false

    while IFS= read -r -d '' compose; do
        while IFS=$'\t' read -r service start_line end_line; do
            [[ -n "$service" ]] || continue
            block="$(pm_lint_compose_service_block "$compose" "$start_line" "$end_line")"
            role=""
            pm_lint_compose_block_label_value role "$block" solutions.etal.service
            case "$role" in
                api|web) has_http=true ;;
            esac
        done < <(pm_lint_compose_services_tsv "$compose")
    done < <(find "$root" -type f \( -name 'docker-compose*.yml' -o -name 'docker-compose*.yaml' -o -name 'compose*.yml' -o -name 'compose*.yaml' \) -print0 2>/dev/null)

    [[ "$has_http" == true ]] || return 0
    if ! grep -Rqs --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=vendor -- '/healthz' "$root"; then
        pm_lint_report PM012 "." 1 \
            "HTTP service detected but no /healthz contract evidence was found" \
            "Implement deterministic liveness and bind the adapter healthcheck to /healthz."
    fi
    if ! grep -Rqs --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=vendor -- '/readyz' "$root"; then
        pm_lint_report PM012 "." 1 \
            "HTTP service detected but no /readyz contract evidence was found" \
            "Implement readiness separately from liveness and validate critical dependencies."
    fi
}

pm_lint_register_rule PM012 WARNING project \
    "Health and readiness evidence" \
    "EPC A2.9" \
    pm_lint_rule_pm012
