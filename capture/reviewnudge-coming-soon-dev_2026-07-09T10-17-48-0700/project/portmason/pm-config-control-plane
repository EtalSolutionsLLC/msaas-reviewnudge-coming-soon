#!/usr/bin/env bash
set -euo pipefail
pm_config_control_plane() {
    pm_config_register DB_API_KEY control-plane '' DB_API_KEY optional
    pm_config_register RUNTIME_API_KEY control-plane '' RUNTIME_API_KEY optional
    pm_config_register DNS_API_KEY control-plane '' DNS_API_KEY optional
    pm_config_register STORAGE_API_KEY control-plane '' STORAGE_API_KEY optional
    pm_config_register EMAIL_API_KEY control-plane '' EMAIL_API_KEY optional
    pm_config_register BILLING_API_KEY control-plane '' BILLING_API_KEY optional
}
