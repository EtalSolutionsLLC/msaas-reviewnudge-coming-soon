#!/usr/bin/env bash
set -euo pipefail

: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)}"
# shellcheck disable=SC1091
. "${PORTMASON_SHARE}/pm-helpers" --minimal

WORKSPACE_ROOT="${PM_NUDGE_WORKSPACE_ROOT:-${HOME}/code}"
APPLY_MIGRATIONS=1
DEPLOY_COMING_SOON=1
CHECK_ENDPOINTS=1
DRY_RUN=0
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)"

usage() {
    cat <<'USAGE'
Usage: pm-launch-reviewnudge [options]

Options:
  --workspace PATH       Workspace containing the three repositories.
  --skip-migrations      Do not re-extract local Build 089 migration archives.
  --skip-coming-soon     Deploy Traefik and ReviewNudge only.
  --skip-endpoints       Skip HTTP health endpoint verification.
  --dry-run              Print the execution sequence without changing anything.
  -h, --help             Show this help.

Optional path overrides:
  PM_TRAEFIK_DIR
  PM_REVIEWNUDGE_COMING_SOON_DIR
  PM_REVIEWNUDGE_DIR
USAGE
}

while (($# > 0)); do
    case "$1" in
        --workspace)
            [[ $# -ge 2 ]] || die "--workspace requires a path" 2
            WORKSPACE_ROOT="$2"
            shift 2
            ;;
        --skip-migrations)
            APPLY_MIGRATIONS=0
            shift
            ;;
        --skip-coming-soon)
            DEPLOY_COMING_SOON=0
            shift
            ;;
        --skip-endpoints)
            CHECK_ENDPOINTS=0
            shift
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "unknown option: $1" 2
            ;;
    esac
done

run_cmd() {
    if ((DRY_RUN)); then
        log INFO "DRY RUN" "command=$(printf '%q ' "$@")"
        return 0
    fi
    "$@"
}

run_in_project() {
    local project_dir="${1:?project directory required}"
    shift
    if ((DRY_RUN)); then
        log INFO "DRY RUN" "cwd=$project_dir" "command=$(printf '%q ' "$@")"
        return 0
    fi
    (
        cd -- "$project_dir"
        "$@"
    )
}

read_app_slug() {
    local env_file="${1:?environment file required}"
    awk -F= '
        $1 == "APP_SLUG" {
            value=$0
            sub(/^[^=]*=/, "", value)
            gsub(/^[[:space:]\047\"]+|[[:space:]\047\"]+$/, "", value)
            print value
            exit
        }
    ' "$env_file"
}

resolve_project() {
    local out_var="${1:?output variable required}"
    local explicit="${2:-}"
    local slug="${3:?application slug required}"
    shift 3
    local candidate env_slug found=""

    if [[ -n "$explicit" ]]; then
        [[ -d "$explicit" ]] || die "configured project directory does not exist: $explicit" 2
        found="$(cd -- "$explicit" && pwd -P)"
    else
        for candidate in "$@"; do
            [[ -d "$candidate" && -r "$candidate/.env" ]] || continue
            env_slug="$(read_app_slug "$candidate/.env")"
            if [[ "$env_slug" == "$slug" ]]; then
                found="$(cd -- "$candidate" && pwd -P)"
                break
            fi
        done
    fi

    if [[ -z "$found" ]]; then
        while IFS= read -r candidate; do
            env_slug="$(read_app_slug "$candidate/.env")"
            if [[ "$env_slug" == "$slug" ]]; then
                found="$(cd -- "$candidate" && pwd -P)"
                break
            fi
        done < <(find "$WORKSPACE_ROOT" -mindepth 1 -maxdepth 2 -type f -name .env -printf '%h\n' 2>/dev/null | sort -u)
    fi

    [[ -n "$found" ]] || die "could not locate project with APP_SLUG=$slug beneath $WORKSPACE_ROOT" 2
    printf -v "$out_var" '%s' "$found"
}

backup_project_files() {
    local project_dir="${1:?project directory required}"
    local backup_dir="$project_dir/.portmason/backups/launch-$RUN_ID"
    local relative
    local -a files=(
        .env
        .env.generated
        docker-compose.yml
        docker-compose.override.yml
        .gitignore
        pm-config-project
        nginx/default.conf
    )

    if ((DRY_RUN)); then
        log INFO "DRY RUN" "backup=$backup_dir"
        return 0
    fi

    mkdir -p -- "$backup_dir"
    chmod 700 "$backup_dir"
    for relative in "${files[@]}"; do
        [[ -e "$project_dir/$relative" ]] || continue
        mkdir -p -- "$backup_dir/$(dirname -- "$relative")"
        cp -a -- "$project_dir/$relative" "$backup_dir/$relative"
    done
    log INFO "project backup complete" "project=$project_dir" "backup=$backup_dir"
}

apply_migration_if_present() {
    local project_dir="${1:?project directory required}"
    local archive_name="${2:?migration archive required}"
    local archive="$project_dir/$archive_name"

    ((APPLY_MIGRATIONS)) || return 0
    if [[ ! -f "$archive" ]]; then
        log WARN "migration archive not present; continuing with current project files" \
            "project=$project_dir" "archive=$archive_name"
        return 0
    fi

    log INFO "applying project migration" "project=$project_dir" "archive=$archive_name"
    run_in_project "$project_dir" pm-extract-files-from-tar "$archive_name"
}

ensure_proxy_network() {
    if ((DRY_RUN)); then
        log INFO "DRY RUN" "command=docker network inspect proxy || docker network create proxy"
        return 0
    fi
    if ! docker network inspect proxy >/dev/null 2>&1; then
        docker network create proxy >/dev/null
        log INFO "created shared Docker network" "network=proxy"
    else
        log INFO "shared Docker network ready" "network=proxy"
    fi
}

service_state() {
    local project_dir="${1:?project directory required}"
    local service="${2:?service required}"
    local cid
    cid="$(cd -- "$project_dir" && docker compose ps -q "$service")"
    [[ -n "$cid" ]] || return 1
    docker inspect --format '{{.State.Status}}|{{if .State.Health}}{{.State.Health.Status}}{{end}}' "$cid"
}

wait_for_service() {
    local project_dir="${1:?project directory required}"
    local service="${2:?service required}"
    local attempt state status health

    ((DRY_RUN)) && return 0

    for attempt in $(seq 1 60); do
        state="$(service_state "$project_dir" "$service" 2>/dev/null || true)"
        status="${state%%|*}"
        health="${state#*|}"
        if [[ "$status" == running && ( -z "$health" || "$health" == healthy ) ]]; then
            log INFO "service ready" "project=$project_dir" "service=$service" \
                "status=$status" "health=${health:-not-defined}"
            return 0
        fi
        if [[ "$status" == exited || "$status" == dead ]]; then
            break
        fi
        sleep 2
    done

    log ERROR "service did not become ready" "project=$project_dir" \
        "service=$service" "state=${state:-missing}"
    return 1
}

read_generated_value() {
    local project_dir="${1:?project directory required}"
    local key="${2:?key required}"
    local file="$project_dir/.env.generated"
    local value=""

    [[ -r "$file" ]] || return 1
    value="$(awk -F= -v wanted="$key" '
        $1 == wanted {
            sub(/^[^=]*=/, "")
            print
        }
    ' "$file" | tail -n 1)"
    value="${value#\'}"
    value="${value%\'}"
    value="${value#\"}"
    value="${value%\"}"
    [[ -n "$value" ]] || return 1
    printf '%s' "$value"
}

check_health_endpoint() {
    local project_dir="${1:?project directory required}"
    local host=""

    ((CHECK_ENDPOINTS)) || return 0
    ((DRY_RUN)) && return 0
    command -v curl >/dev/null 2>&1 || {
        log WARN "curl unavailable; endpoint verification skipped" "project=$project_dir"
        return 0
    }

    host="$(read_generated_value "$project_dir" APP_HOST 2>/dev/null || true)"
    [[ -n "$host" ]] || {
        log WARN "APP_HOST unavailable; endpoint verification skipped" "project=$project_dir"
        return 0
    }

    if curl --insecure --fail --silent --show-error \
        --retry 10 --retry-delay 1 --retry-connrefused \
        "https://${host}/healthz" >/dev/null; then
        log INFO "health endpoint passed" "url=https://${host}/healthz"
    else
        log ERROR "health endpoint failed" "url=https://${host}/healthz"
        return 1
    fi
}

show_failure_context() {
    local project_dir="${1:?project directory required}"
    ((DRY_RUN)) && return 0
    (
        cd -- "$project_dir"
        docker compose ps || true
        docker compose logs --no-color --tail=120 || true
    ) >&2
}

deploy_project() {
    local name="${1:?project name required}"
    local project_dir="${2:?project directory required}"
    local archive_name="${3:?archive name required}"
    shift 3
    local -a services=("$@")
    local service

    log INFO "deployment start" "project=$name" "directory=$project_dir"
    backup_project_files "$project_dir"
    apply_migration_if_present "$project_dir" "$archive_name"

    if ! run_in_project "$project_dir" pm-setup; then
        log ERROR "pm-setup failed" "project=$name"
        show_failure_context "$project_dir"
        return 1
    fi
    if ! run_in_project "$project_dir" docker compose config --quiet; then
        log ERROR "Compose validation failed" "project=$name"
        show_failure_context "$project_dir"
        return 1
    fi
    if ! run_in_project "$project_dir" docker compose up -d --build --remove-orphans; then
        log ERROR "Compose deployment failed" "project=$name"
        show_failure_context "$project_dir"
        return 1
    fi

    for service in "${services[@]}"; do
        if ! wait_for_service "$project_dir" "$service"; then
            show_failure_context "$project_dir"
            return 1
        fi
    done

    run_in_project "$project_dir" docker compose ps
    if [[ "$name" != traefik ]]; then
        check_health_endpoint "$project_dir"
    fi
    log INFO "deployment complete" "project=$name"
}

main() {
    local traefik_dir coming_dir reviewnudge_dir

    command -v git >/dev/null 2>&1 || die "required command not found: git" 2
    if (( ! DRY_RUN )); then
        for command in docker pm-setup pm-extract-files-from-tar; do
            command -v "$command" >/dev/null 2>&1 || die "required command not found: $command" 2
        done
    fi
    [[ -d "$WORKSPACE_ROOT" ]] || die "workspace does not exist: $WORKSPACE_ROOT" 2
    WORKSPACE_ROOT="$(cd -- "$WORKSPACE_ROOT" && pwd -P)"

    resolve_project traefik_dir "${PM_TRAEFIK_DIR:-}" traefik \
        "$WORKSPACE_ROOT/traefik"
    resolve_project coming_dir "${PM_REVIEWNUDGE_COMING_SOON_DIR:-}" reviewnudge-coming-soon \
        "$WORKSPACE_ROOT/msaas-reviewnudge-coming-soon" \
        "$WORKSPACE_ROOT/reviewnudge-coming-soon"
    resolve_project reviewnudge_dir "${PM_REVIEWNUDGE_DIR:-}" reviewnudge \
        "$WORKSPACE_ROOT/msaas-reviewnudge" \
        "$WORKSPACE_ROOT/reviewnudge"

    log INFO "Nudge launch plan" \
        "traefik=$traefik_dir" \
        "coming_soon=$coming_dir" \
        "reviewnudge=$reviewnudge_dir" \
        "apply_migrations=$APPLY_MIGRATIONS"

    ensure_proxy_network

    deploy_project traefik "$traefik_dir" \
        089-traefik-pm-config-manager-migration.tar.gz \
        traefik cloudflared

    if ((DEPLOY_COMING_SOON)); then
        deploy_project coming-soon "$coming_dir" \
            089-msaas-reviewnudge-coming-soon-pm-config-manager-migration.tar.gz \
            web
    fi

    deploy_project reviewnudge "$reviewnudge_dir" \
        089-msaas-reviewnudge-pm-config-manager-migration.tar.gz \
        db web jobs

    log INFO "Nudge launch complete" \
        "traefik=$traefik_dir" \
        "coming_soon=$([[ $DEPLOY_COMING_SOON -eq 1 ]] && printf deployed || printf skipped)" \
        "reviewnudge=$reviewnudge_dir"
}

main "$@"
