#!/usr/bin/env bash
set -euo pipefail

# PM Configuration Manager
# Discovers active entities from canonical selectors, loads entity helpers and
# pm-config-* phase modules, validates the unified registry, and delegates final
# injection to the active adapter module.

if [[ "${__PM_CONFIG_MANAGER_LOADED:-0}" == 1 && "${BASH_SOURCE[0]}" != "$0" ]]; then
    return 0
fi
__PM_CONFIG_MANAGER_LOADED=1
export __PM_CONFIG_MANAGER_LOADED

: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)}"

if ! declare -F pm_config_register >/dev/null 2>&1; then
    # shellcheck disable=SC1090
    . "${PORTMASON_SHARE}/pm-helpers-config"
fi

declare -ga PM_CONFIG_DISCOVERED_ENTITIES=()
declare -ga PM_CONFIG_EXPLICIT_BRIDGES=()
declare -gA PM_CONFIG_SEEN_ENTITIES=()
declare -gA PM_CONFIG_SEEN_BRIDGES=()

a_pm_config_normalize_code() {
    local out_var="${1:?output variable required}"
    local value="${2-}"
    value="${value,,}"
    value="${value//_/-}"
    value="$(printf '%s' "$value" | sed 's/[^a-z0-9-]/-/g; s/-\{2,\}/-/g; s/^-//; s/-$//')"
    printf -v "$out_var" '%s' "$value"
}

pm_config_manager_add_entity() {
    local raw="${1-}"
    local entity
    a_pm_config_normalize_code entity "$raw"
    [[ -n "$entity" ]] || return 0
    [[ -z "${PM_CONFIG_SEEN_ENTITIES[$entity]+x}" ]] || return 0
    PM_CONFIG_SEEN_ENTITIES["$entity"]=1
    PM_CONFIG_DISCOVERED_ENTITIES+=("$entity")
}

pm_config_manager_add_bridge() {
    local raw="${1-}"
    local bridge
    a_pm_config_normalize_code bridge "$raw"
    [[ -n "$bridge" ]] || return 0
    [[ -z "${PM_CONFIG_SEEN_BRIDGES[$bridge]+x}" ]] || return 0
    PM_CONFIG_SEEN_BRIDGES["$bridge"]=1
    PM_CONFIG_EXPLICIT_BRIDGES+=("$bridge")
}

pm_config_manager_discover_optional_providers() {
    local name value
    while IFS= read -r name; do
        [[ "$name" =~ ^PM_[A-Z0-9_]+_PROVIDER$ ]] || continue
        value="${!name:-}"
        [[ -n "$value" ]] || continue
        pm_config_manager_add_entity "$value"
    done < <(compgen -A variable | sort)

    # One-cycle compatibility with the pre-PM namespace.
    for name in SUPPORT_CHANNEL_PROVIDER ACME_DNS_PROVIDER; do
        value="${!name:-}"
        [[ -n "$value" ]] || continue
        pm_config_manager_add_entity "$value"
        if declare -F warn >/dev/null 2>&1; then
            warn "$name is deprecated; use PM_${name}"
        fi
    done
}

pm_config_manager_discover() {
    PM_CONFIG_DISCOVERED_ENTITIES=()
    PM_CONFIG_EXPLICIT_BRIDGES=()
    PM_CONFIG_SEEN_ENTITIES=()
    PM_CONFIG_SEEN_BRIDGES=()

    local runtime_adapter="${RUNTIME_ADAPTER_CODE:-}"
    local runtime="" adapter=""
    local db_code="${DB_PROVIDER_PLATFORM_CODE:-}"
    local db_provider="" db_platform=""
    local item

    # Core contracts are always present.
    for item in core application messaging cache control-plane; do
        pm_config_manager_add_entity "$item"
    done

    if [[ -n "$db_code" && "$db_code" == *-* ]]; then
        db_provider="${db_code%%-*}"
        db_platform="${db_code#*-}"
    else
        # Compatibility only: canonical workflows derive these from the composite
        # selector, but older test/project contexts may already have them set.
        db_provider="${DB_PROVIDER:-}"
        db_platform="${DB_PLATFORM:-}"
    fi
    if [[ -n "$db_provider" || -n "$db_platform" ]]; then
        pm_config_manager_add_entity database
        [[ -n "$db_platform" ]] && pm_config_manager_add_entity "$db_platform"
        [[ -n "$db_provider" ]] && pm_config_manager_add_entity "$db_provider"
        if [[ -n "$db_provider" && -n "$db_platform" ]]; then
            pm_config_manager_add_bridge "${db_provider}-${db_platform}"
        fi
    fi

    pm_config_manager_discover_optional_providers

    if [[ -n "$runtime_adapter" && "$runtime_adapter" == *-* ]]; then
        runtime="${runtime_adapter%%-*}"
        adapter="${runtime_adapter#*-}"
        if [[ "$runtime" == *+* ]]; then
            IFS='+' read -r -a _pm_config_runtime_parts <<<"$runtime"
            for item in "${_pm_config_runtime_parts[@]}"; do
                pm_config_manager_add_entity "$item"
            done
        else
            pm_config_manager_add_entity "$runtime"
        fi
        # Adapter is deliberately last so it performs final injection.
        pm_config_manager_add_entity "$adapter"
        pm_config_manager_add_bridge "${runtime}-${adapter}"
    fi

    IFS=',' read -r -a _pm_config_extra_entities <<<"${PM_CONFIG_ENTITIES:-}"
    for item in "${_pm_config_extra_entities[@]}"; do
        pm_config_manager_add_entity "$item"
    done

    IFS=',' read -r -a _pm_config_extra_bridges <<<"${PM_CONFIG_BRIDGES:-}"
    for item in "${_pm_config_extra_bridges[@]}"; do
        pm_config_manager_add_bridge "$item"
    done
}

pm_config_manager_resolve_file() {
    local out_var="${1:?output variable required}"
    local filename="${2:?filename required}"
    local resolved=""

    if [[ -n "${SCRIPT_DIR:-}" && -r "${SCRIPT_DIR}/${filename}" ]]; then
        resolved="${SCRIPT_DIR}/${filename}"
    elif [[ -r "${PORTMASON_SHARE}/${filename}" ]]; then
        resolved="${PORTMASON_SHARE}/${filename}"
    fi
    printf -v "$out_var" '%s' "$resolved"
}

pm_config_manager_active_adapter() {
    local out_var="${1:?output variable required}"
    local result="${ADAPTER_CODE:-}"

    if [[ -z "$result" && -n "${RUNTIME_ADAPTER_CODE:-}" \
        && "${RUNTIME_ADAPTER_CODE}" == *-* ]]; then
        result="${RUNTIME_ADAPTER_CODE#*-}"
    fi
    printf -v "$out_var" '%s' "$result"
}

pm_config_manager_bootstrap_local_env_files() {
    local adapter="" output_dir compose_file override_file source_file
    local ref basename target created=0
    local -a compose_files=()

    pm_config_manager_active_adapter adapter
    [[ "$adapter" == local ]] || return 0

    output_dir="${PM_CONFIG_OUTPUT_DIR:-${SCRIPT_DIR:-$PWD}/.portmason/config}"
    if [[ "$output_dir" != /* ]]; then
        output_dir="${SCRIPT_DIR:-$PWD}/${output_dir#./}"
    fi

    compose_file="${PM_COMPOSE_FILE:-${SCRIPT_DIR:-$PWD}/docker-compose.yml}"
    override_file="${PM_COMPOSE_OVERRIDE_FILE:-${SCRIPT_DIR:-$PWD}/docker-compose.override.yml}"
    [[ "$compose_file" == /* ]] \
        || compose_file="${SCRIPT_DIR:-$PWD}/${compose_file#./}"
    [[ "$override_file" == /* ]] \
        || override_file="${SCRIPT_DIR:-$PWD}/${override_file#./}"
    compose_files+=("$compose_file")
    [[ -f "$override_file" ]] && compose_files+=("$override_file")

    mkdir -p -- "$output_dir"
    chmod 700 "$output_dir" 2>/dev/null || true

    for source_file in "${compose_files[@]}"; do
        [[ -r "$source_file" ]] || continue
        while IFS= read -r ref; do
            [[ -n "$ref" ]] || continue
            basename="${ref##*/}"
            [[ "$basename" =~ ^[A-Za-z0-9._-]+\.env$ ]] || continue
            target="${output_dir}/${basename}"
            [[ -e "$target" ]] && continue
            (
                umask 077
                # PM-LINT-MACHINE-OUTPUT: exact generated dotenv file content.
                printf '# PM Configuration Manager bootstrap placeholder.\n' >"$target"
            )
            chmod 600 "$target"
            ((created+=1))
            log INFO "pm-config: created bootstrap service environment" \
                "file=$target"
        done < <(
            grep -Eo '(\./)?\.portmason/config/[A-Za-z0-9._-]+\.env' \
                "$source_file" 2>/dev/null \
                | sort -u \
                || true
        )
    done

    if (( created > 0 )); then
        log INFO "pm-config: bootstrap service environments ready" \
            "created=$created" "directory=$output_dir"
    fi
}

pm_config_manager_ensure_compose_model() {
    pm_config_manager_bootstrap_local_env_files
    pm_compose_load_model
}

pm_config_manager_source_entity() {
    local entity="${1:?entity required}"
    local config_file="" function_name

    # Primary selector helpers are loaded by pm-helpers. Optional entity
    # configuration modules may source their own source-safe helper when needed.
    pm_config_manager_resolve_file config_file "pm-config-${entity}"
    if [[ -z "$config_file" ]]; then
        local require_modules="${PM_CONFIG_REQUIRE_ENTITY_MODULES:-}"
        if [[ -z "$require_modules" ]]; then
            case "${PM_CONFIG_MANAGER_MODE:-prepare}" in
                apply|validate|plan) require_modules=true ;;
                *) require_modules=false ;;
            esac
        fi
        if [[ "$require_modules" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
            if declare -F pm_preflight_error >/dev/null 2>&1 \
                && [[ "${PM_CONFIG_MANAGER_MODE:-}" == preflight ]]; then
                pm_preflight_error "config.module" "pm-config-${entity}" \
                    "required configuration module is missing"
                return 0
            fi
            die "Required Portmason configuration module not found: pm-config-${entity}" 2
            return 2
        fi
        log DEBUG "pm-config: optional entity module not found" "entity=$entity"
        return 0
    fi

    log DEBUG "pm-config: loading entity configuration" "entity=$entity" "path=$config_file"
    # shellcheck disable=SC1090
    . "$config_file"
    function_name="pm_config_${entity//-/_}"
    if declare -F "$function_name" >/dev/null 2>&1; then
        PM_CONFIG_ACTIVE_ENTITY="$entity" "$function_name"
    else
        die "pm-config-${entity} does not define $function_name" 2
    fi
}

pm_config_manager_source_project_module() {
    local file="" function_name="pm_config_project"
    if [[ -n "${SCRIPT_DIR:-}" && -r "${SCRIPT_DIR}/pm-config-project" ]]; then
        file="${SCRIPT_DIR}/pm-config-project"
    elif [[ -n "${PROJECT_ROOT:-}" && -r "${PROJECT_ROOT}/pm-config-project" ]]; then
        file="${PROJECT_ROOT}/pm-config-project"
    fi
    [[ -n "$file" ]] || return 0

    log INFO "pm-config: loading project configuration contract" "path=$file"
    # shellcheck disable=SC1090
    . "$file"
    declare -F "$function_name" >/dev/null 2>&1 \
        || die "project configuration module does not define $function_name: $file" 2
    PM_CONFIG_ACTIVE_ENTITY=project "$function_name"
}

pm_config_manager_source_bridge() {
    local bridge="${1:?bridge required}"
    local file="" function_name

    # Existing database bridges use pm-db-bridge-<provider>-<platform>.
    pm_config_manager_resolve_file file "pm-bridge-${bridge}"
    if [[ -z "$file" && "$bridge" == *-* ]]; then
        pm_config_manager_resolve_file file "pm-db-bridge-${bridge}"
    fi
    [[ -n "$file" ]] || return 0

    # Bridge may already be loaded by pm-helpers; sourcing must remain safe.
    # shellcheck disable=SC1090
    . "$file"
    function_name="pm_bridge_${bridge//-/_}_config"
    if declare -F "$function_name" >/dev/null 2>&1; then
        "$function_name"
    elif declare -F pm_db_bridge_config >/dev/null 2>&1; then
        pm_db_bridge_config
    fi
}

pm_config_manager_prepare_base_registry() {
    local entity

    PM_CONFIG_MANAGER_MODE=bootstrap
    export PM_CONFIG_MANAGER_MODE
    pm_config_reset

    # Populate the stable cross-project contract without discovering selectors,
    # sourcing bridges, or replacing lifecycle functions. Full entity discovery
    # occurs later during preflight/apply, after the current context is ready.
    for entity in core application messaging cache control-plane database; do
        pm_config_manager_source_entity "$entity"
    done
    pm_config_validate_registry
    PM_CONFIG_MANAGER_PREPARED=base
    export PM_CONFIG_MANAGER_PREPARED
}

pm_config_manager_prepare() {
    local mode="${1:-prepare}"
    local entity bridge

    PM_CONFIG_MANAGER_MODE="$mode"
    export PM_CONFIG_MANAGER_MODE
    pm_config_reset
    pm_config_manager_discover

    log INFO "pm-config: preparing registry" \
        "mode=$mode" \
        "entities=$(IFS=,; printf '%s' "${PM_CONFIG_DISCOVERED_ENTITIES[*]}")"

    for entity in "${PM_CONFIG_DISCOVERED_ENTITIES[@]}"; do
        pm_config_manager_source_entity "$entity"
    done
    pm_config_manager_source_project_module

    for bridge in "${PM_CONFIG_EXPLICIT_BRIDGES[@]}"; do
        pm_config_manager_source_bridge "$bridge"
    done

    pm_config_validate_registry
    if [[ -n "${PROJECT_SERVICES:-}" ]]; then
        if ! pm_config_validate_required_services; then
            if [[ "$mode" != preflight ]] || ! declare -F pm_preflight_error >/dev/null 2>&1; then
                die "pm-config: one or more required service configuration values are missing" 2
                return 2
            fi
        fi
    fi

    PM_CONFIG_MANAGER_PREPARED=1
    export PM_CONFIG_MANAGER_PREPARED
    log INFO "pm-config: registry prepared" "keys=${#PM_CONFIG_KEYS[@]}"
}

pm_config_manager_apply_entities() {
    local entity function_name adapter=""
    if [[ -n "${RUNTIME_ADAPTER_CODE:-}" && "$RUNTIME_ADAPTER_CODE" == *-* ]]; then
        adapter="${RUNTIME_ADAPTER_CODE#*-}"
    fi

    for entity in "${PM_CONFIG_DISCOVERED_ENTITIES[@]}"; do
        [[ -z "$adapter" || "$entity" != "$adapter" ]] || continue
        function_name="pm_config_apply_${entity//-/_}"
        declare -F "$function_name" >/dev/null 2>&1 || continue
        log INFO "pm-config: applying entity configuration" "entity=$entity"
        "$function_name"
    done

    if [[ -n "$adapter" ]]; then
        function_name="pm_config_apply_${adapter//-/_}"
        if declare -F "$function_name" >/dev/null 2>&1; then
            log INFO "pm-config: applying adapter configuration" "adapter=$adapter"
            "$function_name"
        fi
    fi
}

pm_config_manager_apply_bridges() {
    local bridge function_name
    for bridge in "${PM_CONFIG_EXPLICIT_BRIDGES[@]}"; do
        function_name="pm_bridge_${bridge//-/_}_config_apply"
        declare -F "$function_name" >/dev/null 2>&1 || continue
        log INFO "pm-config: applying bridge configuration" "bridge=$bridge"
        "$function_name"
    done
}

pm_config_manager_apply() {
    if [[ -z "${PROJECT_SERVICES:-}" || -z "${PM_COMPOSE_MODEL_JSON:-}" ]]; then
        pm_config_manager_ensure_compose_model
    fi
    pm_config_manager_prepare apply
    pm_config_manager_apply_bridges
    pm_config_manager_apply_entities
    log INFO "pm-config: configuration phase complete"
}

pm_config_manager_plan() {
    pm_config_manager_prepare plan
    # PM-LINT-MACHINE-OUTPUT: tabular plan output is the command contract.
    printf 'KEY\tTYPE\tSCOPES\tTARGET\tREQUIRED\tOWNER\n'
    pm_config_registry_records | while IFS='|' read -r key type scopes target required owner; do
        # PM-LINT-MACHINE-OUTPUT: tabular plan output is the command contract.
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$key" "$type" "$scopes" "$target" "$required" "$owner"
    done
}

pm_config_manager_main() {
    local command="${1:-apply}"
    shift || true

    if ! declare -F log >/dev/null 2>&1; then
        # shellcheck disable=SC1090
        . "${PORTMASON_SHARE}/pm-helpers" "$@"
    fi
    if ! declare -F pm_compose_load_model >/dev/null 2>&1; then
        # shellcheck disable=SC1090
        . "${PORTMASON_SHARE}/pm-helpers-db"
    fi

    case "$command" in
        prepare|validate)
            pm_config_manager_ensure_compose_model || true
            pm_config_manager_prepare "$command"
            ;;
        apply)
            pm_config_manager_ensure_compose_model || true
            pm_config_manager_apply
            ;;
        plan)
            pm_config_manager_ensure_compose_model || true
            pm_config_manager_plan
            ;;
        *)
            die "Usage: pm-config-manager [prepare|validate|apply|plan]" 2
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    pm_config_manager_main "$@"
fi
