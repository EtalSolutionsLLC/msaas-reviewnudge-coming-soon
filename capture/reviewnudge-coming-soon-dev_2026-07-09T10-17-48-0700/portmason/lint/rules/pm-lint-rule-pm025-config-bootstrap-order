#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm025() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local base="${path##*/}" bootstrap_line="" preflight_line=""

    [[ "$base" == "pm-setup" ]] || return 0
    grep -q 'pm_db_preflight' "$file" || return 0

    bootstrap_line="$(grep -n 'pm_config_manager_bootstrap_local_env_files' "$file" | head -n1 | cut -d: -f1 || true)"
    preflight_line="$(grep -n 'pm_db_preflight' "$file" | tail -n1 | cut -d: -f1 || true)"

    if [[ -z "$bootstrap_line" ]]; then
        pm_lint_report PM025 "$path" "${preflight_line:-1}" \
            "pm-setup renders or validates Compose without a PM Configuration Manager bootstrap boundary" \
            "Create non-destructive generated service env placeholders before selector refresh and aggregate preflight."
        return 0
    fi

    if (( bootstrap_line >= preflight_line )); then
        pm_lint_report PM025 "$path" "$bootstrap_line" \
            "Generated service configuration is bootstrapped after Compose preflight" \
            "Move pm_config_manager_bootstrap_local_env_files before pm_db_preflight so Compose can render deterministically."
    fi
}

pm_lint_register_rule PM025 ERROR file \
    "Configuration bootstrap precedes Compose preflight" \
    "EPC A12.7; PM-PAT-005" \
    pm_lint_rule_pm025
