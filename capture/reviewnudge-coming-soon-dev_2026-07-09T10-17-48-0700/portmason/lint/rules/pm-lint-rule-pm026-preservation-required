#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm026() {
    local root="${1:?root required}"
    local chg="${root}/chg.txt"

    [[ -r "$chg" ]] || return 0
    grep -Eq '(^|/)project/(\.env|docker-compose[^/]*\.ya?ml|compose[^/]*\.ya?ml)$|^project/(\.env|docker-compose[^/]*\.ya?ml|compose[^/]*\.ya?ml)$' "$chg" \
        || return 0

    if [[ -r "${root}/preservation.json" || -r "${root}/project/preservation.json" ]]; then
        return 0
    fi

    pm_lint_report PM026 "chg.txt" 1 \
        "Migration changes project configuration without a preservation manifest" \
        "Add project/preservation.json documenting the source snapshot and every preserved, renamed, removed, and added service, route, volume, and environment key."
}

pm_lint_register_rule PM026 REVIEW project \
    "Configuration migration preservation evidence" \
    "TGF Pattern Governance; EPC A12.8; PM-PAT-006" \
    pm_lint_rule_pm026
