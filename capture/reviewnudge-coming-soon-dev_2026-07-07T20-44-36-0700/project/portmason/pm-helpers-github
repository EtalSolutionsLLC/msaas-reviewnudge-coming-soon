#!/usr/bin/env bash
set -euo pipefail

: "${GITHUB_PAGES_BUILD_DIR:=${STATIC_BUILD_DIR:-${SITE_DIR:-$PWD}}}"
: "${GITHUB_PAGES_CONFIG_JSON:=${GITHUB_PAGES_BUILD_DIR}/config.generated.json}"

github_pages_prepare() {
  mkdir -p "$GITHUB_PAGES_BUILD_DIR"
  "${PORTMASON_SHARE}/pm-util-render-env" --json --out "$GITHUB_PAGES_CONFIG_JSON" "${ENV_FILE}"
  log INFO "Prepared GitHub Pages artifact directory: $GITHUB_PAGES_BUILD_DIR"
}
