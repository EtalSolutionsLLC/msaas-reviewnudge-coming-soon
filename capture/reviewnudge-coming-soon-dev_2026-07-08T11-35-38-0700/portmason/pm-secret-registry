#!/usr/bin/env bash
set -euo pipefail

# Portmason canonical secret registry.
#
# Record format:
#   KEY|CLASSIFICATION|COMMA-SEPARATED SERVICE ROLES
#
# CLASSIFICATION:
#   runtime       May be injected only into the listed runtime service roles.
#   control-plane Recognized and protected, but never injected into a service.
#
# A role list of "*" means every runtime role. An empty role list means none.
#
# This file is the single source of truth for canonical secret classification
# and service-role injection. Do not maintain parallel key lists elsewhere.

PM_SECRET_REGISTRY=(
    'DB_USER|runtime|db,web,app,jobs,worker'
    'DB_PASSWORD|runtime|db,web,app,jobs,worker'
    'DB_ADMIN_USER|runtime|db'
    'DB_ADMIN_PASSWORD|runtime|db'
    'DATABASE_URL|runtime|db,web,app,jobs,worker'
    'DATABASE_DIRECT_URL|runtime|db,web,app,jobs,worker'

    'APP_ADMIN_USER|runtime|web,app,jobs,worker'
    'APP_ADMIN_PASSWORD|runtime|web,app,jobs,worker'
    'APP_SECRET|runtime|web,app,jobs,worker'
    'SESSION_SECRET|runtime|web,app,jobs,worker'
    'COOKIE_SECRET|runtime|web,app,jobs,worker'
    'JWT_SECRET|runtime|web,app,jobs,worker'
    'CHECKOUT_TOKEN_KEY|runtime|web,app,jobs,worker'
    'BILLING_EVENT_SECRET|runtime|web,app,jobs,worker'
    'REVIEW_PROVIDER_EVENT_SECRET|runtime|web,app,jobs,worker'
    'BULKEMAILER_API_KEY|runtime|web,app,jobs,worker'
    'SMTP_PASS|runtime|web,app,jobs,worker'
    'TURNSTILE_SECRET_KEY|runtime|web,app,jobs,worker'
    'ABUSE_IDENTIFIER_SALT|runtime|web,app,jobs,worker'
    'QUEUE_USER|runtime|web,app,jobs,worker'
    'QUEUE_PASSWORD|runtime|web,app,jobs,worker'
    'CACHE_PASSWORD|runtime|cache'

    'SUPPORT_CHANNEL_BOT_TOKEN|runtime|support-bot'
    'SUPPORT_CHANNEL_SOCKET_TOKEN|runtime|support-bot'
    'SUPPORT_CHANNEL_CLIENT_SECRET|runtime|support-bot'
    'SUPPORT_CHANNEL_SIGNING_SECRET|runtime|support-bot'

    'DB_API_KEY|control-plane|'
    'RUNTIME_API_KEY|control-plane|'
    'DNS_API_KEY|control-plane|'
    'STORAGE_API_KEY|control-plane|'
    'EMAIL_API_KEY|control-plane|'
    'BILLING_API_KEY|control-plane|'
)

pm_secret_registry_records() {
    printf '%s\n' "${PM_SECRET_REGISTRY[@]}"
}

pm_secret_registry_record_for_key() {
    local wanted="${1:?secret key required}"
    local record key
    for record in "${PM_SECRET_REGISTRY[@]}"; do
        IFS='|' read -r key _ <<<"$record"
        [[ "$key" == "$wanted" ]] || continue
        printf '%s\n' "$record"
        return 0
    done
    return 1
}

pm_secret_registry_keys_for_classification() {
    local wanted="${1:?classification required}"
    local record key classification roles
    for record in "${PM_SECRET_REGISTRY[@]}"; do
        IFS='|' read -r key classification roles <<<"$record"
        [[ "$classification" == "$wanted" ]] || continue
        printf '%s\n' "$key"
    done
}

pm_secret_registry_role_matches() {
    local configured_roles="${1-}"
    local wanted_role="${2:?service role required}"
    local configured_role

    [[ "$configured_roles" == "*" ]] && return 0

    IFS=',' read -r -a _pm_registry_roles <<<"$configured_roles"
    for configured_role in "${_pm_registry_roles[@]}"; do
        configured_role="${configured_role#${configured_role%%[![:space:]]*}}"
        configured_role="${configured_role%${configured_role##*[![:space:]]}}"
        [[ "$configured_role" == "$wanted_role" ]] && return 0
    done
    return 1
}

pm_secret_registry_keys_for_role() {
    local wanted_role="${1:?service role required}"
    local record key classification roles
    for record in "${PM_SECRET_REGISTRY[@]}"; do
        IFS='|' read -r key classification roles <<<"$record"
        [[ "$classification" == "runtime" ]] || continue
        pm_secret_registry_role_matches "$roles" "$wanted_role" || continue
        printf '%s\n' "$key"
    done
}

pm_secret_registry_validate() {
    local record key classification roles
    local -A seen=()

    for record in "${PM_SECRET_REGISTRY[@]}"; do
        IFS='|' read -r key classification roles <<<"$record"

        [[ "$key" =~ ^[A-Z][A-Z0-9_]*$ ]] \
            || die "invalid canonical secret key in PM_SECRET_REGISTRY: $key" 2

        case "$classification" in
            runtime|control-plane) ;;
            *) die "invalid secret classification for $key: $classification" 2 ;;
        esac

        [[ -z "${seen[$key]+x}" ]] \
            || die "duplicate canonical secret key in PM_SECRET_REGISTRY: $key" 2
        seen["$key"]=1

        if [[ "$classification" == "control-plane" && -n "$roles" ]]; then
            die "control-plane secret must not declare runtime roles: $key" 2
        fi
    done
}

pm_secret_registry_refresh_derived_arrays() {
    mapfile -t PM_CANONICAL_RUNTIME_SECRET_KEYS \
        < <(pm_secret_registry_keys_for_classification runtime)
    mapfile -t PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS \
        < <(pm_secret_registry_keys_for_classification control-plane)

    PM_CANONICAL_SECRET_KEYS=(
        "${PM_CANONICAL_RUNTIME_SECRET_KEYS[@]}"
        "${PM_CANONICAL_CONTROL_PLANE_SECRET_KEYS[@]}"
    )
}

# Override the legacy role switch with the registry-derived implementation.
# PM_ADDITIONAL_SECRET_KEYS remains a backward-compatible project extension.
pm_service_secret_keys() {
    local role="${1:?service role required}"
    local extra

    pm_secret_registry_keys_for_role "$role"

    IFS=',' read -r -a _pm_extra_secret_keys <<<"${PM_ADDITIONAL_SECRET_KEYS:-}"
    for extra in "${_pm_extra_secret_keys[@]}"; do
        extra="${extra#${extra%%[![:space:]]*}}"
        extra="${extra%${extra##*[![:space:]]}}"
        [[ -n "$extra" ]] && printf '%s\n' "$extra"
    done
}

pm_secret_registry_validate
pm_secret_registry_refresh_derived_arrays
