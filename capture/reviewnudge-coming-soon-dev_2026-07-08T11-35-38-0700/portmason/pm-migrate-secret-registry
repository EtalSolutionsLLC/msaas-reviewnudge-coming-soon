#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TARGET="${1:-${SCRIPT_DIR}/pm-helpers-db}"
REGISTRY_FILE="${SCRIPT_DIR}/pm-secret-registry"
MARKER="# Portmason canonical secret registry bootstrap"

[[ -r "$TARGET" ]] || {
    printf 'ERROR: pm-helpers-db not readable: %s\n' "$TARGET" >&2
    exit 2
}

[[ -r "$REGISTRY_FILE" ]] || {
    printf 'ERROR: pm-secret-registry not readable: %s\n' "$REGISTRY_FILE" >&2
    exit 2
}

if grep -Fq "$MARKER" "$TARGET"; then
    printf 'Secret registry bootstrap already present: %s\n' "$TARGET"
    exit 0
fi

cat >>"$TARGET" <<'BOOTSTRAP'

# Portmason canonical secret registry bootstrap
_pm_secret_registry_file="${PORTMASON_SHARE:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)}/pm-secret-registry"
if [[ ! -r "$_pm_secret_registry_file" ]]; then
    die "Portmason canonical secret registry is not readable: $_pm_secret_registry_file" 2
fi
# shellcheck disable=SC1090
. "$_pm_secret_registry_file"
unset _pm_secret_registry_file
BOOTSTRAP

bash -n "$TARGET"
printf 'Installed canonical secret registry bootstrap: %s\n' "$TARGET"
