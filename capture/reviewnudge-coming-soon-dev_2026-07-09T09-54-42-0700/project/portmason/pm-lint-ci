#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
: "${PORTMASON_SHARE:=$SCRIPT_DIR}"
export PORTMASON_SHARE

# shellcheck disable=SC1091
. "${PORTMASON_SHARE}/pm-helpers" --read-only

pm_lint_ci_base_ref() {
    local out_var="${1:?output variable required}"
    local value="${PM_LINT_BASE_REF:-}"

    if [[ -z "$value" && -n "${GITHUB_BASE_REF:-}" ]]; then
        value="origin/${GITHUB_BASE_REF}"
    fi
    if [[ -z "$value" && -n "${GITHUB_EVENT_BEFORE:-}" \
        && ! "$GITHUB_EVENT_BEFORE" =~ ^0+$ ]]; then
        value="$GITHUB_EVENT_BEFORE"
    fi
    if [[ -z "$value" ]] && git rev-parse --verify HEAD^ >/dev/null 2>&1; then
        value="HEAD^"
    fi
    printf -v "$out_var" '%s' "$value"
}

main() {
    local root="${PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd -P)}"
    local base_ref=""
    local -a args=(--root "$root" --changed --format github)

    pm_lint_ci_base_ref base_ref
    [[ -n "$base_ref" ]] && args+=("$base_ref")
    [[ "${PM_LINT_CI_STRICT:-false}" == true ]] && args+=(--strict)
    [[ "${PM_LINT_CI_FAIL_ON_REVIEW:-false}" == true ]] && args+=(--fail-on-review)

    if command -v shellcheck >/dev/null 2>&1; then
        log INFO "pm-lint-ci: ShellCheck is available"
    elif [[ "${PM_LINT_REQUIRE_SHELLCHECK:-true}" == true ]]; then
        die "pm-lint-ci: ShellCheck is required but not installed" 2
    else
        warn "pm-lint-ci: ShellCheck is unavailable; PM020 will be skipped"
    fi

    exec "${PORTMASON_SHARE}/pm-lint" "${args[@]}"
}

main "$@"
