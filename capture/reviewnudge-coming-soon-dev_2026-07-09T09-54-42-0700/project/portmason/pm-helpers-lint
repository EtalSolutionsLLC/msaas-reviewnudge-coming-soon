#!/usr/bin/env bash
set -euo pipefail

# PM Linting Suite core mechanics.
# Source-safe: this file defines rule registration, target discovery,
# exception handling, finding collection, and output formatting only.

if [[ "${__PM_HELPERS_LINT_LOADED:-0}" == "1" ]]; then
    return 0 2>/dev/null || exit 0
fi
__PM_HELPERS_LINT_LOADED=1
export __PM_HELPERS_LINT_LOADED

declare -ga PM_LINT_RULE_ORDER=()
declare -gA PM_LINT_RULE_SEVERITY=()
declare -gA PM_LINT_RULE_SCOPE=()
declare -gA PM_LINT_RULE_TITLE=()
declare -gA PM_LINT_RULE_REFERENCE=()
declare -gA PM_LINT_RULE_FUNCTION=()

declare -ga PM_LINT_FINDINGS=()
declare -ga PM_LINT_TARGET_FILES=()
declare -ga PM_LINT_EXTRA_RULE_DIRS=()
declare -gA PM_LINT_LOADED_RULE_DIRS=()
declare -g PM_LINT_LOADING_RULE_ORIGIN="canonical"
declare -ga PM_LINT_EXCEPTION_RULES=()
declare -ga PM_LINT_EXCEPTION_PATTERNS=()
declare -ga PM_LINT_EXCEPTION_OWNERS=()
declare -ga PM_LINT_EXCEPTION_APPROVED=()
declare -ga PM_LINT_EXCEPTION_REVIEW=()
declare -ga PM_LINT_EXCEPTION_REASONS=()

declare -gi PM_LINT_ERROR_COUNT=0
declare -gi PM_LINT_WARNING_COUNT=0
declare -gi PM_LINT_GUIDANCE_COUNT=0
declare -gi PM_LINT_REVIEW_COUNT=0
declare -gi PM_LINT_SUPPRESSED_COUNT=0

declare -g PM_LINT_ROOT=""
declare -g PM_LINT_FORMAT="text"
declare -g PM_LINT_STRICT="false"
declare -g PM_LINT_FAIL_ON_REVIEW="false"
declare -g PM_LINT_EXCEPTION_FILE=""
declare -g PM_LINT_SELECTED_RULE=""
declare -g PM_LINT_MODE="changed"
declare -g PM_LINT_BASE_REF=""

pm_lint_register_rule() {
    local rule_id="${1:?rule id required}"
    local severity="${2:?severity required}"
    local scope="${3:?scope required}"
    local title="${4:?title required}"
    local reference="${5:?reference required}"
    local function_name="${6:?function name required}"

    [[ "$rule_id" =~ ^PM[0-9]{3}$ ]] \
        || die "pm-lint: invalid rule id: $rule_id" 2

    local rule_number="${rule_id#PM}"
    if [[ "$PM_LINT_LOADING_RULE_ORIGIN" == custom ]] && (( 10#$rule_number < 900 )); then
        die "pm-lint: custom rules must use reserved ids PM900-PM999: $rule_id" 2
    fi
    if [[ "$PM_LINT_LOADING_RULE_ORIGIN" == canonical ]] && (( 10#$rule_number >= 900 )); then
        die "pm-lint: canonical rules may not use project-reserved ids PM900-PM999: $rule_id" 2
    fi

    case "$severity" in
        ERROR|WARNING|GUIDANCE|REVIEW) ;;
        *) die "pm-lint: invalid severity for $rule_id: $severity" 2 ;;
    esac
    case "$scope" in
        file|project) ;;
        *) die "pm-lint: invalid scope for $rule_id: $scope" 2 ;;
    esac
    declare -F "$function_name" >/dev/null 2>&1 \
        || die "pm-lint: rule function not defined for $rule_id: $function_name" 2
    [[ -z "${PM_LINT_RULE_FUNCTION[$rule_id]+x}" ]] \
        || die "pm-lint: duplicate rule id: $rule_id" 2

    PM_LINT_RULE_ORDER+=("$rule_id")
    PM_LINT_RULE_SEVERITY["$rule_id"]="$severity"
    PM_LINT_RULE_SCOPE["$rule_id"]="$scope"
    PM_LINT_RULE_TITLE["$rule_id"]="$title"
    PM_LINT_RULE_REFERENCE["$rule_id"]="$reference"
    PM_LINT_RULE_FUNCTION["$rule_id"]="$function_name"
}

pm_lint_reset_results() {
    PM_LINT_FINDINGS=()
    PM_LINT_ERROR_COUNT=0
    PM_LINT_WARNING_COUNT=0
    PM_LINT_GUIDANCE_COUNT=0
    PM_LINT_REVIEW_COUNT=0
    PM_LINT_SUPPRESSED_COUNT=0
}

pm_lint_normalize_root() {
    local requested="${1:-$PWD}"
    PM_LINT_ROOT="$(cd -- "$requested" && pwd -P)"
    PM_LINT_EXCEPTION_FILE="${PM_LINT_EXCEPTION_FILE:-${PM_LINT_ROOT}/.pm-lint-exceptions}"
    export PM_LINT_ROOT PM_LINT_EXCEPTION_FILE
}

pm_lint_relative_path() {
    local out_var="${1:?output variable required}"
    local path="${2:?path required}"
    local resolved_absolute=""
    local resolved_relative=""

    if [[ "$path" == /* ]]; then
        resolved_absolute="$path"
    else
        resolved_absolute="${PM_LINT_ROOT}/${path#./}"
    fi

    if [[ "$resolved_absolute" == "$PM_LINT_ROOT" ]]; then
        resolved_relative="."
    elif [[ "$resolved_absolute" == "$PM_LINT_ROOT/"* ]]; then
        resolved_relative="${resolved_absolute#${PM_LINT_ROOT}/}"
    else
        resolved_relative="$resolved_absolute"
    fi
    printf -v "$out_var" '%s' "$resolved_relative"
}

pm_lint_absolute_path() {
    local out_var="${1:?output variable required}"
    local path="${2:?path required}"
    if [[ "$path" == /* ]]; then
        printf -v "$out_var" '%s' "$path"
    else
        printf -v "$out_var" '%s' "${PM_LINT_ROOT}/${path#./}"
    fi
}

pm_lint_path_is_ignored() {
    local path="${1:?path required}"
    case "/$path/" in
        */.git/*|*/node_modules/*|*/vendor/*|*/dist/*|*/build/*|*/coverage/*|*/logs/*|*/certs/*|*/.portmason/*|*/__pycache__/*)
            return 0
            ;;
    esac
    case "$path" in
        *:Zone.Identifier|*.png|*.jpg|*.jpeg|*.gif|*.webp|*.ico|*.pdf|*.docx|*.zip|*.tar|*.tar.gz|*.tgz|*.gz|*.7z|*.woff|*.woff2|*.ttf|*.otf|*.key|*.pem|*.crt|*.pfx)
            return 0
            ;;
    esac
    return 1
}

pm_lint_path_is_text() {
    local path="${1:?path required}"
    [[ -f "$path" ]] || return 1
    grep -Iq . "$path" 2>/dev/null || [[ ! -s "$path" ]]
}

pm_lint_add_target() {
    local path="${1:?path required}"
    local relative="" absolute=""
    pm_lint_relative_path relative "$path"
    pm_lint_path_is_ignored "$relative" && return 0
    pm_lint_absolute_path absolute "$relative"
    pm_lint_path_is_text "$absolute" || return 0
    PM_LINT_TARGET_FILES+=("$relative")
}

pm_lint_collect_path() {
    local path="${1:?path required}"
    local absolute=""
    pm_lint_absolute_path absolute "$path"

    if [[ -f "$absolute" ]]; then
        pm_lint_add_target "$absolute"
        return 0
    fi
    [[ -d "$absolute" ]] || return 0

    while IFS= read -r -d '' path; do
        pm_lint_add_target "$path"
    done < <(find "$absolute" -type f -print0)
}

pm_lint_unique_targets() {
    local item
    local -A seen=()
    local -a unique=()
    for item in "${PM_LINT_TARGET_FILES[@]}"; do
        [[ -z "${seen[$item]+x}" ]] || continue
        seen["$item"]=1
        unique+=("$item")
    done
    if (( ${#unique[@]} > 0 )); then
        mapfile -t PM_LINT_TARGET_FILES < <(printf '%s\n' "${unique[@]}" | LC_ALL=C sort)
    else
        PM_LINT_TARGET_FILES=()
    fi
}

pm_lint_collect_all() {
    PM_LINT_TARGET_FILES=()
    local path
    if git -C "$PM_LINT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        while IFS= read -r path; do
            [[ -n "$path" ]] || continue
            pm_lint_add_target "$path"
        done < <(git -C "$PM_LINT_ROOT" ls-files -co --exclude-standard)
    else
        pm_lint_collect_path "$PM_LINT_ROOT"
    fi
    pm_lint_unique_targets
}

pm_lint_collect_changed() {
    local base_ref="${1:-}"
    PM_LINT_TARGET_FILES=()
    local path

    if ! git -C "$PM_LINT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        pm_lint_collect_all
        return 0
    fi

    if [[ -n "$base_ref" ]] && git -C "$PM_LINT_ROOT" rev-parse --verify "$base_ref^{commit}" >/dev/null 2>&1; then
        while IFS= read -r path; do
            [[ -n "$path" ]] && pm_lint_add_target "$path"
        done < <(git -C "$PM_LINT_ROOT" diff --name-only --diff-filter=ACMR "$base_ref"...HEAD)
    fi

    while IFS= read -r path; do
        [[ -n "$path" ]] && pm_lint_add_target "$path"
    done < <(
        git -C "$PM_LINT_ROOT" diff --name-only --diff-filter=ACMR
        git -C "$PM_LINT_ROOT" diff --cached --name-only --diff-filter=ACMR
        git -C "$PM_LINT_ROOT" ls-files --others --exclude-standard
    )
    pm_lint_unique_targets
}

pm_lint_load_rule_dir() {
    local rule_dir="${1:?rule directory required}"
    local origin="${2:?rule origin required}"
    local file resolved=""

    [[ -d "$rule_dir" ]] || return 0
    resolved="$(cd -- "$rule_dir" && pwd -P)"
    [[ -z "${PM_LINT_LOADED_RULE_DIRS[$resolved]+x}" ]] || return 0
    PM_LINT_LOADED_RULE_DIRS["$resolved"]=1

    PM_LINT_LOADING_RULE_ORIGIN="$origin"
    while IFS= read -r -d '' file; do
        # shellcheck disable=SC1090
        . "$file"
    done < <(find "$resolved" -maxdepth 1 -type f -name 'pm-lint-rule-*' -print0 | sort -z)
}

pm_lint_load_rules() {
    local canonical_dir="${PORTMASON_SHARE}/lint/rules"
    local project_dir="${PM_LINT_ROOT}/.pm-lint/rules"
    local raw="" dir=""

    [[ -d "$canonical_dir" ]] || die "pm-lint: rule directory not found: $canonical_dir" 2
    PM_LINT_LOADED_RULE_DIRS=()

    pm_lint_load_rule_dir "$canonical_dir" canonical
    pm_lint_load_rule_dir "$project_dir" custom

    if [[ -n "${PM_LINT_RULE_PATHS:-}" ]]; then
        IFS=':' read -r -a _pm_lint_env_rule_dirs <<<"$PM_LINT_RULE_PATHS"
        for raw in "${_pm_lint_env_rule_dirs[@]}"; do
            [[ -n "$raw" ]] || continue
            pm_lint_load_rule_dir "$raw" custom
        done
    fi

    for dir in "${PM_LINT_EXTRA_RULE_DIRS[@]}"; do
        pm_lint_load_rule_dir "$dir" custom
    done

    PM_LINT_LOADING_RULE_ORIGIN="canonical"
}

pm_lint_date_is_valid() {
    local value="${1:-}"
    [[ "$value" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || return 1
    date -u -d "$value" +%F >/dev/null 2>&1
}

pm_lint_load_exceptions() {
    PM_LINT_EXCEPTION_RULES=()
    PM_LINT_EXCEPTION_PATTERNS=()
    PM_LINT_EXCEPTION_OWNERS=()
    PM_LINT_EXCEPTION_APPROVED=()
    PM_LINT_EXCEPTION_REVIEW=()
    PM_LINT_EXCEPTION_REASONS=()

    [[ -r "$PM_LINT_EXCEPTION_FILE" ]] || return 0

    local line_no=0 line rule pattern owner approved review reason extra today
    today="$(date -u +%F)"
    while IFS= read -r line || [[ -n "$line" ]]; do
        ((line_no += 1))
        [[ -n "$line" ]] || continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        IFS='|' read -r rule pattern owner approved review reason extra <<<"$line"

        if [[ -n "${extra:-}" || -z "${reason:-}" ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception must contain exactly six pipe-delimited fields" \
                "Use RULE|PATH_GLOB|OWNER|APPROVED_DATE|REVIEW_DATE|REASON."
            continue
        fi
        if [[ ! "$rule" =~ ^PM[0-9]{3}$ || "$rule" == PM000 ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Invalid or non-suppressible rule id in exception: ${rule:-<empty>}" \
                "Use a concrete PM### rule other than PM000."
            continue
        fi
        if [[ -z "${PM_LINT_RULE_FUNCTION[$rule]+x}" ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception references an unknown rule: $rule" \
                "Load the owning rule module or remove the stale exception."
            continue
        fi
        if [[ -z "$pattern" || -z "$owner" || -z "$reason" ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception fields may not be blank" \
                "Supply a narrow path glob, accountable owner, dates, and reason."
            continue
        fi
        if ! pm_lint_date_is_valid "$approved" || ! pm_lint_date_is_valid "$review"; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception dates must be valid YYYY-MM-DD values" \
                "Correct the approval and review dates."
            continue
        fi
        if [[ "$approved" > "$today" ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception approval date is in the future: $approved" \
                "Use the actual approval date."
            continue
        fi
        if [[ "$review" < "$approved" ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception review date precedes approval date" \
                "Set REVIEW_DATE on or after APPROVED_DATE."
            continue
        fi
        if [[ "$review" < "$today" ]]; then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception expired on $review: $rule $pattern" \
                "Resolve the violation or renew the exception through documented approval."
            continue
        fi
        case "$pattern" in
            /*|.|./|\*|\*\*|./\*|./\*\*)
                pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                    "Exception path is absolute or overly broad: $pattern" \
                    "Use the narrowest repository-relative path or glob that covers the approved deviation."
                continue
                ;;
        esac
        if (( ${#reason} < 12 )); then
            pm_lint_report_internal PM000 ERROR ".pm-lint-exceptions" "$line_no" \
                "Exception reason is too short to be actionable" \
                "Describe the deviation and the intended resolution or review basis."
            continue
        fi

        PM_LINT_EXCEPTION_RULES+=("$rule")
        PM_LINT_EXCEPTION_PATTERNS+=("$pattern")
        PM_LINT_EXCEPTION_OWNERS+=("$owner")
        PM_LINT_EXCEPTION_APPROVED+=("$approved")
        PM_LINT_EXCEPTION_REVIEW+=("$review")
        PM_LINT_EXCEPTION_REASONS+=("$reason")
    done < "$PM_LINT_EXCEPTION_FILE"
}

pm_lint_exception_matches() {
    local rule_id="${1:?rule id required}"
    local path="${2:?path required}"
    local index pattern
    for ((index = 0; index < ${#PM_LINT_EXCEPTION_RULES[@]}; index++)); do
        [[ "${PM_LINT_EXCEPTION_RULES[$index]}" == "$rule_id" ]] || continue
        pattern="${PM_LINT_EXCEPTION_PATTERNS[$index]}"
        # Intentional shell glob matching against a repository-relative path.
        [[ "$path" == $pattern ]] && return 0
    done
    return 1
}

pm_lint_report_internal() {
    local rule_id="${1:?rule id required}"
    local severity="${2:?severity required}"
    local path="${3:?path required}"
    local line="${4:-0}"
    local message="${5:?message required}"
    local suggestion="${6:-}"
    local separator=$'\x1f'

    PM_LINT_FINDINGS+=("${rule_id}${separator}${severity}${separator}${path}${separator}${line}${separator}${message}${separator}${suggestion}")
    case "$severity" in
        ERROR) ((PM_LINT_ERROR_COUNT += 1)) ;;
        WARNING) ((PM_LINT_WARNING_COUNT += 1)) ;;
        GUIDANCE) ((PM_LINT_GUIDANCE_COUNT += 1)) ;;
        REVIEW) ((PM_LINT_REVIEW_COUNT += 1)) ;;
    esac
}

pm_lint_report() {
    local rule_id="${1:?rule id required}"
    local path="${2:?path required}"
    local line="${3:-0}"
    local message="${4:?message required}"
    local suggestion="${5:-}"
    local severity="${PM_LINT_RULE_SEVERITY[$rule_id]:-ERROR}"

    if pm_lint_exception_matches "$rule_id" "$path"; then
        ((PM_LINT_SUPPRESSED_COUNT += 1))
        return 0
    fi
    pm_lint_report_internal "$rule_id" "$severity" "$path" "$line" "$message" "$suggestion"
}

pm_lint_first_line_number() {
    local out_var="${1:?output variable required}"
    local file="${2:?file required}"
    local pattern="${3:?pattern required}"
    local result=""
    result="$(grep -nE "$pattern" "$file" 2>/dev/null | head -n1 | cut -d: -f1 || true)"
    printf -v "$out_var" '%s' "${result:-1}"
}

pm_lint_is_shell_file() {
    local file="${1:?file required}"
    local base="${file##*/}"
    local first=""
    IFS= read -r first < "$file" || true
    case "$file" in
        *.sh|*.bash) return 0 ;;
    esac
    [[ "$first" == '#!/usr/bin/env bash' || "$first" == '#!/bin/bash' ]] && return 0
    if [[ "$base" == pm-* ]] && grep -Eq '^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*[[:space:]]*\(\)[[:space:]]*\{' "$file"; then
        return 0
    fi
    return 1
}

pm_lint_is_env_file() {
    local path="${1:?path required}"
    local base="${path##*/}"
    case "$base" in
        .env|*.env|*.env.*|env.*) return 0 ;;
    esac
    return 1
}

pm_lint_is_operator_env_file() {
    local path="${1:?path required}"
    pm_lint_is_env_file "$path" || return 1
    case "$path" in
        *.example|*.example.*|*.generated|*.generated.*|*/templates/*) return 1 ;;
    esac
    return 0
}

pm_lint_is_compose_file() {
    local path="${1:?path required}"
    local base="${path##*/}"
    case "$base" in
        docker-compose.yml|docker-compose.yaml|docker-compose.*.yml|docker-compose.*.yaml|compose.yml|compose.yaml|compose.*.yml|compose.*.yaml)
            return 0
            ;;
    esac
    return 1
}

pm_lint_file_is_tracked() {
    local path="${1:?path required}"
    if [[ "${PM_LINT_ASSUME_TRACKED:-false}" == true ]]; then
        return 0
    fi
    git -C "$PM_LINT_ROOT" ls-files --error-unmatch -- "$path" >/dev/null 2>&1
}

pm_lint_run_rules() {
    local rule_id function_name path absolute

    for rule_id in "${PM_LINT_RULE_ORDER[@]}"; do
        [[ -z "$PM_LINT_SELECTED_RULE" || "$rule_id" == "$PM_LINT_SELECTED_RULE" ]] || continue
        [[ "${PM_LINT_RULE_SCOPE[$rule_id]}" == project ]] || continue
        function_name="${PM_LINT_RULE_FUNCTION[$rule_id]}"
        "$function_name" "$PM_LINT_ROOT"
    done

    for path in "${PM_LINT_TARGET_FILES[@]}"; do
        pm_lint_absolute_path absolute "$path"
        for rule_id in "${PM_LINT_RULE_ORDER[@]}"; do
            [[ -z "$PM_LINT_SELECTED_RULE" || "$rule_id" == "$PM_LINT_SELECTED_RULE" ]] || continue
            [[ "${PM_LINT_RULE_SCOPE[$rule_id]}" == file ]] || continue
            function_name="${PM_LINT_RULE_FUNCTION[$rule_id]}"
            "$function_name" "$path" "$absolute"
        done
    done
}

pm_lint_json_escape() {
    local value="${1-}"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    value="${value//$'\r'/\\r}"
    value="${value//$'\t'/\\t}"
    printf '%s' "$value" # PM-LINT-MACHINE-OUTPUT
}

pm_lint_output_text() {
    local record rule severity path line message suggestion
    local separator=$'\x1f'
    for record in "${PM_LINT_FINDINGS[@]}"; do
        IFS="$separator" read -r rule severity path line message suggestion <<<"$record"
        printf '%s %s:%s [%s] %s\n' "$severity" "$path" "$line" "$rule" "$message" # PM-LINT-MACHINE-OUTPUT
        if [[ -n "$suggestion" ]]; then
            printf '  guidance: %s\n' "$suggestion" # PM-LINT-MACHINE-OUTPUT
        fi
    done
    # PM-LINT-MACHINE-OUTPUT
    printf 'PM Lint: %d error(s), %d warning(s), %d guidance item(s), %d review item(s), %d suppressed.\n' \
        "$PM_LINT_ERROR_COUNT" "$PM_LINT_WARNING_COUNT" "$PM_LINT_GUIDANCE_COUNT" \
        "$PM_LINT_REVIEW_COUNT" "$PM_LINT_SUPPRESSED_COUNT" # PM-LINT-MACHINE-OUTPUT
}

pm_lint_output_github() {
    local record rule severity path line message suggestion annotation
    local separator=$'\x1f'
    for record in "${PM_LINT_FINDINGS[@]}"; do
        IFS="$separator" read -r rule severity path line message suggestion <<<"$record"
        case "$severity" in
            ERROR) annotation=error ;;
            WARNING) annotation=warning ;;
            GUIDANCE|REVIEW) annotation=notice ;;
        esac
        message="${message//'%'/'%25'}"
        message="${message//$'\r'/'%0D'}"
        message="${message//$'\n'/'%0A'}"
        # PM-LINT-MACHINE-OUTPUT
        printf '::%s file=%s,line=%s,title=%s::%s%s\n' \
            "$annotation" "$path" "$line" "$rule" "$message" \
            "${suggestion:+ Guidance: $suggestion}" # PM-LINT-MACHINE-OUTPUT
    done
    pm_lint_output_text
}

pm_lint_output_json() {
    local record rule severity path line message suggestion comma=""
    local separator=$'\x1f'
    # PM-LINT-MACHINE-OUTPUT
    printf '{"summary":{"errors":%d,"warnings":%d,"guidance":%d,"review":%d,"suppressed":%d},"findings":[' \
        "$PM_LINT_ERROR_COUNT" "$PM_LINT_WARNING_COUNT" "$PM_LINT_GUIDANCE_COUNT" \
        "$PM_LINT_REVIEW_COUNT" "$PM_LINT_SUPPRESSED_COUNT" # PM-LINT-MACHINE-OUTPUT
    for record in "${PM_LINT_FINDINGS[@]}"; do
        IFS="$separator" read -r rule severity path line message suggestion <<<"$record"
        # PM-LINT-MACHINE-OUTPUT
        printf '%s{"rule":"%s","severity":"%s","path":"%s","line":%d,"message":"%s","suggestion":"%s"}' \
            "$comma" "$(pm_lint_json_escape "$rule")" "$(pm_lint_json_escape "$severity")" \
            "$(pm_lint_json_escape "$path")" "${line:-0}" "$(pm_lint_json_escape "$message")" \
            "$(pm_lint_json_escape "$suggestion")" # PM-LINT-MACHINE-OUTPUT
        comma=,
    done
    printf ']}\n' # PM-LINT-MACHINE-OUTPUT
}

pm_lint_output_results() {
    case "$PM_LINT_FORMAT" in
        text) pm_lint_output_text ;;
        github) pm_lint_output_github ;;
        json) pm_lint_output_json ;;
        *) die "pm-lint: unsupported output format: $PM_LINT_FORMAT" 2 ;;
    esac
}

pm_lint_list_rules() {
    local rule_id
    for rule_id in "${PM_LINT_RULE_ORDER[@]}"; do
        # PM-LINT-MACHINE-OUTPUT
        printf '%s\t%s\t%s\t%s\t%s\n' \
            "$rule_id" "${PM_LINT_RULE_SEVERITY[$rule_id]}" \
            "${PM_LINT_RULE_SCOPE[$rule_id]}" "${PM_LINT_RULE_TITLE[$rule_id]}" \
            "${PM_LINT_RULE_REFERENCE[$rule_id]}" # PM-LINT-MACHINE-OUTPUT
    done
}

pm_lint_exit_code() {
    (( PM_LINT_ERROR_COUNT == 0 )) || return 2
    if [[ "$PM_LINT_STRICT" == true ]] && (( PM_LINT_WARNING_COUNT > 0 )); then
        return 2
    fi
    if [[ "$PM_LINT_FAIL_ON_REVIEW" == true ]] && (( PM_LINT_REVIEW_COUNT > 0 )); then
        return 2
    fi
    return 0
}

pm_lint_compose_services_tsv() {
    local file="${1:?compose file required}"

    awk '
        function flush(end_line) {
            if (service != "") {
                printf "%s\t%d\t%d\n", service, start_line, end_line # PM-LINT-MACHINE-OUTPUT
            }
        }

        BEGIN {
            in_services = 0
            service = ""
            start_line = 0
        }

        /^services:[[:space:]]*(#.*)?$/ {
            in_services = 1
            next
        }

        in_services && /^[^[:space:]#]/ {
            flush(NR - 1)
            in_services = 0
            service = ""
        }

        in_services && /^  [A-Za-z0-9_.-]+:[[:space:]]*(#.*)?$/ {
            flush(NR - 1)
            service = $0
            sub(/^  /, "", service)
            sub(/:.*/, "", service)
            start_line = NR
        }

        END {
            if (in_services) {
                flush(NR)
            }
        }
    ' "$file"
}

pm_lint_compose_service_block() {
    local file="${1:?compose file required}"
    local start_line="${2:?start line required}"
    local end_line="${3:?end line required}"
    sed -n "${start_line},${end_line}p" "$file"
}

pm_lint_compose_block_label_value() {
    local out_var="${1:?output variable required}"
    local block="${2-}"
    local label="${3:?label required}"
    local value=""

    value="$(
        awk -v wanted="$label" '
            {
                line=$0
                sub(/^[[:space:]-]*/, "", line)
                if (index(line, wanted ":") == 1) {
                    sub("^[^:]*:[[:space:]]*", "", line)
                    gsub(/^["'\"']|["'\"']$/, "", line)
                    print line
                    exit
                }
                if (index(line, wanted "=") == 1) {
                    sub("^[^=]*=", "", line)
                    gsub(/^["'\"']|["'\"']$/, "", line)
                    print line
                    exit
                }
            }
        ' <<<"$block"
    )"
    printf -v "$out_var" '%s' "$value"
}

pm_lint_portmason_top_level_basename() {
    local out_var="${1:?output variable required}"
    local path="${2:?path required}"
    local remainder=""

    case "$path" in
        ops/portmason/*) remainder="${path#ops/portmason/}" ;;
        portmason/*) remainder="${path#portmason/}" ;;
        *)
            if [[ "${PM_LINT_ROOT##*/}" == portmason ]]; then
                remainder="$path"
            fi
            ;;
    esac
    [[ -n "$remainder" && "$remainder" != */* ]] || return 1
    printf -v "$out_var" '%s' "$remainder"
}
