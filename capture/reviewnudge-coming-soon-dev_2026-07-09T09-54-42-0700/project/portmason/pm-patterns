#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
: "${PORTMASON_SHARE:=$SCRIPT_DIR}"
export PORTMASON_SHARE

# shellcheck disable=SC1091
. "${PORTMASON_SHARE}/pm-helpers" --read-only

pm_patterns_registry() {
    local out_var="${1:?output variable required}"
    local repo_root=""
    repo_root="$(cd -- "${PORTMASON_SHARE}/../.." && pwd -P)"
    printf -v "$out_var" '%s' "${PM_PATTERN_REGISTRY:-${repo_root}/sops/patterns/portmason-patterns.json}"
}

pm_patterns_require_runtime() {
    have jq || die "pm-patterns requires jq" 2
}

pm_patterns_validate() {
    local registry="${1:?registry required}"
    jq -e '
      .schemaVersion == "1.0"
      and (.patterns | type == "array" and length > 0)
      and ([.patterns[].id] | length == (unique | length))
      and all(.patterns[];
        (.id | test("^PM-PAT-[0-9]{3}$"))
        and (.name | type == "string" and length > 0)
        and (.status == "canonical" or .status == "candidate" or .status == "deprecated")
        and (.category | type == "string" and length > 0)
        and (.requirement | type == "string" and length > 20)
        and (.appliesTo | type == "array" and length > 0)
        and (.authority | type == "array" and length > 0)
        and (.enforcement | type == "object")
      )
    ' "$registry" >/dev/null
    log INFO "pm-patterns: registry valid" "file=$registry" \
        "patterns=$(jq '.patterns | length' "$registry")"
}

pm_patterns_usage() {
    cat <<'USAGE'
Usage:
  pm-patterns list [STATUS]
  pm-patterns search QUERY
  pm-patterns show PM-PAT-###
  pm-patterns validate
  pm-patterns path
USAGE
}

main() {
    pm_patterns_require_runtime
    local registry="" command_name="${1:-list}"
    pm_patterns_registry registry
    [[ -r "$registry" ]] || die "pm-patterns registry not readable: $registry" 2

    case "$command_name" in
        list)
            local status="${2:-}"
            jq -r --arg status "$status" '
              .patterns[]
              | select($status == "" or .status == $status)
              | [.id, .status, .category, .name] | @tsv
            ' "$registry"
            ;;
        search)
            [[ $# -ge 2 ]] || die "pm-patterns search requires a query" 2
            local query="${*:2}"
            jq -r --arg q "${query,,}" '
              .patterns[]
              | select((([.id,.name,.category,.requirement] | join(" ") | ascii_downcase) | contains($q)))
              | [.id, .status, .category, .name] | @tsv
            ' "$registry"
            ;;
        show)
            [[ $# -eq 2 ]] || die "pm-patterns show requires one pattern id" 2
            jq -e --arg id "$2" '.patterns[] | select(.id == $id)' "$registry" \
                || die "unknown Portmason pattern: $2" 2
            ;;
        validate)
            pm_patterns_validate "$registry"
            ;;
        path)
            printf '%s\n' "$registry" # PM-LINT-MACHINE-OUTPUT
            ;;
        -h|--help|help)
            pm_patterns_usage
            ;;
        *)
            pm_patterns_usage >&2
            die "unknown pm-patterns command: $command_name" 2
            ;;
    esac
}

main "$@"
