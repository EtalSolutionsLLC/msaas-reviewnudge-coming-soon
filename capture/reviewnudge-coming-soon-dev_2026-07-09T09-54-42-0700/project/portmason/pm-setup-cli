#!/usr/bin/env bash
set -euo pipefail

# Runtime setup: cli
# Validates CLI entrypoint conventions and provides a "run" action if desired.

script_name="$(basename "${BASH_SOURCE[0]}")"

if [[ -n "${PORTMASON_SHARE:-}" && -f "${PORTMASON_SHARE}/pm-helpers" ]]; then
  # shellcheck disable=SC1090
  source "${PORTMASON_SHARE}/pm-helpers" "$@"
fi

# Load adapter first (per your doctrine: adapter before runtime)
# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/pm-helpers-venv"

# Then runtime
# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/pm-helpers-cli"

log "pm-setup-cli begin (PROJECT_DIR=${PROJECT_DIR:-$PWD})"

# Ensure adapter is ready (venv + deps)
ensure_venv_created
pip_install_if_needed

# Validate entrypoint choice
if [[ -n "${CLI_ENTRYPOINT_MODULE:-}" ]]; then
  log "CLI module entrypoint configured: ${CLI_ENTRYPOINT_MODULE}"
elif [[ -n "${CLI_ENTRYPOINT_FILE:-}" ]]; then
  if [[ -f "${CLI_ENTRYPOINT_FILE}" ]]; then
    log "CLI file entrypoint configured: ${CLI_ENTRYPOINT_FILE}"
  else
    die "CLI entrypoint file not found: ${CLI_ENTRYPOINT_FILE} (set CLI_ENTRYPOINT_FILE or CLI_ENTRYPOINT_MODULE)"
  fi
else
  die "No CLI entrypoint configured. Set CLI_ENTRYPOINT_FILE or CLI_ENTRYPOINT_MODULE."
fi

# Optional: support 'run' as a convenience
ACTION="${1:-${ACTION:-setup}}"
shift || true

case "${ACTION}" in
  setup)
    log "Setup complete."
    ;;
  run)
    if [[ -n "${CLI_ENTRYPOINT_MODULE:-}" ]]; then
      log "Running: python -m ${CLI_ENTRYPOINT_MODULE} ${CLI_DEFAULT_ARGS} $*"
      # shellcheck disable=SC2086
      venv_run_module "${CLI_ENTRYPOINT_MODULE}" ${CLI_DEFAULT_ARGS} "$@"
    else
      log "Running: python ${CLI_ENTRYPOINT_FILE} ${CLI_DEFAULT_ARGS} $*"
      # shellcheck disable=SC2086
      venv_run_script "${CLI_ENTRYPOINT_FILE}" ${CLI_DEFAULT_ARGS} "$@"
    fi
    ;;
  *)
    die "Unknown ACTION: ${ACTION}. Supported: setup | run"
    ;;
esac

log "pm-setup-cli end"
