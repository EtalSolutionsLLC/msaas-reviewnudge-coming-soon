#!/usr/bin/env bash
set -euo pipefail
pm_config_messaging() {
    local scopes='messaging,web,app,jobs,worker'
    pm_config_register MESSAGE_TRANSPORT var "$scopes" MESSAGE_TRANSPORT optional
    pm_config_register BULKEMAILER_PROVIDER var "$scopes" BULKEMAILER_PROVIDER optional
    pm_config_register BULKEMAILER_API_KEY secret "$scopes" BULKEMAILER_API_KEY optional
    pm_config_register SMTP_HOST var "$scopes" SMTP_HOST optional
    pm_config_register SMTP_PORT var "$scopes" SMTP_PORT optional
    pm_config_register SMTP_USER var "$scopes" SMTP_USER optional
    pm_config_register SMTP_PASS secret "$scopes" SMTP_PASS optional
    pm_config_register QUEUE_HOST var "$scopes" QUEUE_HOST optional
    pm_config_register QUEUE_PORT var "$scopes" QUEUE_PORT optional
    pm_config_register QUEUE_USER secret "$scopes" QUEUE_USER optional
    pm_config_register QUEUE_PASSWORD secret "$scopes" QUEUE_PASSWORD optional
}
