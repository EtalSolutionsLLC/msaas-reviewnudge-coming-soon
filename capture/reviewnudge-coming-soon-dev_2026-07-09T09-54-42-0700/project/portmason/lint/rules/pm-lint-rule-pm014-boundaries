#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm014() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local base="${path##*/}"

    case "$base" in
        pm-bridge-*|pm-db-bridge-*|pm-config-manager|pm-setup) return 0 ;;
        pm-config-*|pm-provision-*|pm-deploy-*|pm-setup-*) ;;
        *) return 0 ;;
    esac

    if grep -q 'RUNTIME_CODE' "$file" && grep -q 'ADAPTER_CODE' "$file"; then
        pm_lint_report PM014 "$path" 1 \
            "Non-bridge phase module references both runtime and adapter selectors" \
            "Review whether pair-specific translation belongs in pm-bridge-<runtime>-<adapter>."
    fi
    if grep -q 'DB_PROVIDER' "$file" && grep -q 'DB_PLATFORM' "$file"; then
        pm_lint_report PM014 "$path" 1 \
            "Non-bridge phase module references both database provider and platform selectors" \
            "Review whether pair-specific translation belongs in pm-db-bridge-<provider>-<platform>."
    fi
}

pm_lint_register_rule PM014 GUIDANCE file \
    "Entity and bridge ownership boundaries" \
    "EPC A4; EPC A12.2-A12.3; EPC C5.3-C5.4" \
    pm_lint_rule_pm014
