#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm013() {
    local root="${1:?root required}"

    if [[ ! -f "$root/README.md" && ! -f "$root/readme.md" ]]; then
        pm_lint_report PM013 "." 1 \
            "Repository has no README.md" \
            "Document purpose, local bootstrap, tests, and deployment or link to the governing runbook."
    fi

    if ! find "$root" -type f \( -path '*/tests/*' -o -name '*.test.sh' -o -name '*.test.js' -o -name '*.test.mjs' -o -name '*.spec.js' -o -name '*.spec.ts' \) -print -quit 2>/dev/null | grep -q .; then
        pm_lint_report PM013 "." 1 \
            "Repository has no detectable automated test" \
            "Add at least one CI-executable smoke test for the core flow."
    fi

    if [[ ! -d "$root/.github/workflows" && ! -f "$root/.gitlab-ci.yml" ]]; then
        pm_lint_report PM013 "." 1 \
            "Repository has no detectable CI definition" \
            "Run tests on every push to main and every pull request targeting main."
    fi
}

pm_lint_register_rule PM013 WARNING project \
    "Repository documentation, tests, and CI" \
    "TGF Testing & CI Policy; EPC A10" \
    pm_lint_rule_pm013
