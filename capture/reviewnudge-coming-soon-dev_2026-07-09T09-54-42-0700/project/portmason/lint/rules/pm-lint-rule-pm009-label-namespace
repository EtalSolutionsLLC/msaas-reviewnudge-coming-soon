#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm009() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local record line_no

    [[ "${path##*/}" == pm-lint-rule-pm009-label-namespace ]] && return 0

    while IFS= read -r record; do
        [[ -n "$record" ]] || continue
        line_no="${record%%:*}"
        pm_lint_report PM009 "$path" "$line_no" \
            "Deprecated com.etalsolutions.* label namespace is present" \
            "Migrate the label to the solutions.etal.* EPC namespace."
    done < <(grep -nF 'com.etalsolutions.' "$file" || true)
}

pm_lint_register_rule PM009 ERROR file \
    "EPC label namespace" \
    "EPC A2.8" \
    pm_lint_rule_pm009
