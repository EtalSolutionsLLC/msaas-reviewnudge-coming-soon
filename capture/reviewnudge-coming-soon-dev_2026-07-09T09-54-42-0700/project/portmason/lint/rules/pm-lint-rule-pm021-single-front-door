#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm021() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local service start_line end_line block role="" relative_line="" line=""

    pm_lint_is_compose_file "$path" || return 0

    while IFS=$'\t' read -r service start_line end_line; do
        [[ -n "$service" ]] || continue
        block="$(pm_lint_compose_service_block "$file" "$start_line" "$end_line")"
        role=""
        pm_lint_compose_block_label_value role "$block" solutions.etal.service
        case "$role" in
            api|web) ;;
            *) continue ;;
        esac
        relative_line="$(grep -nE '^[[:space:]]*ports[[:space:]]*:' <<<"$block" | head -n1 | cut -d: -f1 || true)"
        [[ -n "$relative_line" ]] || continue
        line=$((start_line + relative_line - 1))
        pm_lint_report PM021 "$path" "$line" \
            "HTTP service '$service' publishes a host port outside the shared ingress" \
            "Remove the host port mapping and route the service through the stack's single front door."
    done < <(pm_lint_compose_services_tsv "$file")
}

pm_lint_register_rule PM021 ERROR file \
    "Single front door" \
    "EPC A2.4; EPC A3" \
    pm_lint_rule_pm021
