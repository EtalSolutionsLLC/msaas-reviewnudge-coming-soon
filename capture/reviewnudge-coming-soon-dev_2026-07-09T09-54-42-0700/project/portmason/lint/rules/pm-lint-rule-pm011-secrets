#!/usr/bin/env bash
set -euo pipefail

pm_lint_secret_value_is_placeholder() {
    local value="${1-}"
    value="${value%\"}"; value="${value#\"}"
    value="${value%\'}"; value="${value#\'}"
    [[ -z "$value" ]] && return 0
    case "${value,,}" in
        *replace*|*changeme*|*change-me*|*example*|*placeholder*|*redacted*|*your-*|'<secret>'|'***') return 0 ;;
    esac
    [[ "$value" == '${'*'}' ]] && return 0
    return 1
}

pm_lint_rule_pm011() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local record line_no content key value

    if pm_lint_is_env_file "$path"; then
        pm_lint_file_is_tracked "$path" || return 0
        while IFS= read -r record; do
            line_no="${record%%:*}"
            content="${record#*:}"
            key="${content%%=*}"
            key="${key#export }"
            value="${content#*=}"
            pm_lint_secret_value_is_placeholder "$value" && continue
            pm_lint_report PM011 "$path" "$line_no" \
                "Tracked environment file contains a non-placeholder value for secret-like key $key" \
                "Remove the value from version control and provide it through PM Configuration Manager or the platform secret store."
        done < <(grep -nE '^[[:space:]]*(export[[:space:]]+)?([A-Z][A-Z0-9_]*(PASSWORD|PASS|TOKEN|SECRET|API_KEY|PRIVATE_KEY)[A-Z0-9_]*|DB_USER|DB_ADMIN_USER|QUEUE_USER|DATABASE_URL|DATABASE_DIRECT_URL)[[:space:]]*=' "$file" || true)
    fi

    if pm_lint_is_compose_file "$path"; then
        while IFS= read -r record; do
            line_no="${record%%:*}"
            content="${record#*:}"
            value="${content#*:}"
            value="${value#*=}"
            [[ "$content" == *'${'* ]] && continue
            pm_lint_secret_value_is_placeholder "$value" && continue
            pm_lint_report PM011 "$path" "$line_no" \
                "Compose file appears to contain a literal secret value" \
                "Reference an injected variable or generated service-scoped env file instead of embedding the secret."
        done < <(grep -nE '^[[:space:]-]*([A-Z][A-Z0-9_]*(PASSWORD|PASS|TOKEN|SECRET|API_KEY|PRIVATE_KEY)[A-Z0-9_]*|DB_USER|DB_ADMIN_USER|QUEUE_USER|DATABASE_URL|DATABASE_DIRECT_URL)[[:space:]]*[:=]' "$file" || true)
    fi
}

pm_lint_register_rule PM011 ERROR file \
    "Secrets are not committed" \
    "TGF Configuration & Secrets; EPC A2.3" \
    pm_lint_rule_pm011
