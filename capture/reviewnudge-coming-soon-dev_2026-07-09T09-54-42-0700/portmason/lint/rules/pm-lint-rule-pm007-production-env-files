#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm007() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local base="${path##*/}"
    local definite=false record line_no

    case "${path,,}" in
        *prod*|*prd*|*qas*|*pse*|*/.github/workflows/*) definite=true ;;
    esac
    case "$base" in
        pm-deploy-gcp|pm-deploy-aws|pm-deploy-azure|pm-deploy-github|pm-provision-gcp|pm-provision-aws|pm-provision-azure)
            definite=true
            ;;
    esac
    [[ "$definite" == true ]] || return 0

    record="$(grep -nE -- '--env-file([[:space:]=]|$)|^[[:space:]]*env_file[[:space:]]*:' "$file" | head -n1 || true)"
    [[ -n "$record" ]] || return 0
    line_no="${record%%:*}"
    pm_lint_report PM007 "$path" "$line_no" \
        "Production or remote-runtime flow consumes an env file directly" \
        "Use operator-side env files only to prime the platform; inject runtime variables and secrets through native platform controls."
}

pm_lint_register_rule PM007 ERROR file \
    "No runtime env files in production" \
    "TGF Production Rules; EPC A2.2; EPC A3" \
    pm_lint_rule_pm007
