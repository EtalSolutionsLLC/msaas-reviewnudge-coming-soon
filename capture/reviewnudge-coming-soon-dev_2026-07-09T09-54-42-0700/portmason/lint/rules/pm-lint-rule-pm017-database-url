#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm017() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local record line_no key

    pm_lint_is_operator_env_file "$path" || return 0
    while IFS= read -r record; do
        [[ -n "$record" ]] || continue
        line_no="${record%%:*}"
        key="${record#*:}"
        key="${key%%=*}"
        key="${key#export }"
        pm_lint_report PM017 "$path" "$line_no" \
            "$key is a derived connection output, not an operator-authored source of truth" \
            "Provide the canonical seven-value database contract and let the provider/platform modules derive connection strings."
    done < <(grep -nE '^[[:space:]]*(export[[:space:]]+)?DATABASE(_DIRECT)?_URL[[:space:]]*=' "$file" || true)
}

pm_lint_register_rule PM017 ERROR file \
    "Derived database connection strings" \
    "TGF Canonical Database Contract; EPC C5.2" \
    pm_lint_rule_pm017
