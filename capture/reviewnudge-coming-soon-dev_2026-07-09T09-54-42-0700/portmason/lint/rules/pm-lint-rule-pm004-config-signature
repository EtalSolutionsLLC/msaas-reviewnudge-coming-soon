#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm004() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local base="" entity expected

    pm_lint_portmason_top_level_basename base "$path" || return 0
    [[ "$base" == pm-config-* ]] || return 0
    [[ "$base" != pm-config-manager ]] || return 0
    entity="${base#pm-config-}"
    expected="pm_config_${entity//-/_}"

    if ! grep -Eq "^[[:space:]]*${expected}[[:space:]]*\\(\\)[[:space:]]*\\{" "$file"; then
        pm_lint_report PM004 "$path" 1 \
            "$base must define ${expected}()" \
            "Expose the canonical entity configuration entrypoint so pm-config-manager can discover it without pair-specific branching."
    fi
}

pm_lint_register_rule PM004 ERROR file \
    "Configuration module signature" \
    "EPC A4; EPC A12.5; PM Configuration Manager contract" \
    pm_lint_rule_pm004
