#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm022() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local service start_line end_line block role=""

    pm_lint_is_compose_file "$path" || return 0

    while IFS=$'\t' read -r service start_line end_line; do
        [[ -n "$service" ]] || continue
        block="$(pm_lint_compose_service_block "$file" "$start_line" "$end_line")"
        role=""
        pm_lint_compose_block_label_value role "$block" solutions.etal.service
        case "$role" in
            api|web) ;;
            *) continue ;;
        esac
        grep -Eq 'traefik\.enable[=:][[:space:]]*"?true"?' <<<"$block" && continue
        pm_lint_report PM022 "$path" "$start_line" \
            "HTTP service '$service' has no explicit Traefik enablement" \
            "For local Compose ingress, add Traefik routing labels and reference the container's internal listening port."
    done < <(pm_lint_compose_services_tsv "$file")
}

pm_lint_register_rule PM022 GUIDANCE file \
    "Traefik routing evidence" \
    "TGF Local Development; EPC A2.4" \
    pm_lint_rule_pm022
