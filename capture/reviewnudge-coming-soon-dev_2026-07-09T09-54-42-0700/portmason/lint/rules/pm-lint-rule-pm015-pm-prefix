#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm015() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local record line_no content key replacement

    pm_lint_is_operator_env_file "$path" || return 0

    while IFS= read -r record; do
        line_no="${record%%:*}"
        content="${record#*:}"
        key="${content%%=*}"
        key="${key#export }"
        case "$key" in
            SUPPORT_CHANNEL_*) replacement="PM_${key}" ;;
            ACME_DNS_PROVIDER) replacement="PM_ACME_DNS_PROVIDER" ;;
            ACME_EMAIL) replacement="PM_ACME_EMAIL" ;;
            GODADDY_API_KEY) replacement="PM_ACME_DNS_API_KEY" ;;
            GODADDY_API_SECRET) replacement="PM_ACME_DNS_API_SECRET" ;;
            GODADDY_TTL) replacement="PM_ACME_DNS_TTL" ;;
            GODADDY_PROPAGATION_TIMEOUT) replacement="PM_ACME_DNS_PROPAGATION_TIMEOUT" ;;
            GODADDY_POLLING_INTERVAL) replacement="PM_ACME_DNS_POLLING_INTERVAL" ;;
            PM_NETWORK_TUNNEL_PROVIDER) replacement="PM_EDGE_TUNNEL_PROVIDER" ;;
            PM_NETWORK_TUNNEL_TOKEN) replacement="PM_EDGE_TUNNEL_TOKEN" ;;
            PM_NETWORK_TUNNEL_LOG_LEVEL) replacement="PM_EDGE_TUNNEL_LOG_LEVEL" ;;
            PM_NETWORK_TUNNEL_LOG_FILE) replacement="PM_EDGE_TUNNEL_LOG_FILE" ;;
            PM_NETWORK_TUNNEL_NO_AUTOUPDATE) replacement="PM_EDGE_TUNNEL_NO_AUTOUPDATE" ;;
            TUNNEL_TOKEN|TUNNEL_LOGLEVEL|TUNNEL_LOGFILE|NO_AUTOUPDATE)
                replacement="the corresponding PM_EDGE_TUNNEL_* source key"
                ;;
            *) continue ;;
        esac
        pm_lint_report PM015 "$path" "$line_no" \
            "$key is a legacy or provider-native configuration authority" \
            "Use $replacement; PM Configuration Manager maps canonical PM_ inputs to provider-native outputs."
    done < <(grep -nE '^[[:space:]]*(export[[:space:]]+)?[A-Z][A-Z0-9_]*[[:space:]]*=' "$file" || true)
}

pm_lint_register_rule PM015 ERROR file \
    "Portmason-owned PM_ configuration namespace" \
    "TGF Tooling Discipline; EPC Configuration contract; Portmason branding convention" \
    pm_lint_rule_pm015
