#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm023() {
    local root="${1:?root required}"
    local uses_portmason=0 navigation_file="" relative="" line="1"

    if grep -qsE 'RUNTIME_ADAPTER_CODE|solutions\.etal\.' \
        "$root/.env" "$root/.env.example" "$root/docker-compose.yml" "$root/compose.yml"; then
        uses_portmason=1
    fi
    (( uses_portmason == 1 )) || return 0

    if grep -RIlE 'pm-viewport-navigation(\.js)?|PortmasonViewportNavigation' "$root" \
        --include='*.html' --include='*.js' --include='*.mjs' \
        --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=vendor \
        --exclude-dir=dist --exclude-dir=build --exclude-dir=.portmason \
        2>/dev/null | grep -q .; then
        return 0
    fi

    navigation_file="$(
        grep -RIlE 'scrollIntoView[[:space:]]*\(|window\.scrollTo[[:space:]]*\(|hashchange|popstate|location\.hash' "$root" \
            --include='*.html' --include='*.js' --include='*.mjs' \
            --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=vendor \
            --exclude-dir=dist --exclude-dir=build --exclude-dir=.portmason \
            2>/dev/null | head -n1 || true
    )"
    [[ -n "$navigation_file" ]] || return 0

    relative="${navigation_file#${root}/}"
    line="$(grep -nE 'scrollIntoView[[:space:]]*\(|window\.scrollTo[[:space:]]*\(|hashchange|popstate|location\.hash' "$navigation_file" 2>/dev/null | head -n1 | cut -d: -f1 || printf 1)"
    pm_lint_report PM023 "$relative" "$line" \
        "Project-local hash or viewport navigation exists without the canonical Portmason viewport capability" \
        "Run 'pm-capabilities search navigation' and use pm-viewport-navigation.js unless a documented, dated exception proves the shared contract is unsuitable."
}

pm_lint_register_rule PM023 REVIEW project \
    "Reuse canonical viewport navigation" \
    "TGF Pattern Governance; EPC A2.10; PM-PAT-001; PM-PAT-008" \
    pm_lint_rule_pm023
