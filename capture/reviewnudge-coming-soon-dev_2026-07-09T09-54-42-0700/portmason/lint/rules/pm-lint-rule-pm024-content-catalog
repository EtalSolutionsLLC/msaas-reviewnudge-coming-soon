#!/usr/bin/env bash
set -euo pipefail

pm_lint_rule_pm024() {
    local path="${1:?path required}"
    local file="${2:?file required}"
    local count=0 line=1

    case "$path" in
        index.html|*/index.html|www/*.html|www/**/*.html|public/*.html|public/**/*.html) ;;
        *) return 0 ;;
    esac

    grep -Eq 'data-(content-key|i18n)|content/[A-Za-z0-9_-]+/[A-Za-z0-9_.-]+\.json|assets/content\.js|content\.js' "$file" \
        && return 0

    count="$(
        grep -Eio '<(h1|h2|h3|p|button|label|a)([^>]*)>[^<{][^<]{8,}</(h1|h2|h3|p|button|label|a)>' "$file" 2>/dev/null \
            | wc -l | tr -d ' '
    )"
    [[ "$count" =~ ^[0-9]+$ ]] || count=0
    (( count >= 3 )) || return 0

    line="$(grep -nEi '<(h1|h2|h3|p|button|label|a)([^>]*)>[^<{][^<]{8,}</(h1|h2|h3|p|button|label|a)>' "$file" 2>/dev/null | head -n1 | cut -d: -f1 || printf 1)"
    pm_lint_report PM024 "$path" "$line" \
        "Visitor-facing copy appears to be embedded directly in structural HTML" \
        "Move product and marketing language into locale-specific JSON catalogs; keep HTML focused on structure, stable content keys, accessibility fallbacks, and required metadata."
}

pm_lint_register_rule PM024 GUIDANCE file \
    "Visitor-facing copy catalog" \
    "TGF Communications Standards; EPC A2.7; PM-PAT-007" \
    pm_lint_rule_pm024
