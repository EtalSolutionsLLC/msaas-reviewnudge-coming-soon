#!/usr/bin/env bash
set -euo pipefail

# Replace PM900, title, policy reference, matcher, message, and guidance.

pm_lint_rule_pm900() {
    local path="${1:?path required}"
    local file="${2:?file required}"

    # Return when the rule does not apply.
    [[ "$path" == *.example ]] || return 0

    if grep -q 'disallowed-pattern' "$file"; then
        pm_lint_report PM900 "$path" 1 \
            "Describe the violated known convention" \
            "Describe the canonical correction or review path."
    fi
}

pm_lint_register_rule PM900 GUIDANCE file \
    "Concise rule title" \
    "TGF section; EPC section" \
    pm_lint_rule_pm900
