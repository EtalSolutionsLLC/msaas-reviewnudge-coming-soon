#!/usr/bin/env bash
set -euo pipefail

pm_config_neon() {
    if ! declare -F neon_load_api_key >/dev/null 2>&1; then
        # shellcheck disable=SC1090
        . "${PORTMASON_SHARE}/pm-helpers-neon"
    fi
    # DB_API_KEY is registered by the control-plane contract. Neon-specific
    # identifiers remain operator/platform context and are never runtime vars.
}
