#!/usr/bin/env bash
set -euo pipefail

: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
. "${PORTMASON_SHARE}/pm-helpers" "$@"

: "${ENV_FILE:?ENV_FILE is required}"
: "${SITE_DIR:?SITE_DIR is required}"

mkdir -p "$(dirname "${ENV_FILE}.generated")"
mkdir -p "${SITE_DIR}"

"${PORTMASON_SHARE}/pm-util-render-env" \
  --dotenv \
  --out "${ENV_FILE}.generated" \
  "${ENV_FILE}"

# Production public hosts intentionally omit DEPLOY_ENV. Persist the canonical
# identity into generated configuration so later force-loads and Compose see the
# same host even when the source .env contains a suffixed value.
persist_public_host_identity "${ENV_FILE}.generated"

"${PORTMASON_SHARE}/pm-util-render-env" \
  --json \
  --out "${SITE_DIR}/config.generated.json" \
  "${ENV_FILE}.generated"
