#!/usr/bin/env bash
# pm-health-node: Node runtime health adapter
# shellcheck shell=bash

set -euo pipefail

cmd="${1:-}"
case "$cmd" in
  compose-test-json)
    # Uses Node runtime; no curl/wget dependency.
    printf '["CMD", "node", "/opt/portmason/health/node-healthcheck.mjs"]\n'
    ;;
  dockerfile-copy-line)
    printf 'COPY portmason/templates/health/node-healthcheck.mjs /opt/portmason/health/node-healthcheck.mjs\n'
    ;;
  *)
    printf 'pm-health-node: unsupported command: %s\n' "$cmd" >&2
    exit 2
    ;;
esac
