#!/usr/bin/env bash
set -euo pipefail

: "${PORTMASON_SHARE:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)}"
if ! declare -F log >/dev/null 2>&1; then
    . "${PORTMASON_SHARE}/pm-helpers" "$@"
fi
if ! declare -F pm_neon_api_request >/dev/null 2>&1; then
    . "${PORTMASON_SHARE}/pm-helpers-neon"
fi
if ! declare -F pm_db_postgres_build_url >/dev/null 2>&1; then
    . "${PORTMASON_SHARE}/pm-helpers-postgres"
fi

: "${POSTGRES_TOOL_IMAGE:=postgres:17-alpine}"
: "${DB_CONNECT_TIMEOUT_SECONDS:=20}"
export POSTGRES_TOOL_IMAGE DB_CONNECT_TIMEOUT_SECONDS

pm_db_bridge_preflight() {
    [[ "${DB_PROVIDER:-}" == postgres && "${DB_PLATFORM:-}" == neon ]] || return 0
    have docker || pm_preflight_error "database.bridge.postgres-neon" "docker" \
        "Docker is required for containerized PostgreSQL administration and migrations"
}

pm_neon_discover_admin_identity() {
    local roles databases selected
    pm_neon_api_request roles GET \
        "/projects/${NEON_PROJECT_ID}/branches/${NEON_BRANCH_ID}/roles"
    pm_neon_api_request databases GET \
        "/projects/${NEON_PROJECT_ID}/branches/${NEON_BRANCH_ID}/databases"

    if [[ -n "${NEON_ADMIN_ROLE:-}" ]]; then
        jq -e --arg name "$NEON_ADMIN_ROLE" \
            'any(.roles[]?; .name == $name)' >/dev/null <<<"$roles" \
            || die "pm-db-bridge-postgres-neon: configured NEON_ADMIN_ROLE does not exist: $NEON_ADMIN_ROLE" 2
    else
        selected="$(jq -r '
            ([.roles[]? | select(.name == "neondb_owner")][0].name)
            // ([.roles[]? | select((.protected // false) == true)][0].name)
            // .roles[0].name // empty' <<<"$roles")"
        [[ -n "$selected" ]] \
            || die "pm-db-bridge-postgres-neon: no administrative Neon role was discovered" 2
        NEON_ADMIN_ROLE="$selected"
    fi

    if [[ -n "${NEON_ADMIN_DATABASE:-}" ]]; then
        jq -e --arg name "$NEON_ADMIN_DATABASE" \
            'any(.databases[]?; .name == $name)' >/dev/null <<<"$databases" \
            || die "pm-db-bridge-postgres-neon: configured NEON_ADMIN_DATABASE does not exist: $NEON_ADMIN_DATABASE" 2
    else
        selected="$(jq -r --arg owner "$NEON_ADMIN_ROLE" '
            ([.databases[]? | select(.name == "neondb")][0].name)
            // ([.databases[]? | select(.owner_name == $owner)][0].name)
            // .databases[0].name // empty' <<<"$databases")"
        [[ -n "$selected" ]] \
            || die "pm-db-bridge-postgres-neon: no administrative Neon database was discovered" 2
        NEON_ADMIN_DATABASE="$selected"
    fi

    export NEON_ADMIN_ROLE NEON_ADMIN_DATABASE
    log INFO "pm-db-bridge-postgres-neon: discovered administrative identity" \
        "role=$NEON_ADMIN_ROLE" "database=$NEON_ADMIN_DATABASE"
}

pm_neon_hydrate_application_secret() {
    local key="${1:?key required}"
    [[ -n "${!key:-}" ]] && return 0
    if [[ "${ADAPTER_CODE:-}" == gcp ]] \
        && declare -F pm_gcp_get_secret_value >/dev/null 2>&1; then
        local value=""
        if pm_gcp_get_secret_value value "$key"; then
            printf -v "$key" '%s' "$value"
            export "$key"
            log INFO "pm-db-bridge-postgres-neon: loaded application secret from GCP Secret Manager" \
                "key=$key"
        fi
    fi
    [[ -n "${!key:-}" ]] \
        || die "pm-db-bridge-postgres-neon: $key is required or must resolve through SECRET_PATHS" 2
}

pm_neon_prepare_connection_contract() {
    local admin_direct_uri admin_pooled_uri
    local NEON_ADMIN_DIRECT_HOST NEON_ADMIN_DIRECT_PORT NEON_ADMIN_DIRECT_USER
    local NEON_ADMIN_DIRECT_PASSWORD NEON_ADMIN_DIRECT_DATABASE
    local NEON_ADMIN_POOLED_HOST NEON_ADMIN_POOLED_PORT NEON_ADMIN_POOLED_USER
    local NEON_ADMIN_POOLED_PASSWORD NEON_ADMIN_POOLED_DATABASE

    pm_neon_hydrate_application_secret DB_USER
    pm_neon_hydrate_application_secret DB_PASSWORD
    pm_neon_discover_admin_identity
    pm_neon_connection_uri admin_direct_uri "$NEON_ADMIN_ROLE" "$NEON_ADMIN_DATABASE" false
    pm_neon_connection_uri admin_pooled_uri "$NEON_ADMIN_ROLE" "$NEON_ADMIN_DATABASE" true

    pm_db_postgres_parse_url_into NEON_ADMIN_DIRECT "$admin_direct_uri" \
        || die "pm-db-bridge-postgres-neon: unable to parse direct administrative connection URI" 2
    pm_db_postgres_parse_url_into NEON_ADMIN_POOLED "$admin_pooled_uri" \
        || die "pm-db-bridge-postgres-neon: unable to parse pooled administrative connection URI" 2

    DB_ADMIN_USER="$NEON_ADMIN_DIRECT_USER"
    DB_ADMIN_PASSWORD="$NEON_ADMIN_DIRECT_PASSWORD"
    DB_ADMIN_DATABASE="$NEON_ADMIN_DIRECT_DATABASE"
    NEON_DIRECT_HOST="$NEON_ADMIN_DIRECT_HOST"
    NEON_POOLED_HOST="$NEON_ADMIN_POOLED_HOST"
    DB_PORT="$NEON_ADMIN_DIRECT_PORT"
    DATABASE_SSL_MODE=require

    pm_db_postgres_build_url DATABASE_DIRECT_URL \
        "$NEON_DIRECT_HOST" "$DB_PORT" "$DB_NAME" "$DB_USER" "$DB_PASSWORD" require
    pm_db_postgres_build_url DATABASE_URL \
        "$NEON_POOLED_HOST" "$DB_PORT" "$DB_NAME" "$DB_USER" "$DB_PASSWORD" require

    case "$NEON_USE_POOLER" in
        1|true|TRUE|yes|YES|on|ON) DB_HOST="$NEON_POOLED_HOST" ;;
        0|false|FALSE|no|NO|off|OFF)
            DB_HOST="$NEON_DIRECT_HOST"
            DATABASE_URL="$DATABASE_DIRECT_URL"
            ;;
        *) die "pm-db-bridge-postgres-neon: NEON_USE_POOLER must be boolean" 2 ;;
    esac

    export DB_ADMIN_USER DB_ADMIN_PASSWORD DB_ADMIN_DATABASE
    export NEON_DIRECT_HOST NEON_POOLED_HOST DB_HOST DB_PORT DATABASE_SSL_MODE
    export DATABASE_URL DATABASE_DIRECT_URL

    log INFO "pm-db-bridge-postgres-neon: prepared canonical connection contract" \
        "application_host=$DB_HOST" "direct_host=$NEON_DIRECT_HOST" \
        "port=$DB_PORT" "database=$DB_NAME" \
        "mode=$([[ "$DB_HOST" == "$NEON_POOLED_HOST" ]] && printf pooled || printf direct)"
}

db_rt() {
    local user="${PM_DB_RT_USER:-${DB_USER:?DB_USER required}}"
    local password="${PM_DB_RT_PASSWORD:-${DB_PASSWORD:?DB_PASSWORD required}}"
    local database="${PM_DB_RT_DATABASE:-${DB_NAME:?DB_NAME required}}"
    local host="${NEON_DIRECT_HOST:?NEON_DIRECT_HOST required}"
    local port="${DB_PORT:-5432}"

    log DEBUG "pm-db-bridge-postgres-neon: executing PostgreSQL command" \
        "host=$host" "port=$port" "database=$database" "user=$user" \
        "image=$POSTGRES_TOOL_IMAGE"

    PGHOST="$host" PGPORT="$port" PGDATABASE="$database" PGUSER="$user" \
    PGPASSWORD="$password" PGSSLMODE=require \
    PM_DB_SQL_SECRET="${PM_DB_SQL_SECRET:-}" \
        docker run --rm -i \
            --env PGHOST --env PGPORT --env PGDATABASE --env PGUSER \
            --env PGPASSWORD --env PGSSLMODE --env PM_DB_SQL_SECRET \
            --env PGCONNECT_TIMEOUT="$DB_CONNECT_TIMEOUT_SECONDS" \
            "$POSTGRES_TOOL_IMAGE" psql --no-psqlrc --set ON_ERROR_STOP=1 "$@"
}

pm_db_bridge_provision() {
    [[ "${DB_PROVIDER:-}" == postgres && "${DB_PLATFORM:-}" == neon ]] \
        || die "pm-db-bridge-postgres-neon requires postgres-neon" 2
    log INFO "pm-db-bridge-postgres-neon: starting provision binding"
    pm_neon_prepare_connection_contract
    log INFO "pm-db-bridge-postgres-neon: provision binding complete"
}

pm_db_bridge_deploy() {
    [[ "${DB_PROVIDER:-}" == postgres && "${DB_PLATFORM:-}" == neon ]] \
        || die "pm-db-bridge-postgres-neon requires postgres-neon" 2
    log INFO "pm-db-bridge-postgres-neon: starting deploy binding"
    pm_neon_prepare_connection_contract
    db_rt --tuples-only --no-align --command='SELECT 1;' >/dev/null
    log INFO "pm-db-bridge-postgres-neon: deploy binding verified"
}
