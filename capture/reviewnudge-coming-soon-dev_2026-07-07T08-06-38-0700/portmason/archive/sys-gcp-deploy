#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/sys-helpers"

# ---- Canonical vars ----
REGION="${REGION:-us-central1}"
SERVICE_NAME="${SERVICE_NAME:-${STACK}}"
#LOG_DIR="${LOG_DIR:-./logs}"
#TS="$(date -u +%Y%m%dT%H%M%SZ)"
#LOG_FILE="${LOG_DIR}/deploy_${TS}.log"
# ------------------------

echo "== SIMPLIFAI deploy start =="
echo "time: ${TS}"
echo "stack: ${STACK}"
echo "project: ${PROJECT_ID}"
echo "region: ${REGION}"
echo "service: ${SERVICE_NAME}"
echo "log: ${LOG_FILE}"
echo

if ! gcloud projects describe "${PROJECT_ID}" >/dev/null 2>&1; then
  "$(dirname "${BASH_SOURCE[0]}")/sys-gcp-init"
fi

echo "[1/3] Enabling required APIs (idempotent)…"
gcloud services enable run.googleapis.com cloudbuild.googleapis.com artifactregistry.googleapis.com

echo
echo "[2/3] Building & pushing image via Cloud Build…"
gcloud builds submit --tag "gcr.io/${PROJECT_ID}/${SERVICE_NAME}"

echo
echo "[3/3] Deploying to Cloud Run (public)…"
gcloud run deploy "${SERVICE_NAME}" \
  --image "gcr.io/${PROJECT_ID}/${SERVICE_NAME}" \
  --platform managed \
  --region "${REGION}" \
  --allow-unauthenticated

echo
echo "== DONE. Deployed service: ${SERVICE_NAME}"
echo "Open the printed URL above. Full log at: ${LOG_FILE}"
