#!/usr/bin/env bash
set -euo pipefail

: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]}")}"
export CUR_SCRIPT

# pm-configure-site-boilerplate
# Common entry logic for project-level configure-site scripts.
# Expects the calling script to define:
#   project_configure_site() { ... }
# and then `source /usr/local/bin/pm-configure-site-boilerplate`.
# This boilerplate will:
#   - establish SITE_DIR
#   - source pm-helpers (env, STACK, PROJECT_ID, adapters, runtime helpers)
#   - for WordPress runtimes, perform basic core install + theme activation
#   - finally call project_configure_site "$@"

# shellcheck "${PORTMASON_SHARE}/pm-helpers"
. "${PORTMASON_SHARE}/pm-helpers" "$@"

# At this point, pm-helpers has:
#   - loaded .env/.env.example with guardrails
#   - ensured STACK and PROJECT_ID
#   - derived RUNTIME_ADAPTER_CODE, RUNTIME_CODE, ADAPTER_CODE
#   - loaded pm-helpers-${ADAPTER_CODE} and pm-helpers-${RUNTIME_CODE}

log "Handing off to ${PORTMASON_SHARE}/pm-configure-site-${RUNTIME_CODE} ..."
. "${PORTMASON_SHARE}/pm-configure-site-${RUNTIME_CODE}" "$@"
