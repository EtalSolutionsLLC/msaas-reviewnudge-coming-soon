#!/usr/bin/env bash
set -euo pipefail

# List bash function names in a file by matching `name() {` definitions (best-effort; not a full parser).

main() {
  [[ -r "${1:-}" ]] || { echo "Usage: $0 <bash-script-file>"; exit 1; }

  grep -E '^[[:space:]]*[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\(\)[[:space:]]*\{' "$1" \
    | sed -E 's/^[[:space:]]*([a-zA-Z_][a-zA-Z0-9_]*)\s*\(\).*/\1/'
}

main "$@"
